@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>K3 Timeline - PT INDEXIM COALINDO</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #f1f5f9;
            font-family: 'Inter', sans-serif;
            color: #0f172a;
            margin: 0;
            padding: 0;
            padding-bottom: 80px;
        }
        .header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid #e2e8f0;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        }
        .header h4 {
            font-weight: 800;
            margin: 0;
            background: linear-gradient(135deg, #0f172a, #475569);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .feed-container {
            max-width: 500px;
            margin: 20px auto;
            padding: 0 10px;
        }
        .post-card {
            background: #fff;
            border-radius: 24px;
            margin-bottom: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.02);
            transition: transform 0.3s ease;
            animation: fadeIn 0.5s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .post-header {
            padding: 16px;
            display: flex;
            align-items: center;
        }
        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #e2e8f0;
            margin-right: 12px;
        }
        .user-info h6 {
            margin: 0;
            font-weight: 700;
            font-size: 14px;
            color: #1e293b;
        }
        .user-info span {
            font-size: 11px;
            color: #64748b;
        }
        .status-badge {
            margin-left: auto;
            font-size: 10px;
            font-weight: 700;
            padding: 4px 8px;
            border-radius: 10px;
            text-transform: uppercase;
        }
        .status-open { background: rgba(244, 63, 94, 0.1); color: #f43f5e; }
        .status-closed { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
        .status-neutral { background: rgba(56, 189, 248, 0.1); color: #0284c7; }
        
        .post-media {
            width: 100%;
            max-height: 500px;
            object-fit: cover;
            background-color: #f8fafc;
            border-top: 1px solid #f1f5f9;
            border-bottom: 1px solid #f1f5f9;
        }
        
        .post-actions {
            padding: 12px 16px;
            display: flex;
            gap: 16px;
        }
        .action-btn {
            background: none;
            border: none;
            padding: 0;
            color: #0f172a;
            font-size: 24px;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .action-btn:hover {
            transform: scale(1.1);
        }
        .action-btn.liked {
            color: #f43f5e;
            animation: pop 0.3s ease;
        }
        @@keyframes pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.3); }
            100% { transform: scale(1); }
        }
        
        .post-likes {
            padding: 0 16px;
            font-weight: 700;
            font-size: 13px;
            margin-bottom: 6px;
        }
        
        .post-caption {
            padding: 0 16px;
            font-size: 13px;
            margin-bottom: 8px;
        }
        .post-caption span.type-tag {
            font-weight: 700;
            color: #0284c7;
            margin-right: 4px;
        }
        
        .post-comments {
            padding: 0 16px 12px;
            font-size: 13px;
            color: #475569;
        }
        .comment-item {
            margin-bottom: 4px;
        }
        .comment-name {
            font-weight: 700;
            color: #1e293b;
            margin-right: 4px;
        }
        
        .comment-input-area {
            padding: 12px 16px;
            border-top: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
        }
        .comment-input {
            flex-grow: 1;
            border: none;
            background: transparent;
            font-size: 13px;
            outline: none;
        }
        .comment-submit {
            color: #0284c7;
            font-weight: 700;
            font-size: 13px;
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
        }
        .comment-submit:disabled {
            color: #cbd5e1;
        }
        
        .post-time {
            padding: 0 16px 16px;
            font-size: 10px;
            color: #94a3b8;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <header class="header">
        <h4><i class="bi bi-shield-fill-check me-2" style="color: #a855f7;"></i>K3 Timeline</h4>
    </header>

    <div class="feed-container" id="feedContainer">
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-3">Memuat aktivitas K3...</p>
        </div>
    </div>

    <!-- Login Prompt Modal for Guests -->
    <div class="modal fade" id="guestModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 20px; border: none;">
                <div class="modal-body p-4 text-center">
                    <h5 style="font-weight: 800; margin-bottom: 16px;">Tulis Nama Anda</h5>
                    <p class="text-muted" style="font-size: 13px;">Anda mengakses sebagai publik. Silakan masukkan nama Anda untuk berkomentar.</p>
                    <input type="text" id="guestNameInput" class="form-control mb-3" placeholder="Nama Anda..." style="border-radius: 12px; background: #f1f5f9; border: none; padding: 12px 16px;" />
                    <button class="btn btn-primary w-100" style="border-radius: 12px; padding: 12px; font-weight: 700;" onclick="saveGuestName()">Simpan & Komentar</button>
                    <button class="btn btn-light w-100 mt-2" style="border-radius: 12px; padding: 12px; font-weight: 700;" data-bs-dismiss="modal">Batal</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentFeedData = "";
        let pendingCommentAction = null;
        let isUserTyping = false;

        document.addEventListener('focusin', function(e) {
            if(e.target && e.target.classList.contains('comment-input')) {
                isUserTyping = true;
            }
        });
        
        document.addEventListener('focusout', function(e) {
            if(e.target && e.target.classList.contains('comment-input')) {
                setTimeout(() => { isUserTyping = false; }, 500); // delay release
            }
        });

        function timeAgo(dateString) {
            const date = new Date(dateString);
            const seconds = Math.floor((new Date() - date) / 1000);
            
            let interval = seconds / 31536000;
            if (interval > 1) return Math.floor(interval) + " tahun yang lalu";
            interval = seconds / 2592000;
            if (interval > 1) return Math.floor(interval) + " bulan yang lalu";
            interval = seconds / 86400;
            if (interval > 1) return Math.floor(interval) + " hari yang lalu";
            interval = seconds / 3600;
            if (interval > 1) return Math.floor(interval) + " jam yang lalu";
            interval = seconds / 60;
            if (interval > 1) return Math.floor(interval) + " menit yang lalu";
            return "Baru saja";
        }

        function getStatusClass(status) {
            if(status.toLowerCase() === 'open') return 'status-open';
            if(status.toLowerCase() === 'closed' || status.toLowerCase() === 'selesai') return 'status-closed';
            return 'status-neutral';
        }

        function renderFeed(data) {
            const container = document.getElementById('feedContainer');
            let html = '';

            data.forEach(item => {
                // Determine if user has liked locally (for guest experience)
                const isLikedLocally = localStorage.getItem(`liked_${item.type}_${item.id}`) === 'true';
                
                let commentsHtml = '';
                if(item.comments && item.comments.length > 0) {
                    item.comments.slice(-3).forEach(c => { // show last 3
                        commentsHtml += `<div class="comment-item"><span class="comment-name">${c.name}</span> ${c.text}</div>`;
                    });
                    if(item.comments.length > 3) {
                        commentsHtml = `<div class="text-muted mb-1" style="font-size: 11px;">Lihat semua ${item.comments.length} komentar</div>` + commentsHtml;
                    }
                }

                html += `
                    <div class="post-card" id="post-${item.type}-${item.id}">
                        <div class="post-header">
                            <img src="${item.userProfilePic}" class="avatar" alt="Avatar">
                            <div class="user-info">
                                <h6>${item.name}</h6>
                                <span>${item.location || 'General Area'} • ${item.department || 'All Dept'}</span>
                            </div>
                            <span class="status-badge ${getStatusClass(item.status)}">${item.status}</span>
                        </div>
                        
                        ${item.imageUrl ? `<img src="${item.imageUrl}" class="post-media" alt="Post media">` : ''}
                        
                        <div class="post-actions">
                            <button class="action-btn ${isLikedLocally ? 'liked' : ''}" onclick="toggleLike('${item.type}', ${item.id}, this)">
                                <i class="bi ${isLikedLocally ? 'bi-heart-fill' : 'bi-heart'}"></i>
                            </button>
                            <button class="action-btn" onclick="document.getElementById('input-${item.type}-${item.id}').focus()">
                                <i class="bi bi-chat"></i>
                            </button>
                            <button class="action-btn" onclick="sharePost('${item.title}')">
                                <i class="bi bi-send"></i>
                            </button>
                        </div>
                        
                        <div class="post-likes">
                            <span id="like-count-${item.type}-${item.id}">${item.likesCount}</span> suka
                        </div>
                        
                        <div class="post-caption">
                            <span class="type-tag">${item.type.toUpperCase()}</span> <b>${item.title}</b>. ${item.description || ''}
                        </div>
                        
                        <div class="post-comments" id="comments-${item.type}-${item.id}">
                            ${commentsHtml}
                        </div>
                        
                        <div class="post-time">${timeAgo(item.createdAt)}</div>
                        
                        <div class="comment-input-area">
                            <input type="text" id="input-${item.type}-${item.id}" class="comment-input" placeholder="Tambahkan komentar..." onkeyup="checkInput(this, '${item.type}', ${item.id})">
                            <button class="comment-submit" id="btn-${item.type}-${item.id}" disabled onclick="postComment('${item.type}', ${item.id})">Kirim</button>
                        </div>
                    </div>
                `;
            });

            if(html === '') html = '<div class="text-center mt-5 text-muted">Belum ada aktivitas.</div>';
            container.innerHTML = html;
        }

        async function fetchFeed() {
            // Do not override if user is typing
            if (isUserTyping) return;

            try {
                const response = await fetch('/Display/GetLatestFeed');
                const data = await response.json();
                
                // Compare to prevent annoying re-renders if nothing changed
                const dataStr = JSON.stringify(data);
                if (dataStr !== currentFeedData) {
                    currentFeedData = dataStr;
                    renderFeed(data);
                }
            } catch (error) {
                console.error("Error fetching feed:", error);
            }
        }

        function toggleLike(type, id, btn) {
            const icon = btn.querySelector('i');
            const isLiked = icon.classList.contains('bi-heart-fill');
            const countSpan = document.getElementById(`like-count-${type}-${id}`);
            let count = parseInt(countSpan.innerText);

            if(isLiked) {
                // Unlike locally
                icon.classList.remove('bi-heart-fill');
                icon.classList.add('bi-heart');
                btn.classList.remove('liked');
                count--;
                localStorage.setItem(`liked_${type}_${id}`, 'false');
            } else {
                // Like
                icon.classList.remove('bi-heart');
                icon.classList.add('bi-heart-fill');
                btn.classList.add('liked');
                count++;
                localStorage.setItem(`liked_${type}_${id}`, 'true');
                
                // Send to server
                fetch('/Display/AddLike', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ type: type, id: id })
                });
            }
            countSpan.innerText = count;
        }

        function checkInput(input, type, id) {
            const btn = document.getElementById(`btn-${type}-${id}`);
            btn.disabled = input.value.trim() === '';
            
            if(event.key === 'Enter' && !btn.disabled) {
                postComment(type, id);
            }
        }

        function postComment(type, id) {
            const input = document.getElementById(`input-${type}-${id}`);
            const text = input.value.trim();
            if(!text) return;

            // Check if user is logged in natively (since this is public page, we rely on local storage for guest name)
            // The server knows if they are logged in via cookies. If they aren't, the server uses GuestName.
            const guestName = localStorage.getItem('GuestName');
            
            // If they aren't logged in AND don't have a guest name locally, prompt them
            const isLoggedIn = '@User.Identity?.IsAuthenticated.ToString().ToLower()' === 'true';
            
            if(!isLoggedIn && !guestName) {
                pendingCommentAction = { type, id, text };
                const modal = new bootstrap.Modal(document.getElementById('guestModal'));
                modal.show();
                return;
            }

            executeCommentPost(type, id, text, guestName);
            input.value = '';
            document.getElementById(`btn-${type}-${id}`).disabled = true;
        }

        function saveGuestName() {
            const name = document.getElementById('guestNameInput').value.trim();
            if(name) {
                localStorage.setItem('GuestName', name);
                const modal = bootstrap.Modal.getInstance(document.getElementById('guestModal'));
                modal.hide();
                
                if(pendingCommentAction) {
                    executeCommentPost(pendingCommentAction.type, pendingCommentAction.id, pendingCommentAction.text, name);
                    const input = document.getElementById(`input-${pendingCommentAction.type}-${pendingCommentAction.id}`);
                    if(input) input.value = '';
                    pendingCommentAction = null;
                }
            }
        }

        async function executeCommentPost(type, id, text, guestName) {
            // Optimistic UI update
            const commentsContainer = document.getElementById(`comments-${type}-${id}`);
            const displayName = guestName || '@(User.Identity?.Name ?? "Anda")';
            commentsContainer.innerHTML += `<div class="comment-item"><span class="comment-name">${displayName}</span> ${text}</div>`;

            // Server send
            await fetch('/Display/AddComment', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ type: type, id: id, text: text, guestName: guestName })
            });
            
            // Force data refresh next tick
            currentFeedData = "";
        }

        function sharePost(title) {
            if (navigator.share) {
                navigator.share({
                    title: title,
                    text: 'Lihat pembaruan K3 ini di Portal PT INDEXIM COALINDO',
                    url: window.location.href
                });
            } else {
                alert("Salin tautan ini untuk membagikan: " + window.location.href);
            }
        }

        // Init
        fetchFeed();
        setInterval(fetchFeed, 10000); // Auto-update every 10 seconds
    </script>
</body>
</html>

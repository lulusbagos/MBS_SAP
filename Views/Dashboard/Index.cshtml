@{
    ViewData["Title"] = "Pencapaian Saya";
}

<div class="animate-fade-in">
    <div class="screen-title text-center mb-1">Pencapaian K3</div>
    <p class="screen-subtitle text-center mb-4">Statistik partisipasi K3 pribadi Anda</p>

    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="card-sap border-red-accent text-center p-3 mb-0 h-100" style="border-radius: 20px;">
                <div style="background-color: rgba(244, 63, 94, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;">
                    <i class="bi bi-exclamation-triangle-fill" style="color: var(--color-red); font-size: 20px;"></i>
                </div>
                <h3 style="font-weight: 800; color: var(--text-main); margin-bottom: 2px;">@ViewBag.HazardCount</h3>
                <span class="text-muted" style="font-size: 11px; font-weight: 600; text-transform: uppercase;">Temuan Hazard</span>
            </div>
        </div>
        <div class="col-6">
            <div class="card-sap border-primary-accent text-center p-3 mb-0 h-100" style="border-radius: 20px;">
                <div style="background-color: rgba(168, 85, 247, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;">
                    <i class="bi bi-people-fill" style="color: #a855f7; font-size: 20px;"></i>
                </div>
                <h3 style="font-weight: 800; color: var(--text-main); margin-bottom: 2px;">@ViewBag.P5mCount</h3>
                <span class="text-muted" style="font-size: 11px; font-weight: 600; text-transform: uppercase;">Briefing P5M</span>
            </div>
        </div>
        <div class="col-6">
            <div class="card-sap border-orange-accent text-center p-3 mb-0 h-100" style="border-radius: 20px;">
                <div style="background-color: rgba(249, 115, 22, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;">
                    <i class="bi bi-clipboard-check-fill" style="color: var(--color-orange); font-size: 20px;"></i>
                </div>
                <h3 style="font-weight: 800; color: var(--text-main); margin-bottom: 2px;">@ViewBag.InspectionCount</h3>
                <span class="text-muted" style="font-size: 11px; font-weight: 600; text-transform: uppercase;">Inspeksi</span>
            </div>
        </div>
        <div class="col-6">
            <div class="card-sap border-green-accent text-center p-3 mb-0 h-100" style="border-radius: 20px;">
                <div style="background-color: rgba(34, 197, 94, 0.1); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px;">
                    <i class="bi bi-check-circle-fill" style="color: var(--color-green); font-size: 20px;"></i>
                </div>
                <h3 style="font-weight: 800; color: var(--text-main); margin-bottom: 2px;">@ViewBag.ActionPlanCount</h3>
                <span class="text-muted" style="font-size: 11px; font-weight: 600; text-transform: uppercase;">Action Selesai</span>
            </div>
        </div>
    </div>

    <!-- Motivational Box -->
    <div class="card-sap" style="background: linear-gradient(135deg, rgba(56, 189, 248, 0.1), rgba(2, 132, 199, 0.05)); border: 1px solid rgba(56, 189, 248, 0.2);">
        <div class="d-flex align-items-center">
            <i class="bi bi-award-fill me-3" style="font-size: 32px; color: var(--color-primary);"></i>
            <div>
                <h6 style="font-weight: 700; color: var(--text-main); margin-bottom: 4px;">Pahlawan Keselamatan!</h6>
                <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 0;">Terima kasih atas partisipasi aktif Anda dalam menjaga lingkungan kerja yang aman di PT INDEXIM COALINDO.</p>
            </div>
        </div>
    </div>
</div>

                                    <span class="pyramid-label">INSIDEN</span>
                                    <span class="pyramid-value">@ViewBag.OpenInsiden</span>
                                </div>
                            </div>
                            <!-- KRITIS Row -->
                            <div class="pyramid-row" style="width: 48%;">
                                <div class="pyramid-bar bar-kritis" data-val="@ViewBag.OpenKritis" title="Kritis: @ViewBag.OpenKritis">

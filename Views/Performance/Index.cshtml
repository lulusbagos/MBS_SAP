            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <i class="bi bi-exclamation-triangle-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Hazard Dilaporkan</div>
                    <div style="font-size: 28px; font-weight: 900; color: #f43f5e;">@ViewBag.MyHazardsMonth</div>

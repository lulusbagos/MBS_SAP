                        <canvas id="myProporsiChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">Target Kepatuhan Detail Saya</h6>
                    <div class="d-flex flex-column gap-3 mt-3">
                        <div>
                            <div class="d-flex justify-content-between mb-1" style="font-size: 12px; font-weight: 700;">
                                <span>Hazard Report</span>
                                <span>@ViewBag.MyHazardsMonth Laporan</span>

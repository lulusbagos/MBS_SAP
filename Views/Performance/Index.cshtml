@{
    ViewData["Title"] = "Pencapaian SAP";
    var leaderboard = ViewBag.Leaderboard as List<MBS_SAP.Controllers.CompanyLeaderboardViewModel> ?? new List<MBS_SAP.Controllers.CompanyLeaderboardViewModel>();
    var trend = ViewBag.MonthlyTrend as List<MBS_SAP.Controllers.MonthlyTrendViewModel> ?? new List<MBS_SAP.Controllers.MonthlyTrendViewModel>();

    // Calculate overall weekly and monthly achievement percentage
    double weeklyProgress = ViewBag.WeeklyTarget > 0 ? (double)ViewBag.WeeklyRealization / ViewBag.WeeklyTarget * 100.0 : 0.0;
    double monthlyProgress = ViewBag.MonthlyTarget > 0 ? (double)ViewBag.MonthlyRealization / ViewBag.MonthlyTarget * 100.0 : 0.0;
    weeklyProgress = Math.Min(weeklyProgress, 100.0);
    monthlyProgress = Math.Min(monthlyProgress, 100.0);

    // Individual progress calculations
    double myMonthlyProgress = (double)ViewBag.MyTotalMonth / 4.0 * 100.0;
    myMonthlyProgress = Math.Min(myMonthlyProgress, 100.0);
    bool isMyWeekCompliant = ViewBag.MyTotalWeek >= 1;
}

<style>
    .kpi-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 20px;
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        height: 100%;
    }
    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    .kpi-icon-bg {
        position: absolute;
        right: -10px;
        bottom: -15px;
        font-size: 80px;
        color: rgba(255,255,255,0.03);
        pointer-events: none;
    }
    .chart-container {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 24px;
        height: 100%;
    }
    .leaderboard-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 8px;
    }
    .leaderboard-table thead th {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        padding: 10px 14px;
        border: none;
    }
    .leaderboard-row {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        transition: background 0.15s ease;
    }
    .leaderboard-row:hover {
        background: var(--bg-card-hover);
    }
    .leaderboard-row td {
        padding: 14px;
        vertical-align: middle;
        font-size: 13px;
        color: var(--text-main);
        border: none;
    }
    .leaderboard-row td:first-child { border-radius: 12px 0 0 12px; }
    .leaderboard-row td:last-child { border-radius: 0 12px 12px 0; }
    .progress-achievement {
        height: 8px;
        border-radius: 4px;
        background: rgba(255,255,255,0.1);
        overflow: hidden;
    }
    .badge-rank {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 12px;
    }
    .rank-1 { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #000; }
    .rank-2 { background: linear-gradient(135deg, #cbd5e1, #94a3b8); color: #000; }
    .rank-3 { background: linear-gradient(135deg, #b45309, #78350f); color: #fff; }
    .rank-default { background: rgba(255,255,255,0.1); color: var(--text-muted); }

    .tab-btn {
        border-radius: 8px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        outline: none;
    }
    .tab-active {
        background: var(--color-primary) !important;
        color: white !important;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
    }
    .tab-inactive {
        background: transparent !important;
        color: var(--text-muted) !important;
    }
    .motivation-alert {
        border-radius: 16px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        border: 1px solid transparent;
    }
    .motivation-compliant {
        background: rgba(16, 185, 129, 0.1);
        border-color: rgba(16, 185, 129, 0.2);
        color: #10b981;
    }
    .motivation-noncompliant {
        background: rgba(239, 68, 68, 0.1);
        border-color: rgba(239, 68, 68, 0.2);
        color: #ef4444;
    }
    .hierarchy-node {
        position: relative;
    }
    .hierarchy-children {
        position: relative;
        padding-left: 28px;
        margin-left: 12px;
        border-left: 1.5px dashed rgba(255, 255, 255, 0.15);
    }
    body.light-theme .hierarchy-children {
        border-left: 1.5px dashed rgba(0, 0, 0, 0.15);
    }
    .hierarchy-item {
        position: relative;
    }
    .hierarchy-item .card-sap {
        transition: all 0.2s ease;
        border-left: 3px solid transparent !important;
    }
    .hierarchy-item .card-sap:hover {
        transform: translateX(4px);
        box-shadow: 0 4px 15px rgba(3, 105, 161, 0.15);
        border-left: 3px solid var(--color-primary) !important;
        background: var(--bg-card-hover) !important;
    }
    .hierarchy-children > .hierarchy-node > .hierarchy-item::before {
        content: "";
        position: absolute;
        top: 28px;
        left: -16px;
        width: 16px;
        height: 1.5px;
        border-top: 1.5px dashed rgba(255, 255, 255, 0.15);
        z-index: 1;
    }
    body.light-theme .hierarchy-children > .hierarchy-node > .hierarchy-item::before {
        border-top: 1.5px dashed rgba(0, 0, 0, 0.15);
    }

    @@media (max-width: 767.98px) {
        .hierarchy-children {
            padding-left: 16px;
            margin-left: 6px;
        }
        .hierarchy-children > .hierarchy-node > .hierarchy-item::before {
            left: -10px;
            width: 10px;
        }
        .hierarchy-item .card-sap > div {
            flex-direction: column !important;
            align-items: flex-start !important;
        }
        .hierarchy-item .card-sap .text-end {
            text-align: left !important;
            margin-top: 12px;
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            gap: 12px !important;
            justify-content: flex-start !important;
            border-top: 1px solid var(--border-color);
            padding-top: 12px;
        }
        .hierarchy-item .card-sap .text-end > div {
            border-right: none !important;
            padding-right: 0 !important;
            min-width: 100% !important;
            margin-bottom: 0 !important;
        }
        .hierarchy-item .card-sap .text-end .d-flex {
            justify-content: flex-start !important;
        }
    }
</style>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="animate-fade-in pb-5">

    <!-- Header Banner -->
    <div class="position-relative mb-4" style="margin: -20px -20px 20px -20px;">
        <div style="background: linear-gradient(135deg, #0284c7, #0369a1); border-bottom-left-radius: 24px; border-bottom-right-radius: 24px; padding: 32px 20px 24px; text-align: center; position: relative; overflow: hidden;">
            <div style="position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
            <div style="position: absolute; bottom: -30px; left: -10px; width: 80px; height: 80px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
            <i class="bi bi-bar-chart-line-fill text-white mb-2 d-block" style="font-size: 32px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));"></i>
            <h4 style="font-weight: 800; color: white; text-shadow: 0 2px 4px rgba(0,0,0,0.2); margin-bottom: 4px;">PENCAPAIAN KINERJA SAP</h4>
            <p style="color: rgba(255,255,255,0.9); font-size: 12px; margin: 0; font-weight: 500;">Pantau kepatuhan target mingguan dan statistik bahaya perusahaan secara real-time.</p>
        </div>
    </div>

    <!-- Tabs Toggle -->
    <div class="d-flex justify-content-center mb-4">
        <div style="background: var(--bg-card); border: 1.5px solid var(--border-color); padding: 4px; border-radius: 12px; display: inline-flex; gap: 4px; flex-wrap: wrap; justify-content: center;">
            <button class="tab-btn px-4 py-2 tab-active" id="tabMy" onclick="switchTab('my')">
                <i class="bi bi-person-badge-fill me-1"></i> Pencapaian Saya
            </button>
            <button class="tab-btn px-4 py-2 tab-inactive" id="tabCompany" onclick="switchTab('company')">
                <i class="bi bi-building-fill me-1"></i> Kinerja Perusahaan
            </button>
            <button class="tab-btn px-4 py-2 tab-inactive" id="tabMonitoring" onclick="switchTab('monitoring')">
                <i class="bi bi-shield-fill-exclamation me-1"></i> Pemantauan Safety
            </button>
            <button class="tab-btn px-4 py-2 tab-inactive" id="tabHierarchy" onclick="switchTab('hierarchy')">
                <i class="bi bi-diagram-3-fill me-1"></i> Hierarki Perusahaan
            </button>
        </div>
    </div>

    <!-- ==================== SECTION 1: PENCAPAIAN SAYA ==================== -->
    <div id="sectionMy">
        <!-- Motivation Banner & Gamification Badge Row -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-8">
                @if (isMyWeekCompliant)
                {
                    <div class="motivation-alert motivation-compliant h-100 mb-0 animate-fade-in">
                        <i class="bi bi-trophy-fill" style="font-size: 32px; flex-shrink: 0;"></i>
                        <div>
                            <h6 class="mb-1" style="font-weight: 800;">Target Minggu Ini Tercapai!</h6>
                            <p class="mb-2" style="font-size: 12px; opacity: 0.9;">Luar biasa! Anda telah mengunggah laporan SAP untuk minggu ini. Terima kasih atas komitmen Anda dalam menjaga keselamatan kerja.</p>
                            <span style="font-size: 11px; font-weight: 700; background: rgba(255,255,255,0.15); padding: 4px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 6px;">
                                <i class="bi bi-graph-up-arrow"></i> Laporan Anda menyumbang @ViewBag.MyContributionShare% dari seluruh aktivitas perusahaan bulan ini!
                            </span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="motivation-alert motivation-noncompliant h-100 mb-0 animate-fade-in">
                        <i class="bi bi-bell-fill" style="font-size: 32px; animation: pulse 2s infinite; flex-shrink: 0;"></i>
                        <div>
                            <h6 class="mb-1" style="font-weight: 800;">Belum Memenuhi Target Kepatuhan!</h6>
                            <p class="mb-2" style="font-size: 12px; opacity: 0.9;">Ayo! Anda belum mengirimkan minimal 1 laporan SAP untuk minggu ini. Segera buat laporan Hazard atau Inspeksi demi keselamatan area kerja Anda.</p>
                            <span style="font-size: 11px; font-weight: 700; background: rgba(255,255,255,0.15); padding: 4px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 6px;">
                                <i class="bi bi-graph-up-arrow"></i> Laporan Anda menyumbang @ViewBag.MyContributionShare% dari seluruh aktivitas perusahaan bulan ini!
                            </span>
                        </div>
                    </div>
                }
            </div>

            <div class="col-12 col-lg-4">
                <div class="kpi-card text-center d-flex flex-column align-items-center justify-content-center py-4">
                    <i class="bi @ViewBag.MyBadgeIcon" style="font-size: 40px; color: @ViewBag.MyBadgeColor; filter: drop-shadow(0 2px 8px @ViewBag.MyBadgeColor);"></i>
                    <h6 class="mt-2 mb-1" style="font-weight: 800; color: var(--text-main); font-size: 14px;">Lencana Kepatuhan Saya</h6>
                    <span style="font-size: 13px; font-weight: 700; color: @ViewBag.MyBadgeColor; background: rgba(255,255,255,0.05); padding: 2px 10px; border-radius: 20px;">@ViewBag.MyBadgeName</span>
                    <p class="mb-0 text-muted" style="font-size: 10px; margin-top: 6px; font-weight: 500;">Tingkatkan kontribusi mingguan Anda untuk menaikkan rank Lencana Anda!</p>
                </div>
            </div>
        </div>

        <!-- Daily Safety Reminder Box -->
        @{
            string safetyTip = DateTime.Now.DayOfWeek switch
            {
                DayOfWeek.Monday => "Monday Mindset: Pastikan alat pelindung diri (APD) terpasang lengkap sebelum memulai pekerjaan lapangan.",
                DayOfWeek.Tuesday => "Housekeeping: Rapikan kabel, peralatan, dan material di sekitar Anda. Area bersih adalah area aman.",
                DayOfWeek.Wednesday => "Ergonomi Kerja: Lakukan peregangan otot ringan dan jaga postur tubuh saat mengangkat barang berat.",
                DayOfWeek.Thursday => "Kelistrikan & Alat: Laporkan segera jika menemukan isolasi kabel rusak atau alat kerja yang tidak layak pakai.",
                DayOfWeek.Friday => "Fokus Akhir Pekan: Jangan terburu-buru menyelesaikan pekerjaan tanpa menghiraukan rambu-rambu keselamatan.",
                _ => "Gaya Hidup Sehat: Istirahat cukup untuk menjaga stamina dan fokus optimal saat kembali bertugas."
            };
        }
        <div class="card-sap p-3 mb-4 border-0 animate-fade-in" style="background: rgba(245, 158, 11, 0.08); border-left: 4px solid #f59e0b !important; border-radius: 12px;">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; background: rgba(245, 158, 11, 0.15); border-radius: 50%;">
                    <i class="bi bi-lightbulb-fill text-warning" style="font-size: 16px;"></i>
                </div>
                <div>
                    <div style="font-size: 10px; font-weight: 800; text-transform: uppercase; color: #f59e0b; letter-spacing: 0.5px;">Reminder K3 Hari Ini</div>
                    <p class="mb-0" style="font-size: 12px; font-weight: 600; color: var(--text-main);">@safetyTip</p>
                </div>
            </div>
        </div>

        <!-- My KPI Cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <i class="bi bi-calendar-check-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Status Minggu Ini</div>
                    <div style="font-size: 22px; font-weight: 900; color: @(isMyWeekCompliant ? "#10b981" : "#ef4444");">
                        @(isMyWeekCompliant ? "PATUH (OK)" : "BELUM PATUH")
                    </div>
                    <div class="text-muted mt-1" style="font-size: 11px;">Target: Minimal 1 laporan/minggu</div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <i class="bi bi-award-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Pencapaian Bulan Ini</div>
                    <div style="font-size: 28px; font-weight: 900; color: #f59e0b;">@ViewBag.MyTotalMonth <span style="font-size: 14px; font-weight: 500; color: var(--text-muted);">/ 4 Target</span></div>
                    <div class="mt-2">
                        <div class="progress-achievement">
                            <div class="progress-bar bg-warning" style="width: @(myMonthlyProgress)%; height: 100%;"></div>
                        </div>
                        <span class="text-muted" style="font-size: 10px;">Progress: @Math.Round(myMonthlyProgress)%</span>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <i class="bi bi-exclamation-triangle-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Hazard Dilaporkan</div>
                    <div style="font-size: 28px; font-weight: 900; color: #f43f5e;">@ViewBag.MyHazardsMonth</div>
                    <div class="text-muted" style="font-size: 11px;">Bahaya yang Anda temukan (Bulan Ini)</div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="kpi-card">
                    <i class="bi bi-shield-fill-check kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Lainnya (Bulan Ini)</div>
                    <div style="font-size: 13px; font-weight: 700; color: var(--text-main); line-height: 1.6;">
                        📋 Inspeksi: <strong>@ViewBag.MyInspectionsMonth</strong> <br />
                        📢 Safety Talk: <strong>@ViewBag.MySafetyTalksMonth</strong> <br />
                        👥 P5M: <strong>@ViewBag.MyP5msMonth</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- My Activity Distribution -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">Proporsi Laporan Saya (Bulan Ini)</h6>
                    <div style="height: 250px; display: flex; align-items: center; justify-content: center;">
                        <canvas id="myProporsiChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">Target Kepatuhan Detail Saya</h6>
                    <div class="d-flex flex-column gap-3 mt-3">
                        <div>
                            <div class="d-flex justify-content-between mb-1" style="font-size: 12px; font-weight: 700;">
                                <span>Hazard Report</span>
                                <span>@ViewBag.MyHazardsMonth Laporan</span>
                            </div>
                            <div class="progress-achievement" style="height: 10px;">
                                <div class="progress-bar bg-danger" style="width: @(Math.Min((double)ViewBag.MyHazardsMonth / 2.0 * 100.0, 100.0))%;"></div>
                            </div>
                        </div>

                        <div>
                            <div class="d-flex justify-content-between mb-1" style="font-size: 12px; font-weight: 700;">
                                <span>Safety Inspection</span>
                                <span>@ViewBag.MyInspectionsMonth Laporan</span>
                            </div>
                            <div class="progress-achievement" style="height: 10px;">
                                <div class="progress-bar bg-primary" style="width: @(Math.Min((double)ViewBag.MyInspectionsMonth / 1.0 * 100.0, 100.0))%;"></div>
                            </div>
                        </div>

                        <div>
                            <div class="d-flex justify-content-between mb-1" style="font-size: 12px; font-weight: 700;">
                                <span>Safety Talk</span>
                                <span>@ViewBag.MySafetyTalksMonth Kali</span>
                            </div>
                            <div class="progress-achievement" style="height: 10px;">
                                <div class="progress-bar bg-warning" style="width: @(Math.Min((double)ViewBag.MySafetyTalksMonth / 1.0 * 100.0, 100.0))%;"></div>
                            </div>
                        </div>

                        <div>
                            <div class="d-flex justify-content-between mb-1" style="font-size: 12px; font-weight: 700;">
                                <span>P5M Pre-Start</span>
                                <span>@ViewBag.MyP5msMonth Kali</span>
                            </div>
                            <div class="progress-achievement" style="height: 10px;">
                                <div class="progress-bar bg-success" style="width: @(Math.Min((double)ViewBag.MyP5msMonth / 1.0 * 100.0, 100.0))%;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== SECTION 2: PENCAPAIAN PERUSAHAAN ==================== -->
    <div id="sectionCompany" style="display: none;">
        <!-- KPI Summary Grid (5 Columns Layout) -->
        <div class="row g-3 mb-4 row-cols-2 row-cols-md-3 row-cols-lg-5 justify-content-center animate-fade-in">
            <!-- Total Karyawan -->
            <div class="col">
                <div class="kpi-card">
                    <i class="bi bi-people-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Total Karyawan</div>
                    <div style="font-size: 24px; font-weight: 900; color: #38bdf8;">@ViewBag.TotalKaryawan</div>
                    <div class="text-muted" style="font-size: 10px;">Karyawan aktif terdaftar</div>
                </div>
            </div>

            <!-- Target vs Realisasi Minggu Ini -->
            <div class="col">
                <div class="kpi-card">
                    <i class="bi bi-calendar-event-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Minggu Ini</div>
                    <div style="font-size: 24px; font-weight: 900; color: #10b981;">@ViewBag.WeeklyRealization <span style="font-size: 12px; font-weight: 500; color: var(--text-muted);">/ @ViewBag.WeeklyTarget</span></div>
                    <div class="mt-2">
                        <div class="progress-achievement" style="height: 6px;">
                            <div class="progress-bar bg-success" style="width: @(weeklyProgress)%; height: 100%;"></div>
                        </div>
                        <span class="text-muted" style="font-size: 9px;">Pencapaian: @Math.Round(weeklyProgress)%</span>
                    </div>
                </div>
            </div>

            <!-- Target vs Realisasi Bulan Ini -->
            <div class="col">
                <div class="kpi-card">
                    <i class="bi bi-calendar-month-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Bulan Ini</div>
                    <div style="font-size: 24px; font-weight: 900; color: #f59e0b;">@ViewBag.MonthlyRealization <span style="font-size: 12px; font-weight: 500; color: var(--text-muted);">/ @ViewBag.MonthlyTarget</span></div>
                    <div class="mt-2">
                        <div class="progress-achievement" style="height: 6px;">
                            <div class="progress-bar bg-warning" style="width: @(monthlyProgress)%; height: 100%;"></div>
                        </div>
                        <span class="text-muted" style="font-size: 9px;">Pencapaian: @Math.Round(monthlyProgress)%</span>
                    </div>
                </div>
            </div>

            <!-- Hazard Aktif (Open) -->
            <div class="col">
                <div class="kpi-card">
                    <i class="bi bi-exclamation-triangle-fill kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Hazard Open</div>
                    <div style="font-size: 24px; font-weight: 900; color: #f43f5e;">@ViewBag.TotalOpenHazards <span style="font-size: 12px; font-weight: 500; color: var(--text-muted);">Open</span></div>
                    <div class="text-muted" style="font-size: 10px;">@ViewBag.TotalClosedHazards diselesaikan</div>
                </div>
            </div>

            <!-- Rata-rata Kecepatan Perbaikan Temuan -->
            <div class="col">
                <div class="kpi-card">
                    <i class="bi bi-speedometer kpi-icon-bg"></i>
                    <div class="text-muted mb-1" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Avg Closure</div>
                    <div style="font-size: 24px; font-weight: 900; color: #a855f7;">@ViewBag.AvgClosureDays <span style="font-size: 12px; font-weight: 500; color: var(--text-muted);">Hari</span></div>
                    <div class="text-muted" style="font-size: 10px;">Rata-rata durasi perbaikan</div>
                </div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="row g-3 mb-4 animate-fade-in">
            <!-- Doughnut 1: Proporsi Aktivitas -->
            <div class="col-12 col-md-6">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">Proporsi Aktivitas SAP (Bulan Ini)</h6>
                    <div style="height: 250px; display: flex; align-items: center; justify-content: center;">
                        <canvas id="proporsiChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Doughnut 2: Hazard Open by Risk -->
            <div class="col-12 col-md-6">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">Hazard Aktif (Open) Berdasarkan Risiko</h6>
                    <div style="height: 250px; display: flex; align-items: center; justify-content: center;">
                        <canvas id="risikoChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Line Chart: Tren Bulanan -->
        <div class="row mb-4 animate-fade-in">
            <div class="col-12">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">Tren Aktivitas SAP (6 Bulan Terakhir)</h6>
                    <div style="height: 300px; position: relative;">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Leaderboard Chart -->
        <div class="row mb-4 animate-fade-in">
            <div class="col-12">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">Grafik Perbandingan Kepatuhan Perusahaan (%)</h6>
                    <div style="height: 300px; position: relative;">
                        <canvas id="leaderboardChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Leaderboard Table -->
        <div class="row animate-fade-in">
            <div class="col-12">
                <div class="chart-container">
                    <h6 class="mb-3" style="font-weight: 700;">@(ViewBag.IsAdmin == true ? "Leaderboard Kepatuhan Perusahaan (Bulan Ini)" : "Pencapaian Kepatuhan Perusahaan (Bulan Ini)")</h6>
                    <div class="table-responsive">
                        <table class="leaderboard-table">
                            <thead>
                                <tr>
                                    @if (ViewBag.IsAdmin == true)
                                    {
                                        <th style="width: 60px;">Rank</th>
                                    }
                                    <th>Perusahaan</th>
                                    <th style="width: 120px;" class="text-center">Karyawan Aktif</th>
                                    <th style="width: 140px;" class="text-center">Aktivitas Dilaporkan</th>
                                    <th style="width: 140px;" class="text-center">Target Kepatuhan</th>
                                    <th class="text-end" style="width: 200px;">Pencapaian (%)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int rank = 1;
                                    foreach (var comp in leaderboard)
                                    {
                                        string rankClass = rank switch
                                        {
                                            1 => "rank-1",
                                            2 => "rank-2",
                                            3 => "rank-3",
                                            _ => "rank-default"
                                        };
                                        <tr class="leaderboard-row">
                                            @if (ViewBag.IsAdmin == true)
                                            {
                                                <td>
                                                    <div class="badge-rank @rankClass">@rank</div>
                                                </td>
                                            }
                                            <td style="font-weight: 700;">@comp.CompanyName</td>
                                            <td class="text-center" style="font-family: monospace; font-weight: 600;">@comp.ActiveEmployees</td>
                                            <td class="text-center" style="font-family: monospace; font-weight: 600; color: #38bdf8;">@comp.TotalSubmissions</td>
                                            <td class="text-center" style="font-family: monospace; font-weight: 600; color: var(--text-muted);">@comp.TargetSubmissions</td>
                                            <td>
                                                <div class="d-flex align-items-center justify-content-end gap-2">
                                                    <div class="flex-grow-1" style="max-width: 100px;">
                                                        <div class="progress-achievement">
                                                            @{
                                                                string barColor = "bg-danger";
                                                                if (comp.AchievementRate >= 100) barColor = "bg-success";
                                                                else if (comp.AchievementRate >= 50) barColor = "bg-warning";
                                                            }
                                                            <div class="progress-bar @barColor" style="width: @Math.Min(comp.AchievementRate, 100.0)%; height: 100%;"></div>
                                                        </div>
                                                    </div>
                                                    <span style="font-family: monospace; font-weight: 800; font-size: 13px; color: @(comp.AchievementRate >= 100 ? "#10b981" : comp.AchievementRate >= 50 ? "#f59e0b" : "#f43f5e")">
                                                        @comp.AchievementRate%
                                                    </span>
                                                </div>
                                            </td>
                                        </tr>
                                        rank++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    @{
        var uncompliantWeek = ViewBag.UncompliantWeek as List<MBS_SAP.Controllers.UncompliantEmployeeViewModel> ?? new List<MBS_SAP.Controllers.UncompliantEmployeeViewModel>();
        var uncompliantMonth = ViewBag.UncompliantMonth as List<MBS_SAP.Controllers.UncompliantEmployeeViewModel> ?? new List<MBS_SAP.Controllers.UncompliantEmployeeViewModel>();
        var companyHistory = ViewBag.CompanyHistory as List<MBS_SAP.Controllers.PerformanceHistoryViewModel> ?? new List<MBS_SAP.Controllers.PerformanceHistoryViewModel>();
    }

        <div id="sectionMonitoring" style="display: none;" class="animate-fade-in">
            <!-- Monitoring Options -->
            <div class="card-sap p-3 mb-4 border-0" style="border-radius: 16px;">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div>
                        <h6 class="mb-1" style="font-weight: 800;">Safety Officer Monitoring Panel</h6>
                        <p class="mb-0 text-muted" style="font-size: 11px;">Pantau kepatuhan pengisian SAP karyawan dan unduh laporan yang tidak patuh.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="DownloadUncompliantReport" asp-route-range="week" class="btn btn-sm px-3 py-2 text-white" style="background: var(--color-primary); border-radius: 8px; font-weight: 700; font-size: 12px; text-decoration: none;">
                            <i class="bi bi-file-earmark-excel-fill me-1"></i> Download Belum SAP (Minggu Ini)
                        </a>
                        <a asp-action="DownloadUncompliantReport" asp-route-range="month" class="btn btn-sm px-3 py-2 text-white" style="background: var(--color-primary); border-radius: 8px; font-weight: 700; font-size: 12px; text-decoration: none;">
                            <i class="bi bi-file-earmark-excel-fill me-1"></i> Download Belum SAP (Bulan Ini)
                        </a>
                    </div>
                </div>
            </div>

            <!-- Monitoring Grid -->
            <div class="row g-3">
                <!-- Panel Left: Uncompliant Employees List -->
                <div class="col-12 col-lg-6">
                    <div class="chart-container" style="max-height: 550px; display: flex; flex-direction: column;">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h6 style="font-weight: 700; margin: 0;">Karyawan Belum Mengisi SAP</h6>
                            <select id="uncompliantPeriodSelect" class="form-select-sm" style="background: var(--bg-layout); border: 1.5px solid var(--border-color); color: var(--text-main); border-radius: 6px; font-weight: 600;" onchange="toggleUncompliantPeriod(this.value)">
                                <option value="week">Minggu Ini (@uncompliantWeek.Count Orang)</option>
                                <option value="month">Bulan Ini (@uncompliantMonth.Count Orang)</option>
                            </select>
                        </div>
                        
                        <!-- Search Box for Uncompliant -->
                        <div class="mb-3">
                            <input type="text" id="searchUncompliant" class="input-sap" placeholder="🔍 Cari nama atau NIK..." style="height: 36px; font-size: 12px;" oninput="filterUncompliant(this.value)" />
                        </div>

                        <!-- Uncompliant List Wrapper -->
                        <div class="table-responsive flex-grow-1" style="overflow-y: auto; max-height: 380px;">
                            <table class="table table-sm text-start align-middle" style="color: var(--text-main); font-size: 12px;">
                                <thead>
                                    <tr style="border-bottom: 2px solid var(--border-color);">
                                        <th>NIK</th>
                                        <th>Nama Lengkap</th>
                                        <th>Departemen</th>
                                        <th class="text-end">Jumlah</th>
                                    </tr>
                                </thead>
                                <tbody id="uncompliantTableBody">
                                    <!-- Week Items -->
                                    @foreach (var emp in uncompliantWeek)
                                    {
                                        <tr class="uncompliant-item item-week" data-search="@emp.Nama.ToLower() @emp.Nik.ToLower()">
                                            <td style="font-family: monospace; font-weight: 600;">@emp.Nik</td>
                                            <td style="font-weight: 700;">@emp.Nama</td>
                                            <td>@emp.Departemen</td>
                                            <td class="text-end text-danger" style="font-weight: 700;">0/1</td>
                                        </tr>
                                    }
                                    <!-- Month Items -->
                                    @foreach (var emp in uncompliantMonth)
                                    {
                                        <tr class="uncompliant-item item-month" data-search="@emp.Nama.ToLower() @emp.Nik.ToLower()" style="display: none;">
                                            <td style="font-family: monospace; font-weight: 600;">@emp.Nik</td>
                                            <td style="font-weight: 700;">@emp.Nama</td>
                                            <td>@emp.Departemen</td>
                                            <td class="text-end text-warning" style="font-weight: 700;">@emp.SubmissionCount/4</td>
                                        </tr>
                                    }
                                    @if (uncompliantWeek.Count == 0 && uncompliantMonth.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">Semua karyawan sudah mematuhi kepatuhan SAP.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Panel Right: Company History Activity -->
                <div class="col-12 col-lg-6">
                    <div class="chart-container" style="max-height: 550px; display: flex; flex-direction: column;">
                        <h6 style="font-weight: 700;" class="mb-3">History Input SAP Perusahaan</h6>
                        
                        <!-- Search Box for History -->
                        <div class="mb-3">
                            <input type="text" id="searchHistory" class="input-sap" placeholder="🔍 Cari aktivitas, nama, atau NIK..." style="height: 36px; font-size: 12px;" oninput="filterHistory(this.value)" />
                        </div>

                        <!-- History List Wrapper -->
                        <div class="table-responsive flex-grow-1" style="overflow-y: auto; max-height: 430px;">
                            <table class="table table-sm text-start align-middle" style="color: var(--text-main); font-size: 12px;">
                                <thead>
                                    <tr style="border-bottom: 2px solid var(--border-color);">
                                        <th style="width: 90px;">Tanggal</th>
                                        <th>Pengirim</th>
                                        <th>Modul</th>
                                        <th>Detail/Lokasi</th>
                                    </tr>
                                </thead>
                                <tbody id="historyTableBody">
                                    @foreach (var item in companyHistory)
                                    {
                                        string badgeClass = item.Type switch
                                        {
                                            "Hazard" => "bg-danger",
                                            "Inspection" => "bg-primary",
                                            "SafetyTalk" => "bg-warning text-dark",
                                            "P5m" => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                        <tr class="history-item" data-search="@item.User.ToLower() @item.Nik.ToLower() @item.Title.ToLower() @item.Description.ToLower()">
                                            <td style="font-size: 10px; color: var(--text-muted);">@item.Date.ToString("dd MMM HH:mm")</td>
                                            <td>
                                                <div style="font-weight: 700;">@item.User</div>
                                                <div style="font-size: 10px; font-family: monospace; color: var(--text-muted);">@item.Nik</div>
                                            </td>
                                            <td>
                                                <span class="badge @badgeClass" style="font-size: 9px; font-weight: 800; text-transform: uppercase; padding: 4px 6px;">@item.Type</span>
                                            </td>
                                            <td>
                                                <div style="font-weight: 600;">@item.Title</div>
                                                <div style="font-size: 10px; color: var(--text-muted); max-width: 250px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;" title="@item.Description">@item.Description</div>
                                            </td>
                                        </tr>
                                    }
                                    @if (companyHistory.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">Belum ada riwayat aktivitas yang terekam.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    @{
        var hierarchy = ViewBag.CompanyHierarchy as List<MBS_SAP.Controllers.CompanyHierarchyNode> ?? new List<MBS_SAP.Controllers.CompanyHierarchyNode>();

        void RenderNode(MBS_SAP.Controllers.CompanyHierarchyNode node, int level = 0)
        {
            var hasChildren = node.Children != null && node.Children.Count > 0;
            var collapseId = $"collapse_comp_{node.CompanyId}";
            var progressColor = node.CumulativeAchievementRate >= 100 ? "bg-success" : (node.CumulativeAchievementRate >= 50 ? "bg-warning" : "bg-danger");
            var ownProgressColor = node.OwnAchievementRate >= 100 ? "bg-success" : (node.OwnAchievementRate >= 50 ? "bg-warning" : "bg-danger");

            <div class="hierarchy-node">
                <div class="hierarchy-item mb-2">
                    <div class="card-sap p-3 border-0 position-relative animate-fade-in" style="border-radius: 14px; background: var(--bg-card);">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            
                            <!-- Left: Collapse toggle + Name -->
                            <div class="d-flex align-items-center gap-2" style="min-width: 250px; flex-grow: 1;">
                                @if (hasChildren)
                                {
                                    <button class="btn btn-sm p-0 border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="true" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.05); border-radius: 6px; z-index: 2;">
                                        <i class="bi bi-chevron-down toggle-icon" style="transition: transform 0.2s;"></i>
                                    </button>
                                }
                                else
                                {
                                    <div style="width: 24px;"></div>
                                }
                                <div>
                                    <div style="font-weight: 800; font-size: 13px; color: var(--text-main);">
                                        @node.CompanyName
                                    </div>
                                    <span class="text-muted" style="font-size: 10px;">ID Perusahaan: @node.CompanyId</span>
                                </div>
                            </div>

                            <!-- Right Stats Grid: Own vs Cumulative -->
                            <div class="d-flex align-items-center gap-4 flex-wrap text-end">
                                
                                <!-- Own Stats -->
                                <div style="min-width: 130px; border-right: 1px solid var(--border-color); padding-right: 16px;">
                                    <div class="text-muted" style="font-size: 9px; font-weight: 700; text-transform: uppercase;">Direct (Mandiri)</div>
                                    <div style="font-size: 11px; font-weight: 600;">
                                        <i class="bi bi-people me-1"></i>@node.OwnEmployees Karyawan
                                    </div>
                                    <div style="font-size: 11px; font-weight: 600; color: var(--color-primary);">
                                        <i class="bi bi-file-earmark-text me-1"></i>@node.OwnSubmissions/@node.OwnTarget SAP
                                    </div>
                                    <div class="d-flex align-items-center justify-content-end gap-2 mt-1">
                                        <div class="progress-achievement" style="width: 60px; height: 6px;">
                                            <div class="progress-bar @ownProgressColor" style="width: @Math.Min(node.OwnAchievementRate, 100.0)%;"></div>
                                        </div>
                                        <span style="font-size: 10px; font-weight: 800;" class="text-white">@node.OwnAchievementRate%</span>
                                    </div>
                                </div>

                                <!-- Cumulative (Group) Stats -->
                                <div style="min-width: 140px;">
                                    <div class="text-muted" style="font-size: 9px; font-weight: 700; text-transform: uppercase;">Group (Kumulatif)</div>
                                    <div style="font-size: 11px; font-weight: 600;">
                                        <i class="bi bi-people-fill me-1"></i>@node.CumulativeEmployees Karyawan
                                    </div>
                                    <div style="font-size: 11px; font-weight: 600; color: var(--color-primary);">
                                        <i class="bi bi-file-earmark-bar-graph-fill me-1"></i>@node.CumulativeSubmissions/@node.CumulativeTarget SAP
                                    </div>
                                    <div class="d-flex align-items-center justify-content-end gap-2 mt-1">
                                        <div class="progress-achievement" style="width: 60px; height: 6px;">
                                            <div class="progress-bar @progressColor" style="width: @Math.Min(node.CumulativeAchievementRate, 100.0)%;"></div>
                                        </div>
                                        <span style="font-size: 10px; font-weight: 800;" class="text-white">@node.CumulativeAchievementRate%</span>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                @if (hasChildren)
                {
                    <div class="collapse show" id="@collapseId">
                        <div class="hierarchy-children">
                            @foreach (var child in node.Children!)
                            {
                                RenderNode(child, level + 1);
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

        <div id="sectionHierarchy" style="display: none;" class="animate-fade-in">
            <!-- Header Card -->
            <div class="card-sap p-4 mb-4 border-0" style="border-radius: 16px;">
                <h5 class="mb-1" style="font-weight: 800;"><i class="bi bi-diagram-3 me-2 text-primary"></i>Struktur Hierarki & Pencapaian SAP Perusahaan</h5>
                <p class="text-muted mb-0" style="font-size: 12px;">Berikut adalah pemetaan kepatuhan SAP berdasarkan bagan hierarki parent-child (kontraktor utama & sub-kontraktor). Statistik kumulatif menggabungkan data perusahaan tersebut beserta seluruh sub-kontraktor di bawahnya.</p>
                <div class="mt-3 position-relative">
                    <i class="bi bi-search position-absolute text-muted" style="left: 14px; top: 12px; font-size: 14px;"></i>
                    <input type="text" id="hierarchySearchInput" class="form-control ps-5" placeholder="Cari nama perusahaan atau ID..." style="background: rgba(255,255,255,0.03); border: 1.5px solid var(--border-color); border-radius: 10px; color: var(--text-main); font-size: 13px; height: 42px;" onkeyup="filterHierarchyTree()">
                </div>

                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <button class="btn btn-sm btn-outline-light" onclick="expandAllHierarchy()" style="border-radius: 8px; font-weight: 600; font-size: 11px; padding: 6px 12px;">
                        <i class="bi bi-plus-lg me-1"></i>Expand Semua
                    </button>
                    <button class="btn btn-sm btn-outline-light" onclick="collapseAllHierarchy()" style="border-radius: 8px; font-weight: 600; font-size: 11px; padding: 6px 12px;">
                        <i class="bi bi-dash-lg me-1"></i>Collapse Semua
                    </button>
                </div>
            </div>

            <!-- Tree Roots Container -->
            <div class="hierarchy-tree-container">
                @foreach (var root in hierarchy)
                {
                    RenderNode(root, 0);
                }
                
                @if (hierarchy.Count == 0)
                {
                    <div class="text-center text-muted py-5 card-sap border-0" style="border-radius: 16px;">
                        <i class="bi bi-info-circle" style="font-size: 32px;"></i>
                        <p class="mt-2 mb-0" style="font-size: 13px;">Tidak ada data hierarki perusahaan yang terdaftar.</p>
                    </div>
                }
            </div>
        </div>
</div>

<!-- Charts & Tabs Handling Script -->
@section Scripts {
<script>
    function switchTab(tab) {
        document.getElementById('sectionMy').style.display = tab === 'my' ? 'block' : 'none';
        document.getElementById('sectionCompany').style.display = tab === 'company' ? 'block' : 'none';
        
        const monitorSec = document.getElementById('sectionMonitoring');
        if (monitorSec) {
            monitorSec.style.display = tab === 'monitoring' ? 'block' : 'none';
        }

        const hierarchySec = document.getElementById('sectionHierarchy');
        if (hierarchySec) {
            hierarchySec.style.display = tab === 'hierarchy' ? 'block' : 'none';
        }

        document.getElementById('tabMy').className = 'tab-btn px-4 py-2 ' + (tab === 'my' ? 'tab-active' : 'tab-inactive');
        document.getElementById('tabCompany').className = 'tab-btn px-4 py-2 ' + (tab === 'company' ? 'tab-active' : 'tab-inactive');
        
        const tabMon = document.getElementById('tabMonitoring');
        if (tabMon) {
            tabMon.className = 'tab-btn px-4 py-2 ' + (tab === 'monitoring' ? 'tab-active' : 'tab-inactive');
        }

        const tabHier = document.getElementById('tabHierarchy');
        if (tabHier) {
            tabHier.className = 'tab-btn px-4 py-2 ' + (tab === 'hierarchy' ? 'tab-active' : 'tab-inactive');
        }
    }

    function toggleUncompliantPeriod(period) {
        const query = document.getElementById('searchUncompliant').value.toLowerCase();
        if (period === 'week') {
            $('.item-week').show();
            $('.item-month').hide();
        } else {
            $('.item-week').hide();
            $('.item-month').show();
        }
        if (query) {
            filterUncompliant(query);
        }
    }

    function filterUncompliant(query) {
        const q = query.toLowerCase();
        const activePeriod = document.getElementById('uncompliantPeriodSelect').value;
        const selector = activePeriod === 'week' ? '.item-week' : '.item-month';

        $(selector).each(function() {
            const data = $(this).data('search') || '';
            $(this).toggle(data.indexOf(q) !== -1);
        });
    }

    function filterHistory(query) {
        const q = query.toLowerCase();
        $('.history-item').each(function() {
            const data = $(this).data('search') || '';
            $(this).toggle(data.indexOf(q) !== -1);
        });
    }

    document.addEventListener("DOMContentLoaded", function () {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark' || 
                       (!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
        
        const textColor = isDark ? '#cbd5e1' : '#334155';
        const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';

        // 1. Chart Proporsi Aktivitas Saya
        const ctxMyProp = document.getElementById('myProporsiChart').getContext('2d');
        new Chart(ctxMyProp, {
            type: 'doughnut',
            data: {
                labels: ['Hazard', 'Inspeksi', 'Safety Talk', 'P5M'],
                datasets: [{
                    data: [@ViewBag.MyHazardsMonth, @ViewBag.MyInspectionsMonth, @ViewBag.MySafetyTalksMonth, @ViewBag.MyP5msMonth],
                    backgroundColor: ['#f43f5e', '#3b82f6', '#a855f7', '#10b981'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { weight: 'bold', size: 11 } }
                    }
                }
            }
        });

        // 2. Chart Proporsi Aktivitas Perusahaan
        const ctxProp = document.getElementById('proporsiChart').getContext('2d');
        new Chart(ctxProp, {
            type: 'doughnut',
            data: {
                labels: ['Hazard', 'Inspeksi', 'Safety Talk', 'P5M'],
                datasets: [{
                    data: [@ViewBag.MonthHazards, @ViewBag.MonthInspections, @ViewBag.MonthSafetyTalks, @ViewBag.MonthP5ms],
                    backgroundColor: ['#f43f5e', '#3b82f6', '#a855f7', '#10b981'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { weight: 'bold', size: 11 } }
                    }
                }
            }
        });

        // 3. Chart Risiko Hazard Open
        const ctxRisiko = document.getElementById('risikoChart').getContext('2d');
        new Chart(ctxRisiko, {
            type: 'pie',
            data: {
                labels: ['Ringan (Low)', 'Sedang (Medium)', 'Berat (High)', 'Sangat Berat (Extreme)'],
                datasets: [{
                    data: [@ViewBag.OpenLow, @ViewBag.OpenMedium, @ViewBag.OpenHigh, @ViewBag.OpenExtreme],
                    backgroundColor: ['#10b981', '#f59e0b', '#ef4444', '#7f1d1d'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { weight: 'bold', size: 11 } }
                    }
                }
            }
        });

        // 4. Chart Tren Bulanan
        const ctxTrend = document.getElementById('trendChart').getContext('2d');
        
        const labels = [];
        const hazardData = [];
        const inspectData = [];
        const talkData = [];
        const p5mData = [];

        @foreach (var item in trend)
        {
            <text>
                labels.push('@item.MonthLabel');
                hazardData.push(@item.Hazards);
                inspectData.push(@item.Inspections);
                talkData.push(@item.SafetyTalks);
                p5mData.push(@item.P5ms);
            </text>
        }

        new Chart(ctxTrend, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Hazard',
                        data: hazardData,
                        borderColor: '#f43f5e',
                        backgroundColor: 'rgba(244,63,94,0.1)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 3
                    },
                    {
                        label: 'Inspeksi',
                        data: inspectData,
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59,130,246,0.1)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 3
                    },
                    {
                        label: 'Safety Talk',
                        data: talkData,
                        borderColor: '#a855f7',
                        backgroundColor: 'rgba(168,85,247,0.1)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 3
                    },
                    {
                        label: 'P5M',
                        data: p5mData,
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16,185,129,0.1)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 3
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { color: textColor, font: { weight: 'bold' } }
                    }
                },
                scales: {
                    x: {
                        grid: { color: gridColor },
                        ticks: { color: textColor, font: { weight: 'bold' } }
                    },
                    y: {
                        grid: { color: gridColor },
                        ticks: { color: textColor, font: { weight: 'bold' } }
                    }
                }
            }
        });

        // 5. Chart Perbandingan Kepatuhan Perusahaan (Leaderboard Chart)
        const ctxLeaderboard = document.getElementById('leaderboardChart').getContext('2d');
        
        const compNames = [];
        const compRates = [];
        const barColors = [];

        @foreach (var comp in leaderboard)
        {
            <text>
                compNames.push('@comp.CompanyName');
                compRates.push(@comp.AchievementRate);
                
                if (@comp.AchievementRate >= 100) {
                    barColors.push('rgba(16, 185, 129, 0.85)'); // Green
                } else if (@comp.AchievementRate >= 50) {
                    barColors.push('rgba(245, 158, 11, 0.85)'); // Yellow
                } else {
                    barColors.push('rgba(239, 68, 68, 0.85)'); // Red
                }
            </text>
        }

        new Chart(ctxLeaderboard, {
            type: 'bar',
            data: {
                labels: compNames,
                datasets: [{
                    label: 'Pencapaian (%)',
                    data: compRates,
                    backgroundColor: barColors,
                    borderWidth: 0,
                    borderRadius: 6
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { color: gridColor },
                        ticks: { color: textColor, font: { weight: 'bold' } },
                        max: 100
                    },
                    y: {
                        grid: { display: false },
                        ticks: { color: textColor, font: { weight: 'bold' } }
                    }
                }
            }
        });
    });

    function expandAllHierarchy() {
        $('#sectionHierarchy .collapse').addClass('show');
        $('#sectionHierarchy .toggle-icon').removeClass('bi-chevron-right').addClass('bi-chevron-down');
    }

    function collapseAllHierarchy() {
        $('#sectionHierarchy .collapse').removeClass('show');
        $('#sectionHierarchy .toggle-icon').removeClass('bi-chevron-down').addClass('bi-chevron-right');
    }

    function filterHierarchyTree() {
        const q = document.getElementById('hierarchySearchInput').value.toLowerCase().trim();
        if (!q) {
            $('#sectionHierarchy .hierarchy-node').show();
            return;
        }
        
        $('#sectionHierarchy .hierarchy-node').hide();
        
        $('#sectionHierarchy .hierarchy-node').each(function() {
            const compName = $(this).find('> .hierarchy-item .card-sap [style*="font-weight: 800"]').text().toLowerCase();
            const compIdStr = $(this).find('> .hierarchy-item .card-sap .text-muted').text().toLowerCase();
            
            if (compName.includes(q) || compIdStr.includes(q)) {
                $(this).show();
                $(this).parents('.hierarchy-node').show();
                $(this).find('.hierarchy-node').show();
                $(this).parents('.collapse').addClass('show');
                $(this).parents('.hierarchy-node').find('> .hierarchy-item .toggle-icon').removeClass('bi-chevron-right').addClass('bi-chevron-down');
            }
        });
    }

    $(document).ready(function() {
        $('#sectionHierarchy').on('show.bs.collapse', '.collapse', function(e) {
            e.stopPropagation();
            $(this).prev().find('.toggle-icon').removeClass('bi-chevron-right').addClass('bi-chevron-down');
        });
        $('#sectionHierarchy').on('hide.bs.collapse', '.collapse', function(e) {
            e.stopPropagation();
            $(this).prev().find('.toggle-icon').removeClass('bi-chevron-down').addClass('bi-chevron-right');
        });
    });
</script>
}

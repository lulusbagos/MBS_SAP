    /* ═══════════════════════════════════════════════════
       ORG CHART – PREMIUM REDESIGN
       Design tokens defined on .org-chart-wrapper root
    ═══════════════════════════════════════════════════ */
    .org-chart-wrapper {
        /* tokens */
        --oc-line:         #b0bec5;
        --oc-line-w:       2px;
        --oc-radius:       12px;
        --oc-gap-h:        28px;
        --oc-conn-v:       28px;
        /* colours per tier */
        --oc-owner-border: #1e40af;
        --oc-owner-bar:    linear-gradient(135deg,#1e40af,#2563eb);
        --oc-owner-bg:     #ffffff;
        --oc-main-border:  #0284c7;
        --oc-main-bar:     linear-gradient(135deg,#0369a1,#0ea5e9);
        --oc-main-bg:      #ffffff;
        --oc-sub-border:   #0d9488;
        --oc-sub-bar:      linear-gradient(135deg,#0f766e,#14b8a6);
        --oc-sub-bg:       #ffffff;
        --oc-vend-border:  #b45309;
        --oc-vend-bar:     linear-gradient(135deg,#b45309,#f59e0b);
        --oc-vend-bg:      #ffffff;
        /* layout */
        overflow: auto;
        max-height: min(74vh, 940px);
        padding: 24px 20px 20px;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        background-color: #f0f4f8;
        background-image:
            radial-gradient(circle, #cbd5e1 1px, transparent 1px);
        background-size: 22px 22px;
        scroll-behavior: smooth;
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.04);
    }
    .org-chart-tree,
    .org-chart-tree ul {
        margin: 0;
        padding: 0;
        list-style: none;
    }
    .org-chart-tree {
        text-align: center;
        min-width: max-content;
        padding: 4px 8px 8px;
    }
    .org-chart-tree ul {
        position: relative;
        padding-top: var(--oc-conn-v);
        display: flex;
        justify-content: center;
        gap: var(--oc-gap-h);
    }
    .org-chart-tree ul.org-children-compact {
        gap: 16px;
    }
    .org-chart-tree ul.org-children-dense {
        gap: 10px;
        padding-top: 20px;
    }
    .org-chart-tree ul.org-children-dense::before {
        height: 20px;
    }
    .org-chart-tree ul.org-secondary-matrix {
        display: grid;
        grid-template-columns: repeat(5, minmax(145px, 1fr));
        gap: 10px;
        padding-top: 34px;
        justify-content: stretch;
        min-width: 820px;
    }
    .org-chart-tree ul.org-secondary-matrix::before {
        display: none;
    }
    .org-chart-tree ul.org-secondary-matrix > li {
        width: 100%;
        padding: 0;
    }
    .org-chart-tree ul.org-secondary-matrix > li::before,
    .org-chart-tree ul.org-secondary-matrix > li::after {
        display: none;
    }
    .org-chart-outer {
        position: relative;
    }
    .org-scroll-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 6px;
        gap: 8px;
    }
    .org-scroll-btn {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        background: #ffffff;
        color: #475569;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.15s ease;
        box-shadow: 0 1px 4px rgba(15,23,42,0.07);
    }
    .org-scroll-btn:hover {
        border-color: #0284c7;
        color: #0284c7;
        background: #f0f9ff;
        box-shadow: 0 2px 8px rgba(14,165,233,0.18);
    }
    .org-scroll-btn:active {
        transform: scale(0.93);
    }
    .org-scroll-track {
        flex: 1;
        height: 4px;
        background: #e2e8f0;
        border-radius: 999px;
        overflow: hidden;
    }
    .org-scroll-thumb {
        height: 100%;
        background: linear-gradient(90deg,#0369a1,#0ea5e9);
        border-radius: 999px;
        transition: width 0.2s, left 0.2s;
        position: relative;
        min-width: 30px;
    }
    .org-chart-wrapper {
        cursor: grab;
    }
    .org-chart-wrapper.is-dragging {
        cursor: grabbing;
        user-select: none;
    }
    /* secondary maincon aligned at the edge, same top level as primary row */
    .org-level1-flex {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .org-secondary-block {
        margin-top: 16px;
        padding-top: 20px;
        border-top: 1px solid #e2e8f0;
        position: relative;
        min-width: 820px;
        width: 100%;
    }
    .org-secondary-block::after {
        content: "Maincon Non Utama";
        position: absolute;
        top: -10px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: #94a3b8;
        background: #f0f4f8;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 3px 12px;
        white-space: nowrap;
    }
    .org-chart-tree ul.org-secondary-maincon-row {
        display: grid;
        grid-template-columns: repeat(5, minmax(145px, 1fr));
        gap: 10px;
        padding-top: 2px;
        min-width: 820px;
        align-items: start;
    }
    .org-chart-tree ul.org-secondary-maincon-row::before {
        display: none;
    }
    .org-chart-tree ul.org-secondary-maincon-row > li.org-secondary-branch {
        width: 100%;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    /* Maincon row: primary branch + right-side secondary 5x5 grid */
    .org-maincon-combined-row {
        gap: var(--oc-gap-h);
        align-items: flex-start;
    }
    .org-maincon-separator {
        width: 3px;
        min-height: 108px;
        background: linear-gradient(180deg, transparent, #cbd5e1 25%, #cbd5e1 75%, transparent);
        align-self: stretch;
        flex-shrink: 0;
        border-radius: 999px;
        padding: 0 !important;
        margin: 0 4px;
    }
    .org-maincon-separator::before,
    .org-maincon-separator::after {
        display: none !important;
    }
    .org-secondary-maincon-cell {
        min-width: 820px;
        width: 820px;
        padding: 0 !important;
        position: relative;
    }
    .org-secondary-maincon-cell::before,
    .org-secondary-maincon-cell::after {
        display: none !important;
    }
    .org-secondary-maincon-cell > .org-secondary-caption {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 8px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.45px;
        text-transform: uppercase;
        color: #64748b;
        background: #e2e8f0;
        border-radius: 999px;
        padding: 4px 10px;
    }
    .org-chart-tree ul.org-secondary-maincon-row {
        margin: 0;
        padding-top: 8px;
        display: grid;
        grid-template-columns: repeat(5, minmax(145px, 1fr));
        grid-auto-rows: minmax(90px, auto);
        gap: 10px;
        min-width: 820px;
    }
    .org-chart-tree ul.org-secondary-maincon-row > li {
        width: 100%;
        padding: 0;
    }
    .org-chart-tree ul.org-secondary-maincon-row > li.org-secondary-branch::before,
    .org-chart-tree ul.org-secondary-maincon-row > li.org-secondary-branch::after {
        display: none;
    }
    .org-chart-tree ul.org-secondary-maincon-row > li::before,
    .org-chart-tree ul.org-secondary-maincon-row > li::after {
        display: none;
    }
    .org-chart-tree ul.org-secondary-maincon-row > li.org-secondary-branch > .org-node-card {
        width: 100%;
    }
    .org-secondary-branch-subcons {
        width: 100%;
        margin-top: 10px;
        padding-top: 12px;
        display: grid;
        gap: 8px;
        position: relative;
    }
    .org-secondary-branch-subcons::before {
        content: "";
        position: absolute;
        left: 50%;
        top: 0;
        transform: translateX(-50%);
        height: 12px;
        border-left: var(--org-line-width) solid var(--org-line-color);
    }
    .org-secondary-branch-subcons > li {
        width: 100%;
        padding: 0;
    }
    .org-secondary-branch-subcons > li::before,
    .org-secondary-branch-subcons > li::after {
        display: none;
    }
    .org-secondary-branch-subcons > li > .org-node-card {
        width: 100%;
    }
    .org-chart-tree ul.org-subcon-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(150px, 1fr));
        gap: 10px;
        min-width: 820px;
        padding-top: 22px;
        align-items: start;
        justify-content: stretch;
    }
    .org-chart-tree ul.org-subcon-grid::before {
        display: none;
    }
    .org-chart-tree ul.org-subcon-grid > li {
        width: 100%;
        padding: 0;
    }
    .org-chart-tree ul.org-subcon-grid > li::before,
    .org-chart-tree ul.org-subcon-grid > li::after {
        display: none;
    }
    .org-chart-tree ul.org-subcon-grid > li > .org-node-card {
        width: 100%;
        min-height: 74px;
        border-radius: var(--oc-radius);
        box-shadow: 0 1px 4px rgba(15,23,42,0.07);
    }
    .org-chart-tree ul.org-subcon-grid > li > .org-node-card .org-node-card-inner {
        padding: 7px 8px 8px;
    }
    .org-chart-tree ul.org-subcon-grid > li > .org-node-card .org-avatar {
        width: 26px;
        height: 26px;
        font-size: 13px;
        border-radius: 6px;
    }
    .org-chart-tree ul.org-subcon-grid > li > .org-node-card .org-node-title {
        font-size: 10px;
    }
    .org-chart-tree ul.org-subcon-grid > li > .org-node-card .org-node-meta {
        font-size: 9px;
        line-height: 1.2;
    }
    .org-chart-tree ul.org-subcon-grid > li > .org-node-card .org-node-tag,
    .org-chart-tree ul.org-subcon-grid > li > .org-node-card .org-level-pill {
        font-size: 8px;
    }
    .org-chart-tree ul.org-subcon-grid > li.has-children > .org-node-card::after {
        display: none;
    }
    .org-chart-tree li {
        position: relative;
        padding: 0 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .org-chart-tree li::before,
    .org-chart-tree li::after {
        content: "";
        position: absolute;
        top: 0;
        width: 50%;
        height: 18px;
        border-top: var(--oc-line-w) solid var(--oc-line);
    }
    .org-chart-tree li::before {
        right: 50%;
        border-right: var(--oc-line-w) solid var(--oc-line);
        border-radius: 0 0 0 0;
    }
    .org-chart-tree li::after {
        left: 50%;

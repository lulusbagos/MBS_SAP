@model MBS_SAP.Controllers.QrProfileViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Scan QR Absensi";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

<style>
    #qrReader {
        width: 100%;
        min-height: min(60vh, 450px);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        overflow: hidden;
        background: #0f172a;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
    }
    .scan-status {
        margin-top: 12px;
        border-radius: 14px;
        border: 1px solid transparent;
        padding: 11px 12px;
        font-size: 13px;
        font-weight: 700;
        display: none;
    }
    .scan-status.ok {
        display: block;
        border-color: rgba(34, 197, 94, 0.3);
        color: var(--color-green);
        background: rgba(34, 197, 94, 0.1);
    }
    .scan-status.err {
        display: block;
        border-color: rgba(244, 63, 94, 0.3);
        color: var(--color-red);
        background: rgba(244, 63, 94, 0.1);
    }
    
    body.light-theme .scan-status.ok {
        border-color: #86efac;
        color: #166534;
        background: #dcfce7;
    }
    body.light-theme .scan-status.err {
        border-color: #fca5a5;
        color: #991b1b;
        background: #fee2e2;
    }
</style>

<div class="animate-fade-in">
    <!-- Back Button -->
    <div class="mb-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-sap-secondary btn-sm d-inline-flex align-items-center">
            <i class="bi bi-arrow-left me-1"></i> Kembali ke Menu
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card-sap border-primary-accent">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 56px; height: 56px; background: rgba(56, 189, 248, 0.15);">
                        <i class="bi bi-qr-code-scan" style="font-size: 26px; color: var(--color-primary);"></i>
                    </div>
                    <h3 class="screen-title text-center mb-1">Camera Scan QR Event</h3>
                    <p class="text-muted" style="font-size: 13px; line-height: 1.5;">Arahkan kamera ke QR acara untuk absensi. Halaman ini dibuat fokus kamera agar stabil di mode mobile.</p>
                </div>

                <div id="qrReader"></div>

                <div class="d-grid gap-2 mt-4" style="display: grid; grid-template-columns: 1fr 1fr;">
                    <button type="button" id="startScanBtn" class="btn-sap-primary w-100 py-3" style="font-size: 14px; display: flex; align-items: center; justify-content: center; border-radius: 12px; font-weight: 700; border: none; padding: 12px;"><i class="bi bi-play-circle me-2"></i>Mulai Scan</button>
                    <button type="button" id="stopScanBtn" class="btn-sap-secondary w-100 py-3" style="font-size: 14px; display: flex; align-items: center; justify-content: center; border-radius: 12px; font-weight: 700; padding: 12px;"><i class="bi bi-stop-circle me-2"></i>Stop</button>
                </div>

                <div id="scanStatus" class="scan-status text-center"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        (function () {
            const baseUrl = '@baseUrl';
            const statusEl = document.getElementById('scanStatus');
            const startBtn = document.getElementById('startScanBtn');
            const stopBtn = document.getElementById('stopScanBtn');

            let scanner = null;
            let isRunning = false;

            function setStatus(type, message) {
                if (!statusEl) return;
                statusEl.className = 'scan-status ' + type;
                statusEl.textContent = message;
            }

            function normalizeToScanUrl(rawText) {
                const text = (rawText || '').trim();
                if (!text) return null;

                if (text.includes('/QrAttendance/Scan/')) {
                    if (text.startsWith('http://') || text.startsWith('https://')) {
                        return text;
                    }
                    return baseUrl + (text.startsWith('/') ? text : '/' + text);
                }

                if (/^[a-fA-F0-9]{16,64}$/.test(text)) {
                    return baseUrl + '/QrAttendance/Scan/' + text;
                }

                try {
                    const url = new URL(text);
                    if (url.pathname.includes('/QrAttendance/Scan/')) {
                        return url.toString();
                    }
                } catch {
                    return null;
                }

                return null;
            }

            function proceedScan(text) {
                const target = normalizeToScanUrl(text);
                if (!target) {
                    setStatus('err', 'QR tidak dikenali sebagai QR absensi event.');
                    return;
                }

                setStatus('ok', 'QR valid. Mengarahkan ke absensi...');
                setTimeout(function () {
                    window.location.href = target;
                }, 250);
            }

            async function startScan() {
                if (isRunning) return;
                if (!window.Html5Qrcode) {
                    setStatus('err', 'Library scanner tidak tersedia. Refresh halaman.');
                    return;
                }

                scanner = scanner || new Html5Qrcode('qrReader');

                try {
                    await scanner.start(
                        { facingMode: 'environment' },
                        { fps: 10, qrbox: { width: 250, height: 250 } },
                        function (decodedText) {
                            proceedScan(decodedText);
                        },
                        function () {}
                    );

                    isRunning = true;
                    setStatus('ok', 'Scanner aktif. Arahkan kamera ke QR event.');
                } catch {
                    setStatus('err', 'Gagal mengakses kamera. Cek izin browser atau perangkat kamera.');
                }
            }

            async function stopScan() {
                if (!scanner || !isRunning) return;
                try {
                    await scanner.stop();
                    await scanner.clear();
                } catch {
                }
                isRunning = false;
                setStatus('ok', 'Scanner dihentikan.');
            }

            startBtn?.addEventListener('click', function () {
                startScan();
            });

            stopBtn?.addEventListener('click', function () {
                stopScan();
            });

            startScan();
        })();
    </script>
}


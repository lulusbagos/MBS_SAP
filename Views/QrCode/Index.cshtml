@model MBS_SAP.Controllers.QrProfileViewModel
@{
    Layout = null;
    ViewData["Title"] = "Scan QR Absensi";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

<style>
    * { box-sizing: border-box; }
    body {
        margin: 0;
        font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
        background: #020617;
        color: #e2e8f0;
    }
    .scan-page {
        min-height: 100vh;
        padding: 16px;
        background:
            radial-gradient(circle at top left, rgba(14, 165, 233, 0.22), transparent 28%),
            radial-gradient(circle at top right, rgba(34, 197, 94, 0.16), transparent 26%),
            linear-gradient(180deg, #020617 0%, #0f172a 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .scan-shell {
        width: min(100%, 520px);
        border-radius: 24px;
        padding: 18px;
        background: rgba(15, 23, 42, 0.82);
        border: 1px solid rgba(148, 163, 184, 0.18);
        box-shadow: 0 24px 60px rgba(2, 6, 23, 0.45);
        backdrop-filter: blur(14px);
    }
    .scan-head {
        margin-bottom: 14px;
    }
    .scan-title {
        margin: 0;
        font-size: 22px;
        font-weight: 900;
        letter-spacing: -0.03em;
        color: #f8fafc;
    }
    .scan-subtitle {
        margin: 8px 0 0;
        font-size: 12px;
        line-height: 1.6;
        color: #94a3b8;
    }

    #qrReader {
        width: 100%;
        min-height: min(68vh, 520px);
        border: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 20px;
        overflow: hidden;
        background: #0f172a;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
    }

    .scanner-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: 14px;
    }

    .scan-btn {
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 14px;
        background: rgba(255,255,255,0.08);
        color: #e2e8f0;
        font-size: 12px;
        font-weight: 800;
        padding: 11px 12px;
        cursor: pointer;
    }

    .scan-btn:hover {
        border-color: rgba(56, 189, 248, 0.42);
        color: #f8fafc;
        background: rgba(56, 189, 248, 0.16);
    }

    .scan-status {
        margin-top: 12px;
        border-radius: 14px;
        border: 1px solid transparent;
        padding: 11px 12px;
        font-size: 12px;
        font-weight: 700;
        display: none;
    }

    .scan-status.ok {
        display: block;
        border-color: #86efac;
        color: #166534;
        background: #dcfce7;
    }

    .scan-status.err {
        display: block;
        border-color: #fca5a5;
        color: #991b1b;
        background: #fee2e2;
    }

    @@media (max-width: 768px) {
        .scan-page {
            padding: 10px;
            align-items: stretch;
        }
        .scan-shell {
            width: 100%;
            min-height: calc(100vh - 20px);
            border-radius: 20px;
            padding: 14px;
        }
        .scan-title {
            font-size: 20px;
        }
        #qrReader {
            min-height: 62vh;
        }
    }
</style>

<div class="scan-page">
    <div class="scan-shell">
        <div class="scan-head">
            <h2 class="scan-title">Camera Scan QR Event</h2>
            <p class="scan-subtitle">Arahkan kamera ke QR acara untuk absensi. Halaman ini dibuat fokus kamera agar stabil di mode mobile.</p>
        </div>

        <div id="qrReader"></div>

        <div class="scanner-actions">
            <button type="button" id="startScanBtn" class="scan-btn"><i class="bi bi-play-circle me-1"></i>Mulai Scan</button>
            <button type="button" id="stopScanBtn" class="scan-btn"><i class="bi bi-stop-circle me-1"></i>Stop</button>
        </div>

        <div id="scanStatus" class="scan-status"></div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        (function () {
            const baseUrl = '@baseUrl';
            const statusEl = document.getElementById('scanStatus');
            const startBtn = document.getElementById('startScanBtn');
            const stopBtn = document.getElementById('stopScanBtn');

            let scanner = null;
            let isRunning = false;

            function setStatus(type, message) {
                if (!statusEl) return;
                statusEl.className = 'scan-status ' + type;
                statusEl.textContent = message;
            }

            function normalizeToScanUrl(rawText) {
                const text = (rawText || '').trim();
                if (!text) return null;

                if (text.includes('/QrAttendance/Scan/')) {
                    if (text.startsWith('http://') || text.startsWith('https://')) {
                        return text;
                    }
                    return baseUrl + (text.startsWith('/') ? text : '/' + text);
                }

                if (/^[a-fA-F0-9]{16,64}$/.test(text)) {
                    return baseUrl + '/QrAttendance/Scan/' + text;
                }

                try {
                    const url = new URL(text);
                    if (url.pathname.includes('/QrAttendance/Scan/')) {
                        return url.toString();
                    }
                } catch {
                    return null;
                }

                return null;
            }

            function proceedScan(text) {
                const target = normalizeToScanUrl(text);
                if (!target) {
                    setStatus('err', 'QR tidak dikenali sebagai QR absensi event.');
                    return;
                }

                setStatus('ok', 'QR valid. Mengarahkan ke absensi...');
                setTimeout(function () {
                    window.location.href = target;
                }, 250);
            }

            async function startScan() {
                if (isRunning) return;
                if (!window.Html5Qrcode) {
                    setStatus('err', 'Library scanner tidak tersedia. Refresh halaman.');
                    return;
                }

                scanner = scanner || new Html5Qrcode('qrReader');

                try {
                    await scanner.start(
                        { facingMode: 'environment' },
                        { fps: 10, qrbox: { width: 250, height: 250 } },
                        function (decodedText) {
                            proceedScan(decodedText);
                        },
                        function () {}
                    );

                    isRunning = true;
                    setStatus('ok', 'Scanner aktif. Arahkan kamera ke QR event.');
                } catch {
                    setStatus('err', 'Gagal mengakses kamera. Cek izin browser atau perangkat kamera.');
                }
            }

            async function stopScan() {
                if (!scanner || !isRunning) return;
                try {
                    await scanner.stop();
                    await scanner.clear();
                } catch {
                }
                isRunning = false;
                setStatus('ok', 'Scanner dihentikan.');
            }

            startBtn?.addEventListener('click', function () {
                startScan();
            });

            stopBtn?.addEventListener('click', function () {
                stopScan();
            });

            startScan();
        })();
    </script>
}

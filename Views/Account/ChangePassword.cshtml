@{
    ViewData["Title"] = "Ubah Password - SAP";
    ViewData["ActiveTab"] = "ChangePassword";
    string currentPwd = ViewData["CurrentPassword"]?.ToString() ?? "123456";
}

<div class="animate-fade-in d-flex justify-content-center align-items-center" style="min-height: calc(80vh - 100px);">
    <div class="card-sap border-primary-accent p-4" style="max-width: 450px; width: 100%;">
        <div class="text-center mb-4">
            <div class="brand-logo mb-2" style="font-size: 36px; display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; border-radius: 16px; background: linear-gradient(135deg, var(--color-primary), #4f46e5); color: white;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h4 class="text-white" style="font-weight: 800;">Ubah Kata Sandi</h4>
            <p class="text-muted" style="font-size: 13px;">Ganti password default Anda atau ubah password saat ini demi keamanan akun.</p>
        </div>

        @if (ViewData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 mb-3" role="alert" style="background-color: rgba(244, 63, 94, 0.15); color: var(--color-red); border-radius: 12px; font-size: 13px;">
                <i class="bi bi-x-circle-fill me-2"></i> @ViewData["Error"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close" style="font-size: 10px;"></button>
            </div>
        }

        @if (ViewData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 mb-3" role="alert" style="background-color: rgba(16, 185, 129, 0.15); color: var(--color-green); border-radius: 12px; font-size: 13px;">
                <i class="bi bi-check-circle-fill me-2"></i> @ViewData["Success"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close" style="font-size: 10px;"></button>
            </div>
        }

        <!-- ── Info: Password Saat Ini ───────────────────────────── -->
        <div style="background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.25); border-radius: 12px; padding: 12px 16px; margin-bottom: 20px;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--color-primary); margin-bottom: 4px;">
                        <i class="bi bi-info-circle-fill me-1"></i> Password Anda Saat Ini
                    </div>
                    <div id="pwdDisplay" style="font-size: 20px; font-weight: 900; letter-spacing: 4px; color: var(--text-main); font-family: monospace; filter: blur(5px); transition: filter 0.3s ease; user-select: none;">
                        @currentPwd
                    </div>
                    <div style="font-size: 10px; color: var(--text-muted); margin-top: 3px;">Klik ikon mata untuk menampilkan</div>
                </div>
                <button type="button" id="togglePwdBtn" onclick="toggleCurrentPwd()"
                        style="background: rgba(56,189,248,0.15); border: none; border-radius: 10px; padding: 8px 12px; color: var(--color-primary); cursor: pointer; font-size: 18px;">
                    <i class="bi bi-eye-fill" id="eyeIcon"></i>
                </button>
            </div>
        </div>

        <form asp-controller="Account" asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group-sap">
                <label class="form-label-sap" for="oldPassword">Password Lama</label>
                <div class="input-sap-wrapper">
                    <i class="bi bi-lock-fill input-sap-icon"></i>
                    <input type="password" id="oldPassword" name="oldPassword" class="input-sap" placeholder="Masukkan password saat ini" required />
                </div>
            </div>

            <div class="form-group-sap">
                <label class="form-label-sap" for="newPassword">Password Baru</label>
                <div class="input-sap-wrapper">
                    <i class="bi bi-key-fill input-sap-icon"></i>
                    <input type="password" id="newPassword" name="newPassword" class="input-sap" placeholder="Masukkan password baru" required />
                </div>
            </div>

            <div class="form-group-sap mb-4">
                <label class="form-label-sap" for="confirmPassword">Konfirmasi Password Baru</label>
                <div class="input-sap-wrapper">
                    <i class="bi bi-key-fill input-sap-icon"></i>
                    <input type="password" id="confirmPassword" name="confirmPassword" class="input-sap" placeholder="Ulangi password baru" required />
                </div>
            </div>

            <button type="submit" class="btn btn-sap-primary w-100 py-3 mb-3">
                <i class="bi bi-check-circle-fill me-2"></i> UPDATE PASSWORD
            </button>
            
            <div class="d-flex justify-content-between align-items-center" style="font-size: 12px;">
                <a asp-controller="Home" asp-action="Index" style="color: var(--color-primary); text-decoration: none; font-weight: 600;">
                    <i class="bi bi-arrow-left me-1"></i> Dashboard
                </a>
                <a asp-controller="Account" asp-action="Logout" class="text-danger" style="text-decoration: none; font-weight: 600;">
                    <i class="bi bi-box-arrow-right me-1"></i> Log Out
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var revealed = false;
        function toggleCurrentPwd() {
            revealed = !revealed;
            var display = document.getElementById('pwdDisplay');
            var icon = document.getElementById('eyeIcon');
            if (revealed) {
                display.style.filter = 'none';
                display.style.userSelect = 'text';
                icon.className = 'bi bi-eye-slash-fill';
            } else {
                display.style.filter = 'blur(5px)';
                display.style.userSelect = 'none';
                icon.className = 'bi bi-eye-fill';
            }
        }
    </script>
}

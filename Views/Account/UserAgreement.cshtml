@{
    ViewData["Title"] = "Syarat dan Ketentuan K3";
    ViewData["HideNav"] = true;
    ViewData["HideHeader"] = true;
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 100vh; padding: 20px;">
    <div class="card-sap" style="max-width: 500px; width: 100%;">
        <div class="text-center mb-4">
            <i class="bi bi-shield-check" style="font-size: 48px; color: var(--color-primary);"></i>
            <h4 class="mt-3" style="font-weight: 800; color: var(--text-main);">Komitmen K3L</h4>
            <p class="text-muted" style="font-size: 13px;">PT INDEXIM COALINDO</p>
        </div>

        <div style="background-color: var(--bg-layout); padding: 16px; border-radius: 12px; font-size: 13px; color: var(--text-muted); max-height: 300px; overflow-y: auto; margin-bottom: 24px; border: 1px solid var(--border-color);">
            <p><strong>1. Keselamatan adalah Prioritas:</strong> Saya berkomitmen untuk mengutamakan keselamatan dan kesehatan kerja (K3) dalam setiap aktivitas saya di area operasional perusahaan.</p>
            <p><strong>2. Kepatuhan terhadap Aturan:</strong> Saya akan mematuhi seluruh peraturan, prosedur standar operasional (SOP), dan instruksi kerja yang berlaku terkait K3.</p>
            <p><strong>3. Penggunaan APD:</strong> Saya berjanji untuk selalu menggunakan Alat Pelindung Diri (APD) yang diwajibkan sesuai dengan standar dan peruntukannya selama berada di area kerja.</p>
            <p><strong>4. Pelaporan Insiden:</strong> Saya akan segera melaporkan setiap kondisi berbahaya (unsafe condition), tindakan berbahaya (unsafe act), nyaris celaka (near miss), maupun kecelakaan kerja kepada atasan atau departemen K3.</p>
            <p><strong>5. Integritas Data:</strong> Saya menjamin bahwa data yang saya masukkan ke dalam sistem ini adalah akurat dan sesuai dengan kondisi sebenarnya di lapangan.</p>
        </div>

        @if (ViewData["HasAgreed"] as bool? == true)
        {
            <div class="alert alert-success text-center mb-4" style="border-radius: 12px;">
                <i class="bi bi-check-circle-fill me-2"></i> Anda telah menyetujui komitmen ini.
            </div>
            <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-secondary w-100 py-3" style="border-radius: 12px; font-weight: 700;">
                <i class="bi bi-arrow-left me-2"></i> Kembali ke Profil
            </a>
        }
        else
        {
            <form asp-action="AgreeToTerms" method="post">
                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" id="agreeCheck" required style="border-color: var(--color-primary);">
                    <label class="form-check-label text-main" for="agreeCheck" style="font-size: 13px; font-weight: 600;">
                        Saya telah membaca, memahami, dan menyetujui komitmen keselamatan ini.
                    </label>
                </div>

                <button type="submit" class="btn btn-sap-primary w-100 py-3" id="btnAgree" disabled>
                    <i class="bi bi-check-circle-fill me-2"></i> SAYA SETUJU & LANJUTKAN
                </button>
            </form>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('agreeCheck').addEventListener('change', function() {
            document.getElementById('btnAgree').disabled = !this.checked;
        });
    </script>
}

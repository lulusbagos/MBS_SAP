@model IEnumerable<MBS_SAP.Models.TimelineViewModel>
@{
    ViewData["Title"] = "SafeFeed - Aktivitas Pelaporan";
    ViewData["ActiveTab"] = "Timeline";
}

<style>
    /* Custom styles for SafeFeed Premium Redesign */
    .timeline-card {
        border-radius: 16px;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s ease, border-color 0.25s ease;
        overflow: hidden;
        margin-bottom: 24px;
    }
    .timeline-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        border-color: rgba(56, 189, 248, 0.15);
    }
    
    /* Translucent Glowing Badges */
    .badge-glass {
        padding: 4px 10px;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.5px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        text-transform: uppercase;
        line-height: 1;
    }

    /* Status badge styles */
    .badge-status-violation {
        background: rgba(244, 63, 94, 0.1);
        color: var(--color-red, #f43f5e);
        border: 1px solid rgba(244, 63, 94, 0.2);
    }
    .badge-status-improvement {
        background: rgba(249, 115, 22, 0.1);
        color: var(--color-orange, #f97316);
        border: 1px solid rgba(249, 115, 22, 0.2);
    }
    .badge-status-positive {
        background: rgba(16, 185, 129, 0.1);
        color: var(--color-green, #10b981);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .badge-status-open {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
    .badge-status-progres {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }
    .badge-status-closed {
        background: rgba(16, 185, 129, 0.1);
        color: var(--color-green, #10b981);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    /* Risk levels */
    .badge-risk-ekstrim {
        background: rgba(185, 28, 28, 0.15);
        color: #ef4444;
        border: 1px solid rgba(185, 28, 28, 0.25);
    }
    .badge-risk-tinggi {
        background: rgba(244, 63, 94, 0.12);
        color: #f43f5e;
        border: 1px solid rgba(244, 63, 94, 0.25);
    }
    .badge-risk-sedang {
        background: rgba(249, 115, 22, 0.12);
        color: #f97316;
        border: 1px solid rgba(249, 115, 22, 0.25);
    }
    .badge-risk-rendah {
        background: rgba(16, 185, 129, 0.12);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.25);
    }

    /* Item Type styles */
    .badge-type-hazard {
        background: rgba(244, 63, 94, 0.08);
        color: #f43f5e;
        border: 1px solid rgba(244, 63, 94, 0.15);
    }
    .badge-type-inspection {
        background: rgba(56, 189, 248, 0.08);
        color: #38bdf8;
        border: 1px solid rgba(56, 189, 248, 0.15);
    }
    .badge-type-actionplan {
        background: rgba(16, 185, 129, 0.08);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.15);
    }
    .badge-type-safetytalk {
        background: rgba(6, 182, 212, 0.08);
        color: #06b6d4;
        border: 1px solid rgba(6, 182, 212, 0.15);
    }
    .badge-type-p5m {
        background: rgba(139, 92, 246, 0.08);
        color: #8b5cf6;
        border: 1px solid rgba(139, 92, 246, 0.15);
    }
    .badge-type-observation {
        background: rgba(249, 115, 22, 0.08);
        color: #f97316;
        border: 1px solid rgba(249, 115, 22, 0.15);
    }
    .badge-type-p2h {
        background: rgba(100, 116, 139, 0.08);
        color: #94a3b8;
        border: 1px solid rgba(100, 116, 139, 0.15);
    }

    /* Metadata details grid */
    .meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 10px;
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 16px;
    }
    body.light-theme .meta-grid {
        background: rgba(0, 0, 0, 0.01);
        border-color: rgba(0, 0, 0, 0.04);
    }
    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
    }
    .meta-item i {
        font-size: 14px;
        color: var(--color-primary);
    }
    .meta-item-label {
        font-size: 9px;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 500;
        line-height: 1.1;
    }
    .meta-item-value {
        font-weight: 600;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
    }

    /* Specific Info Boxes */
    .detail-box-p2h {
        background: linear-gradient(135deg, rgba(31, 41, 55, 0.2), rgba(17, 24, 39, 0.2));
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 12px;
        padding: 12px 14px;
    }
    body.light-theme .detail-box-p2h {
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
        border-color: #cbd5e1;
    }
    .detail-box-hazard {
        background: linear-gradient(135deg, rgba(244, 63, 94, 0.02), rgba(17, 24, 39, 0.1));
        border: 1px solid rgba(244, 63, 94, 0.08);
        border-radius: 12px;
        padding: 12px 14px;
    }
    body.light-theme .detail-box-hazard {
        background: linear-gradient(135deg, #fff5f5, #ffebeb);
        border-color: #fecaca;
    }

    /* Action bar buttons */
    .btn-action-feed {
        background: none;
        border: none;
        color: var(--text-muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        transition: all 0.2s ease;
        cursor: pointer;
        padding: 0;
    }
    .btn-action-feed:hover {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-main) !important;
        transform: scale(1.08);
    }
    body.light-theme .btn-action-feed:hover {
        background: rgba(0, 0, 0, 0.04);
    }
    .btn-action-feed:active {
        transform: scale(0.92);
    }

    /* Comment pill */
    .comment-input-pill {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border-color);
        border-radius: 24px;
        padding: 6px 14px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        width: 100%;
    }
    body.light-theme .comment-input-pill {
        background: rgba(0, 0, 0, 0.015);
    }
    .comment-input-pill:focus-within {
        border-color: var(--color-primary);
        box-shadow: 0 0 12px rgba(56, 189, 248, 0.15);
        background: rgba(255, 255, 255, 0.04);
    }

    /* Images */
    .feed-image-container {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 16px;
        border: 1px solid var(--border-color);
        background-color: rgba(255, 255, 255, 0.01);
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .feed-image {
        width: 100%;
        max-height: 480px;
        object-fit: contain;
        transition: transform 0.5s ease;
    }
    .feed-image-container:hover .feed-image {
        transform: scale(1.015);
    }

    /* Animation delay list */
    .timeline-feed .animate-fade-up {
        opacity: 0;
        transform: translateY(15px);
        animation: feedFadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .delay-1 { animation-delay: 0.05s; }
    .delay-2 { animation-delay: 0.1s; }
    .delay-3 { animation-delay: 0.15s; }
    .delay-4 { animation-delay: 0.2s; }
    .delay-5 { animation-delay: 0.25s; }
    .delay-6 { animation-delay: 0.3s; }

    @@keyframes feedFadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container-fluid py-4" style="max-width: 600px; margin: 0 auto;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0" style="color: var(--text-main); font-family: var(--font-heading);"><i class="bi bi-rss-fill me-2 text-primary"></i>SafeFeed</h4>
    </div>

    <div class="timeline-feed">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 48px;"></i>
                <p class="text-muted mt-3">Belum ada aktivitas pelaporan.</p>
            </div>
        }
        else
        {
            int loopIndex = 1;
            foreach (var item in Model)
            {
                var delayClass = "delay-" + (loopIndex > 6 ? 6 : loopIndex);
                <div class="timeline-card animate-fade-up @delayClass">
                    
                    <!-- Header Post -->
                    <div class="pt-3 pb-2 px-3 d-flex justify-content-between align-items-start">
                        <div class="d-flex align-items-center">
                            <div class="position-relative d-inline-flex me-2">
                                @if (!string.IsNullOrEmpty(item.FotoDiriUrl))
                                {
                                    <img src="@item.FotoDiriUrl" class="rounded-circle shadow-sm" style="width: 40px; height: 40px; object-fit: cover; border: 2px solid var(--color-primary);" alt="Profile" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <div class="rounded-circle shadow-sm" style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--color-primary, #3b82f6), #1d4ed8); color: white; font-weight: bold; font-size: 14px; display: none; align-items: center; justify-content: center;">
                                        @(string.IsNullOrEmpty(item.Nama) ? "?" : item.Nama.Substring(0, 1).ToUpper())
                                    </div>
                                }
                                else
                                {
                                    <div class="rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--color-primary, #3b82f6), #1d4ed8); color: white; font-weight: bold; font-size: 14px;">
                                        @(string.IsNullOrEmpty(item.Nama) ? "?" : item.Nama.Substring(0, 1).ToUpper())
                                    </div>
                                }
                            </div>
                            <div style="line-height: 1.2;">
                                <div class="fw-bold" style="font-size: 14px; color: var(--text-main);">@item.Nama</div>
                                @if (!string.IsNullOrEmpty(item.Jabatan) || !string.IsNullOrEmpty(item.Perusahaan) || !string.IsNullOrEmpty(item.Departemen))
                                {
                                    <div class="text-muted d-flex flex-wrap align-items-center gap-1 my-0.5" style="font-size: 10px;">
                                        @if (!string.IsNullOrEmpty(item.Jabatan))
                                        {
                                            <span class="badge bg-light text-dark border px-1.5 py-0.5" style="font-size: 9px; font-weight: 600; line-height: 1;">@item.Jabatan</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Departemen))
                                        {
                                            <span>@item.Departemen</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Perusahaan))
                                        {
                                            <span class="text-secondary fw-semibold">| @item.Perusahaan</span>
                                        }
                                    </div>
                                }
                                <div class="text-muted" style="font-size: 10px; margin-top: 1px; display: flex; align-items: center; gap: 4px;">
                                    <span><i class="bi bi-clock" style="font-size: 9px;"></i> @item.Tanggal.ToString("dd MMM yyyy") @item.Waktu.ToString(@"hh\:mm")</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex flex-column align-items-end gap-1">
                            @if (!string.IsNullOrEmpty(item.Status))
                            {
                                var statusLower = item.Status.ToLower();
                                if (item.ItemType == "Observation")
                                {
                                    if (statusLower == "violation")
                                    {
                                        <span class="badge-glass badge-status-violation"><i class="bi bi-x-circle-fill"></i>Violation</span>
                                    }
                                    else if (statusLower == "improvement")
                                    {
                                        <span class="badge-glass badge-status-improvement"><i class="bi bi-exclamation-triangle-fill"></i>Improvement</span>
                                    }
                                    else
                                    {
                                        <span class="badge-glass badge-status-positive"><i class="bi bi-check-circle-fill"></i>Positive</span>
                                    }
                                }
                                else if (item.ItemType == "P2h")
                                {
                                    if (statusLower == "good")
                                    {
                                        <span class="badge-glass badge-status-positive"><i class="bi bi-check-circle-fill"></i>Aman</span>
                                    }
                                    else
                                    {
                                        <span class="badge-glass badge-status-violation"><i class="bi bi-exclamation-circle-fill"></i>Temuan</span>
                                    }
                                }
                                else
                                {
                                    if (statusLower == "open")
                                    {
                                        <span class="badge-glass badge-status-open"><i class="bi bi-exclamation-circle-fill"></i>Open</span>
                                    }
                                    else if (statusLower == "progres")
                                    {
                                        <span class="badge-glass badge-status-progres"><i class="bi bi-arrow-repeat"></i>Progres</span>
                                    }
                                    else
                                    {
                                        <span class="badge-glass badge-status-closed"><i class="bi bi-check-circle-fill"></i>Closed</span>
                                    }
                                }
                            }
                            
                            @{
                                var itemTypeBadgeClass = item.ItemType.ToLower() switch {
                                    "hazard" => "badge-type-hazard",
                                    "inspection" => "badge-type-inspection",
                                    "actionplan" => "badge-type-actionplan",
                                    "safetytalk" => "badge-type-safetytalk",
                                    "p5m" => "badge-type-p5m",
                                    "observation" => "badge-type-observation",
                                    "p2h" => "badge-type-p2h",
                                    _ => "bg-secondary text-white"
                                };
                                var itemTypeDisplay = item.ItemType.ToLower() switch {
                                    "hazard" => "Hazard Report",
                                    "inspection" => "Inspeksi",
                                    "actionplan" => "Action Plan",
                                    "safetytalk" => "Safety Talk",
                                    "p5m" => "P5M",
                                    "observation" => "Observasi",
                                    "p2h" => "P2H",
                                    _ => item.ItemType
                                };
                                var itemTypeIcon = item.ItemType.ToLower() switch {
                                    "hazard" => "bi-exclamation-triangle",
                                    "inspection" => "bi-clipboard-check",
                                    "actionplan" => "bi-calendar-check",
                                    "safetytalk" => "bi-megaphone",
                                    "p5m" => "bi-people",
                                    "observation" => "bi-eye",
                                    "p2h" => "bi-truck",
                                    _ => "bi-rss"
                                };
                            }
                            <span class="badge-glass @itemTypeBadgeClass"><i class="bi @itemTypeIcon"></i>@itemTypeDisplay</span>
                            
                            @if (!string.IsNullOrEmpty(item.TingkatResiko))
                            {
                                var riskLower = item.TingkatResiko.ToLower();
                                var riskClass = riskLower switch {
                                    "ekstrim" => "badge-risk-ekstrim",
                                    "tinggi"  => "badge-risk-tinggi",
                                    "sedang"  => "badge-risk-sedang",
                                    _         => "badge-risk-rendah"
                                };
                                <span class="badge-glass @riskClass">
                                    <i class="bi bi-shield-fill-exclamation"></i>@item.TingkatResiko.ToUpper()
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Card Body -->
                    <div class="px-3 pb-3 pt-1">
                        
                        <!-- Metadata Grid -->
                        @if (!string.IsNullOrEmpty(item.Area) || !string.IsNullOrEmpty(item.Lokasi) || !string.IsNullOrEmpty(item.Kategori))
                        {
                            <div class="meta-grid">
                                @if (!string.IsNullOrEmpty(item.Area))
                                {
                                    <div class="meta-item" title="Area">
                                        <i class="bi bi-geo-alt-fill text-primary"></i>
                                        <div>
                                            <div class="meta-item-label">Area</div>
                                            <div class="meta-item-value">@item.Area</div>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(item.Lokasi))
                                {
                                    <div class="meta-item" title="Lokasi Spesifik">
                                        <i class="bi bi-pin-map-fill text-info"></i>
                                        <div>
                                            <div class="meta-item-label">Lokasi</div>
                                            <div class="meta-item-value">@item.Lokasi</div>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(item.Kategori))
                                {
                                    var categoryIcon = item.ItemType.ToLower() switch {
                                        "p2h" => "bi-truck-front",
                                        "hazard" => "bi-exclamation-octagon",
                                        "inspection" => "bi-journal-check",
                                        "observation" => "bi-eye",
                                        _ => "bi-tag"
                                    };
                                    <div class="meta-item" title="Kategori / Jenis">
                                        <i class="bi @categoryIcon text-warning"></i>
                                        <div>
                                            <div class="meta-item-label">Kategori</div>
                                            <div class="meta-item-value">@item.Kategori</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Post Description / Content Box -->
                        @if (item.ItemType == "P2h")
                        {
                            <div class="detail-box-p2h mb-3">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="bi bi-shield-check text-primary" style="font-size: 14px;"></i>
                                    <span class="fw-bold" style="font-size: 12px; color: var(--text-main);">Hasil Pemeriksaan Unit</span>
                                </div>
                                <p class="mb-0 text-muted" style="font-size: 13px; line-height: 1.5; font-family: var(--font-body);">@item.Content</p>
                            </div>
                        }
                        else if (item.ItemType == "Hazard")
                        {
                            <div class="detail-box-hazard mb-3">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="bi bi-exclamation-octagon-fill text-danger" style="font-size: 14px;"></i>
                                    <span class="fw-bold" style="font-size: 12px; color: var(--text-main);">Deskripsi Temuan Bahaya</span>
                                </div>
                                <p class="mb-0 text-muted" style="font-size: 13px; line-height: 1.5; font-family: var(--font-body);">@item.Content</p>
                            </div>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(item.Content))
                            {
                                <div class="mb-3" style="font-size: 13px; line-height: 1.5; color: var(--text-main); font-family: var(--font-body);">
                                    @if (!string.IsNullOrEmpty(item.Title))
                                    {
                                        <strong class="d-block mb-1" style="font-size: 14px; color: var(--text-main); font-family: var(--font-heading);">@item.Title</strong>
                                    }
                                    @item.Content
                                </div>
                            }
                        }

                        <!-- Image Display (Full Width Box) - hanya Admin yang bisa melihat foto -->
                        @if (!string.IsNullOrEmpty(item.FotoUrl))
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <div class="feed-image-container">
                                    <img src="@item.FotoUrl" class="feed-image" alt="Foto Laporan" />
                                </div>
                            }
                            else
                            {
                                <div class="px-3 py-2.5 d-flex align-items-center gap-2 mb-3" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 12px;">
                                    <i class="bi bi-shield-lock-fill text-warning" style="font-size: 16px;"></i>
                                    <span class="text-muted" style="font-size: 11px;">📷 Foto tersedia — hanya dapat dilihat oleh Administrator</span>
                                </div>
                            }
                        }

                        <!-- Action Bar (Like, Comment, Share) -->
                        <div class="d-flex gap-2 mb-2 align-items-center">
                            <button class="btn-action-feed btn-like" 
                                    data-type="@item.ItemType" data-id="@item.OriginalId"
                                    style="color: @(item.IsLikedByCurrentUser ? "var(--color-primary)" : "var(--text-muted)");"
                                    title="Suka">
                                <i class="bi @(item.IsLikedByCurrentUser ? "bi-hand-thumbs-up-fill" : "bi-hand-thumbs-up")" style="font-size: 18px;"></i>
                            </button>
                            <button class="btn-action-feed btn-comment-toggle"
                                    onclick="$('#comment-input-@item.ItemType-@item.OriginalId').focus();"
                                    style="color: var(--text-muted);"
                                    title="Komentar">
                                <i class="bi bi-chat" style="font-size: 18px;"></i>
                            </button>
                            <button class="btn-action-feed btn-share"
                                    onclick="shareTimelineItem('@item.ItemType', '@item.Title', '@item.Nama')"
                                    style="color: var(--text-muted);"
                                    title="Bagikan">
                                <i class="bi bi-send" style="font-size: 18px;"></i>
                            </button>
                            
                            <!-- Likes Count (Suka) -->
                            <div class="fw-bold ms-2" style="font-size: 12.5px; color: var(--text-main);">
                                <span id="like-count-@item.ItemType-@item.OriginalId">@item.LikesCount</span> suka
                            </div>
                        </div>

                        <!-- Comments Section -->
                        <div class="mt-2">
                            @if (item.CommentsCount > 0)
                            {
                                <div class="text-muted mb-2 btn-comment-toggle" style="font-size: 12.5px; cursor: pointer; font-weight: 500;" onclick="$('#comments-list-@item.ItemType-@item.OriginalId').slideToggle(150);">
                                    Lihat semua <span id="comment-count-@item.ItemType-@item.OriginalId">@item.CommentsCount</span> komentar
                                </div>
                            }
                            else
                            {
                                <div class="text-muted mb-2" style="font-size: 12.5px; display: none; font-weight: 500;" id="comment-count-wrapper-@item.ItemType-@item.OriginalId">
                                    Lihat semua <span id="comment-count-@item.ItemType-@item.OriginalId">0</span> komentar
                                </div>
                            }
                            
                            <div class="comments-list ps-1 mb-2" id="comments-list-@item.ItemType-@item.OriginalId" style="display: none; border-left: 2px solid var(--border-color); padding-left: 8px;">
                                @foreach (var c in item.Comments)
                                {
                                    <div class="mb-1.5" style="font-size: 12.5px; color: var(--text-main); line-height: 1.4;">
                                        <span class="fw-bold me-1 text-primary" style="font-size: 12px;">@c.NamaPengguna</span>
                                        <span>@c.CommentText</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Add Comment Input Pill -->
                        <div class="pt-2 border-top d-flex align-items-center" style="border-color: var(--border-color) !important;">
                            <div class="comment-input-pill">
                                <input type="text" class="form-control border-0 px-0 shadow-none" id="comment-input-@item.ItemType-@item.OriginalId" placeholder="Tambahkan komentar..." style="font-size: 12.5px; background-color: transparent; color: var(--text-main);" />
                                <button class="btn btn-link text-primary text-decoration-none fw-bold p-0 btn-send-comment ms-2" data-type="@item.ItemType" data-id="@item.OriginalId" style="font-size: 12.5px; min-width: 40px;">
                                    Kirim
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
                loopIndex++;
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Like action
            $('.btn-like').click(function() {
                var btn = $(this);
                var type = btn.data('type');
                var id = btn.data('id');
                var icon = btn.find('i');

                $.post('/Timeline/ToggleLike', { itemType: type, itemId: id }, function(res) {
                    if (res.success) {
                        $('#like-count-' + type + '-' + id).text(res.totalLikes);
                        if (res.isLiked) {
                            btn.css('color', 'var(--color-primary)');
                            icon.removeClass('bi-hand-thumbs-up').addClass('bi-hand-thumbs-up-fill');
                            
                            // Micro-interaction bounce
                            btn.css('transform', 'scale(1.3)');
                            setTimeout(function() {
                                btn.css('transform', '');
                            }, 150);
                        } else {
                            btn.css('color', 'var(--text-muted)');
                            icon.removeClass('bi-hand-thumbs-up-fill').addClass('bi-hand-thumbs-up');
                        }
                    } else {
                        alert(res.message);
                    }
                });
            });

            // Send comment on button click
            $('.btn-send-comment').click(function() {
                sendComment($(this));
            });

            // Send comment on enter key
            $('input[id^="comment-input-"]').keypress(function(e) {
                if(e.which == 13) {
                    var input = $(this);
                    var type = input.attr('id').split('-')[2];
                    var id = input.attr('id').split('-')[3];
                    var btn = $('.btn-send-comment[data-type="'+type+'"][data-id="'+id+'"]');
                    sendComment(btn);
                }
            });

            function sendComment(btn) {
                var type = btn.data('type');
                var id = btn.data('id');
                var input = $('#comment-input-' + type + '-' + id);
                var text = input.val();

                if (!text || text.trim() === '') return;

                btn.prop('disabled', true);
                $.post('/Timeline/AddComment', { itemType: type, itemId: id, text: text }, function(res) {
                    if (res.success) {
                        input.val('');
                        $('#comment-count-' + type + '-' + id).text(res.totalComments);
                        
                        var newCommentHtml = `
                            <div class="mb-1.5" style="font-size: 12.5px; color: var(--text-main); line-height: 1.4;">
                                <span class="fw-bold me-1 text-primary" style="font-size: 12px;">${res.nama}</span>
                                <span>${res.text}</span>
                            </div>
                        `;
                        $('#comments-list-' + type + '-' + id).append(newCommentHtml).show();
                        $('#comment-count-wrapper-' + type + '-' + id).show();
                    } else {
                        alert(res.message);
                    }
                    btn.prop('disabled', false);
                }).fail(function() {
                    alert('Gagal mengirim komentar');
                    btn.prop('disabled', false);
                });
            }
        });

        function shareTimelineItem(type, title, name) {
            if (navigator.share) {
                navigator.share({
                    title: 'INDEXIM SAP Laporan',
                    text: 'Lihat laporan ' + type + ' dari ' + name + (title ? ' - ' + title : ''),
                    url: window.location.href
                }).catch(function(error) {
                    console.log('Error sharing', error);
                });
            } else {
                // Clipboard fallback
                var tempInput = document.createElement("input");
                tempInput.value = window.location.href;
                document.body.appendChild(tempInput);
                tempInput.select();
                document.execCommand("copy");
                document.body.removeChild(tempInput);
                
                alert('Tautan timeline berhasil disalin ke clipboard!');
            }
        }
    </script>
}


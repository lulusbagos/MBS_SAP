@model MBS_SAP.Controllers.EventQrEditForm
@{
    ViewData["Title"] = "Edit Event QR";
}

<style>
    .edit-shell {
        max-width: 600px;
        margin: 0 auto;
        padding: 24px;
        background:
            radial-gradient(circle at 10% 10%, rgba(56, 189, 248, 0.08), transparent 35%),
            radial-gradient(circle at 90% 90%, rgba(16, 185, 129, 0.06), transparent 35%),
            linear-gradient(180deg, rgba(17, 24, 39, 0.2) 0%, rgba(3, 7, 18, 0.2) 100%);
        border: 1px solid var(--border-color);
        border-radius: 20px;
    }
    .edit-card {
        border: 1px solid var(--border-color);
        border-radius: 18px;
        background: var(--bg-card);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
        overflow: hidden;
    }
    .edit-card-head {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.01);
    }
    .edit-title {
        margin: 0;
        font-family: 'Outfit', sans-serif;
        font-size: 16px;
        font-weight: 800;
        color: var(--text-main);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .edit-card-body {
        padding: 24px;
    }
    .edit-form {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }
    .edit-form label {
        font-size: 11px;
        font-weight: 800;
        color: var(--text-muted);
        margin-bottom: 6px;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .edit-form input,
    .edit-form textarea {
        width: 100%;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.25);
        color: var(--text-main);
        font-size: 13px;
        padding: 11px 14px;
        transition: all 0.2s ease;
    }
    .edit-form textarea {
        min-height: 90px;
        resize: vertical;
    }
    .edit-form input:focus,
    .edit-form textarea:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: var(--glow-primary);
        background: rgba(0, 0, 0, 0.35);
    }
    .edit-form .invalid {
        color: var(--color-red);
        font-size: 11px;
        margin-top: 5px;
        font-weight: 600;
        display: block;
    }
    .btn-submit-edit {
        border: 0;
        border-radius: 12px;
        background: linear-gradient(135deg, #0284c7, #0ea5e9);
        color: #ffffff;
        font-family: 'Outfit', sans-serif;
        font-size: 13px;
        font-weight: 800;
        padding: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(2, 132, 199, 0.25);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-submit-edit:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(2, 132, 199, 0.4);
    }
    .btn-back-edit {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-main);
        padding: 12px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s ease;
    }
    .btn-back-edit:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.15);
    }
</style>

<div class="edit-shell">
    <div class="edit-card">
        <header class="edit-card-head">
            <h3 class="edit-title"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Event QR</h3>
        </header>
        <div class="edit-card-body">
            <form asp-action="Edit" method="post" class="edit-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div>
                    <label asp-for="EventName">Nama Acara</label>
                    <input asp-for="EventName" placeholder="Contoh: Safety Talk Mingguan" autocomplete="off" />
                    <span asp-validation-for="EventName" class="invalid"></span>
                </div>

                <div>
                    <label asp-for="EventLocation">Lokasi</label>
                    <input asp-for="EventLocation" placeholder="Contoh: Mess Hall, Pit B, dll." autocomplete="off" />
                    <span asp-validation-for="EventLocation" class="invalid"></span>
                </div>

                <div>
                    <label asp-for="StartAt">Waktu Mulai</label>
                    <input asp-for="StartAt" type="datetime-local" />
                    <span asp-validation-for="StartAt" class="invalid"></span>
                </div>

                <div>
                    <label asp-for="EndAt">Waktu Selesai</label>
                    <input asp-for="EndAt" type="datetime-local" />
                    <span asp-validation-for="EndAt" class="invalid"></span>
                </div>

                <div>
                    <label asp-for="EventDescription">Deskripsi / Keterangan</label>
                    <textarea asp-for="EventDescription" placeholder="Catatan singkat acara..."></textarea>
                    <span asp-validation-for="EventDescription" class="invalid"></span>
                </div>

                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActiveEditCheck" style="width: 18px; height: 18px; margin: 0; cursor: pointer;" />
                    <label class="form-check-label" for="isActiveEditCheck" style="margin: 0; cursor: pointer; text-transform: none; font-size: 12px; font-weight: 600;">Aktifkan event absensi ini</label>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                    <a href="/EventQr" class="btn-back-edit"><i class="bi bi-arrow-left"></i>Kembali</a>
                    <button class="btn-submit-edit" type="submit"><i class="bi bi-save-fill"></i>Simpan Perubahan</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model MBS_SAP.Controllers.EventQrAttendanceViewModel
@{
    ViewData["Title"] = "Daftar Kehadiran Event";
}

<style>
    .att-shell {
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 16px;
        background: var(--bg-card);
    }
    .att-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 12px;
    }
    .att-head h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 800;
        color: var(--text-main);
    }
    .att-head p {
        margin: 4px 0 0;
        font-size: 12px;
        color: var(--text-muted);
    }
    .att-table-wrap {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
    }
    .att-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--bg-body);
    }
    .att-table th,
    .att-table td {
        border-bottom: 1px solid var(--border-color);
        padding: 10px;
        text-align: left;
        font-size: 12px;
        color: var(--text-main);
    }
    .att-table th {
        background: rgba(148, 163, 184, 0.15);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    .att-empty {
        padding: 18px;
        text-align: center;
        color: var(--text-muted);
        font-size: 12px;
    }
</style>

<div class="att-shell">
    <div class="att-head">
        <div>
            <h3>@Model.Event.EventName</h3>
            <p><i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrWhiteSpace(Model.Event.EventLocation) ? "Lokasi belum diisi" : Model.Event.EventLocation)</p>
            <p><i class="bi bi-clock me-1"></i>@Model.Event.StartAt.ToString("dd MMM yyyy HH:mm") - @Model.Event.EndAt.ToString("dd MMM yyyy HH:mm")</p>
        </div>
        <a class="btn btn-outline-info" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Kembali</a>
    </div>

    <div class="att-table-wrap">
        @if (Model.Records.Count == 0)
        {
            <div class="att-empty">Belum ada scan absensi untuk event ini.</div>
        }
        else
        {
            <table class="att-table">
                <thead>
                    <tr>
                        <th>Waktu Scan</th>
                        <th>NIK</th>
                        <th>Nama</th>
                        <th>Jabatan</th>
                        <th>Perusahaan</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Records)
                    {
                        <tr>
                            <td>@row.ScanAt.ToString("dd MMM yyyy HH:mm:ss")</td>
                            <td>@row.Nik</td>
                            <td>@row.Nama</td>
                            <td>@row.Jabatan</td>
                            <td>@row.Perusahaan</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@model MBS_SAP.Controllers.EventQrAttendanceViewModel
@{
    Layout = null;
    ViewData["Title"] = "Display Kehadiran Event";
    var snapshotUrl = Url.Action("AttendanceSnapshot", "EventQr", new { id = Model.Event.Id }) ?? string.Empty;
    var companyRate = Model.TotalActiveCompanies > 0
        ? Math.Round((double)Model.TotalPresentCompanies / Model.TotalActiveCompanies * 100.0, 1)
        : 0.0;
    var qrUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/QrAttendance/Scan/{Model.Event.QrToken}";
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>@ViewData["Title"] - INDEXIM SAP</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        * { box-sizing: border-box; }
        
        :root {
            --bg-app: #030712;
            --bg-card: rgba(17, 24, 39, 0.75);
            --border-color: rgba(255, 255, 255, 0.06);
            --color-primary: #38bdf8;
            --color-green: #10b981;
            --color-red: #f43f5e;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --glow-primary: 0 0 25px rgba(56, 189, 248, 0.25);
            --glow-green: 0 0 25px rgba(16, 185, 129, 0.25);
            --glow-red: 0 0 25px rgba(244, 63, 94, 0.25);
        }

        body {
            margin: 0;
            font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
            background-color: var(--bg-app);
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .display-shell {
            min-height: 100vh;
            padding: 24px;
            background:
                radial-gradient(circle at 10% 15%, rgba(56, 189, 248, 0.12), transparent 35%),
                radial-gradient(circle at 90% 10%, rgba(16, 185, 129, 0.1), transparent 35%),
                linear-gradient(180deg, #030712 0%, #090d16 100%);
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Top Header */
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            padding: 16px 24px;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .brand-section {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .brand-logo {
            width: 50px;
            height: 50px;
            object-fit: contain;
            background: #ffffff;
            border-radius: 12px;
            padding: 6px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
        }

        .brand-text {
            display: grid;
            gap: 2px;
        }

        .brand-subtitle {
            font-family: 'Outfit', sans-serif;
            font-size: 11px;
            font-weight: 800;
            color: var(--color-primary);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .brand-title {
            font-family: 'Outfit', sans-serif;
            font-size: 18px;
            font-weight: 900;
            line-height: 1.1;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .live-clock {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 14px;
            font-size: 14px;
            font-weight: 700;
            font-family: monospace;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--color-primary);
        }

        .btn-action {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 8px 16px;
            border-radius: 14px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-action:hover {
            background: rgba(56, 189, 248, 0.15);
            border-color: rgba(56, 189, 248, 0.3);
            color: #ffffff;
            transform: translateY(-1px);
        }

        /* Layout Grid */
        .monitor-layout {
            display: grid;
            grid-template-columns: 360px 1.2fr 1fr;
            gap: 20px;
            align-items: start;
        }

        .glass-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            padding: 24px;
        }

        /* Panel Title */
        .panel-header {
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .panel-title {
            font-family: 'Outfit', sans-serif;
            font-size: 16px;
            font-weight: 800;
            margin: 0;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Left Column: QR & Details */
        .qr-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .qr-wrapper {
            background: #ffffff;
            padding: 18px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 0 40px rgba(56, 189, 248, 0.15);
            display: inline-block;
            margin-bottom: 20px;
            transition: all 0.3s ease;
        }

        .qr-wrapper:hover {
            transform: scale(1.02);
            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.6), 0 0 50px rgba(56, 189, 248, 0.25);
        }

        .event-info-title {
            font-family: 'Outfit', sans-serif;
            font-size: 22px;
            font-weight: 900;
            margin: 0 0 10px;
            line-height: 1.2;
            background: linear-gradient(135deg, #ffffff 40%, var(--text-muted) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .event-info-desc {
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.5;
            margin: 0 0 20px;
        }

        .info-meta-list {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 12px;
            text-align: left;
        }

        .info-meta-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 12px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .info-meta-item i {
            color: var(--color-primary);
            font-size: 16px;
            margin-top: 2px;
        }

        .info-meta-item div {
            display: grid;
            gap: 2px;
        }

        .info-meta-item strong {
            font-size: 10px;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .info-meta-item span {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-main);
        }

        /* Center & Right Column: Stats Row */
        .stats-strip {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }

        .stat-card-glow {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            transition: all 0.3s ease;
        }

        .stat-card-glow:hover {
            transform: translateY(-2px);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .stat-card-glow.present {
            border-color: rgba(16, 185, 129, 0.15);
            box-shadow: inset 0 0 15px rgba(16, 185, 129, 0.05);
        }
        
        .stat-card-glow.pending {
            border-color: rgba(244, 63, 94, 0.15);
            box-shadow: inset 0 0 15px rgba(244, 63, 94, 0.05);
        }

        .stat-card-left {
            display: grid;
            gap: 4px;
        }

        .stat-card-label {
            font-size: 11px;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .stat-card-val {
            font-family: 'Outfit', sans-serif;
            font-size: 32px;
            font-weight: 900;
            line-height: 1.1;
        }

        .stat-card-sub {
            font-size: 10px;
            font-weight: 600;
            color: var(--text-muted);
        }

        .stat-card-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-color);
        }

        .stat-card-glow.present .stat-card-icon {
            background: rgba(16, 185, 129, 0.1);
            color: var(--color-green);
            border-color: rgba(16, 185, 129, 0.2);
            box-shadow: var(--glow-green);
        }

        .stat-card-glow.pending .stat-card-icon {
            background: rgba(244, 63, 94, 0.1);
            color: var(--color-red);
            border-color: rgba(244, 63, 94, 0.2);
            box-shadow: var(--glow-red);
        }
        
        .stat-card-glow.active .stat-card-icon {
            background: rgba(56, 189, 248, 0.1);
            color: var(--color-primary);
            border-color: rgba(56, 189, 248, 0.2);
            box-shadow: var(--glow-primary);
        }

        /* Company grid status */
        .company-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 12px;
            max-height: 45vh;
            overflow-y: auto;
            padding-right: 4px;
        }

        .company-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            transition: all 0.2s ease;
        }

        .company-card:hover {
            border-color: rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.03);
        }

        .company-card.is-present {
            border-color: rgba(16, 185, 129, 0.25);
            background: rgba(16, 185, 129, 0.06);
        }

        .company-card-name {
            font-size: 13px;
            font-weight: 700;
            margin: 0;
            color: var(--text-main);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .badge-status {
            font-size: 9px;
            font-weight: 800;
            padding: 3px 8px;
            border-radius: 999px;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            border: 1px solid transparent;
        }

        .badge-status.present {
            background: rgba(16, 185, 129, 0.15);
            color: var(--color-green);
            border-color: rgba(16, 185, 129, 0.2);
        }

        .badge-status.pending {
            background: rgba(226, 232, 240, 0.05);
            color: var(--text-muted);
            border-color: var(--border-color);
        }

        /* Pending list column */
        .pending-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 45vh;
            overflow-y: auto;
            padding-right: 4px;
        }

        .pending-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .pending-item h4 {
            margin: 0;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-main);
        }

        .pending-item span {
            font-size: 11px;
            color: var(--color-red);
            font-weight: 700;
        }

        /* Live Table section */
        .live-table-section {
            grid-column: span 2;
        }

        .live-table-wrap {
            max-height: 380px;
            overflow-y: auto;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            background: rgba(0, 0, 0, 0.15);
        }

        .live-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .live-table th {
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid var(--border-color);
            padding: 12px 16px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }

        .live-table tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            transition: background var(--transition-fast);
        }

        .live-table tr:hover {
            background: rgba(255, 255, 255, 0.01);
        }

        .live-table td {
            padding: 12px 16px;
            font-size: 12px;
            color: var(--text-main);
        }

        .live-table td strong {
            font-weight: 700;
            color: var(--color-primary);
        }

        .empty-state {
            padding: 30px;
            text-align: center;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 600;
            border: 1px dashed rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.01);
        }

        /* Scrollbars */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.01);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* Responsive Layouts */
        @@media (max-width: 1399px) {
            .monitor-layout {
                grid-template-columns: 340px 1fr;
            }
            .live-table-section {
                grid-column: span 1;
            }
            .stats-strip {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 1099px) {
            .monitor-layout {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .display-shell {
                padding: 14px;
            }
            .dashboard-header {
                flex-direction: column;
                align-items: stretch;
                padding: 16px;
                border-radius: 18px;
            }
            .header-actions {
                justify-content: space-between;
            }
            .stats-strip {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
<div class="display-shell">
    <!-- Top Header -->
    <header class="dashboard-header">
        <div class="brand-section">
            <img src="/images/logo_mbs.png" alt="INDEXIM SAP" class="brand-logo" />
            <div class="brand-text">
                <span class="brand-subtitle">Safety Accountability Program</span>
                <span class="brand-title">Live Attendance Display</span>
            </div>
        </div>
        <div class="header-actions">
            <div class="live-clock" id="liveClock">
                <i class="bi bi-clock-history"></i><span>--:--:--</span>
            </div>
            <button type="button" class="btn-action" id="fullscreenToggleBtn">
                <i class="bi bi-arrows-fullscreen"></i><span>Fullscreen</span>
            </button>
            <a class="btn-action" href="/EventQr">
                <i class="bi bi-arrow-left"></i><span>Kembali</span>
            </a>
        </div>
    </header>

    <!-- Monitor Grid -->
    <main class="monitor-layout">
        <!-- Column 1: QR & Event Info -->
        <section class="glass-card qr-section">
            <div class="panel-header" style="width: 100%;">
                <h3 class="panel-title"><i class="bi bi-qr-code-scan text-primary"></i>Pindai Absensi</h3>
            </div>
            
            <div class="qr-wrapper">
                <div id="eventQrCode"></div>
            </div>
            
            <h1 class="event-info-title">@Model.Event.EventName</h1>
            <p class="event-info-desc">Pindai QR Code di atas menggunakan browser/kamera HP Anda untuk mencatat kehadiran secara otomatis.</p>
            
            <div class="info-meta-list">
                <div class="info-meta-item">
                    <i class="bi bi-geo-alt-fill"></i>
                    <div>
                        <strong>Lokasi Acara</strong>
                        <span>@(string.IsNullOrWhiteSpace(Model.Event.EventLocation) ? "Lokasi belum diisi" : Model.Event.EventLocation)</span>
                    </div>
                </div>
                <div class="info-meta-item">
                    <i class="bi bi-calendar-event-fill"></i>
                    <div>
                        <strong>Waktu Pelaksanaan</strong>
                        <span>@Model.Event.StartAt.ToString("dd MMM yyyy")</span>
                    </div>
                </div>
                <div class="info-meta-item">
                    <i class="bi bi-clock-fill"></i>
                    <div>
                        <strong>Jadwal Jam</strong>
                        <span>@Model.Event.StartAt.ToString("HH:mm") - @Model.Event.EndAt.ToString("HH:mm") WITA</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Column 2: Stats & Company Status Grid -->
        <div style="display: flex; flex-direction: column; gap: 20px; grid-column: span 2;">
            <!-- Stats strip -->
            <section class="stats-strip">
                <div class="stat-card-glow active">
                    <div class="stat-card-left">
                        <span class="stat-card-label">Perusahaan Terdaftar</span>
                        <span class="stat-card-val" id="activeCompaniesValue">@Model.TotalActiveCompanies</span>
                        <span class="stat-card-sub">total perusahaan aktif</span>
                    </div>
                    <div class="stat-card-icon"><i class="bi bi-buildings-fill"></i></div>
                </div>
                <div class="stat-card-glow present">
                    <div class="stat-card-left">
                        <span class="stat-card-label">Hadir (Perusahaan)</span>
                        <span class="stat-card-val" id="presentCompaniesValue">@Model.TotalPresentCompanies</span>
                        <span class="stat-card-sub" id="presentCompaniesRate">@companyRate% dari total</span>
                    </div>
                    <div class="stat-card-icon"><i class="bi bi-check-circle-fill"></i></div>
                </div>
                <div class="stat-card-glow pending">
                    <div class="stat-card-left">
                        <span class="stat-card-label">Belum Hadir (Perusahaan)</span>
                        <span class="stat-card-val" id="pendingCompaniesValue">@(Model.TotalActiveCompanies - Model.TotalPresentCompanies)</span>
                        <span class="stat-card-sub">menunggu perwakilan</span>
                    </div>
                    <div class="stat-card-icon"><i class="bi bi-exclamation-circle-fill"></i></div>
                </div>
            </section>

            <!-- Bottom Sub-Grid: Company Grid & Pending List -->
            <div style="display: grid; grid-template-columns: 1.3fr 1fr; gap: 20px;">
                <!-- Company Status Card -->
                <section class="glass-card">
                    <div class="panel-header">
                        <h3 class="panel-title"><i class="bi bi-grid-3x3-gap-fill text-success"></i>Status Kehadiran Perusahaan</h3>
                    </div>
                    <div class="company-grid" id="companyGrid">
                        @foreach (var company in Model.CompanyStatuses)
                        {
                            <article class="company-card @(company.HasAttendance ? "is-present" : "is-pending")">
                                <h4 class="company-card-name" title="@company.CompanyName">@company.CompanyName</h4>
                                <span class="badge-status @(company.HasAttendance ? "present" : "pending")">
                                    @(company.HasAttendance ? "Hadir" : "Belum")
                                </span>
                            </article>
                        }
                    </div>
                </section>

                <!-- Pending Companies Card -->
                <section class="glass-card">
                    <div class="panel-header">
                        <h3 class="panel-title"><i class="bi bi-clock-history text-danger"></i>Daftar Belum Hadir</h3>
                    </div>
                    <div class="pending-list" id="pendingCompaniesList">
                        @if (Model.PendingCompanies.Count == 0)
                        {
                            <div class="empty-state">Semua perusahaan aktif sudah hadir.</div>
                        }
                        else
                        {
                            @foreach (var company in Model.PendingCompanies)
                            {
                                <article class="pending-item">
                                    <h4>@company.CompanyName</h4>
                                    <span>Belum Hadir</span>
                                </article>
                            }
                        }
                    </div>
                </section>
            </div>

            <!-- Live Table Card (Grid Expansion) -->
            <section class="glass-card live-table-section">
                <div class="panel-header">
                    <h3 class="panel-title"><i class="bi bi-rss-fill text-primary"></i>Live Attendance Feed</h3>
                    <span class="badge-status present" style="background: rgba(56, 189, 248, 0.15); color: var(--color-primary); border-color: rgba(56, 189, 248, 0.2);" id="totalAttendeesBadge">
                        @Model.TotalPresentEmployees Peserta Hadir
                    </span>
                </div>
                <div class="live-table-wrap">
                    <table class="live-table">
                        <thead>
                            <tr>
                                <th>Waktu Scan</th>
                                <th>NIK</th>
                                <th>Nama Lengkap</th>
                                <th>Jabatan</th>
                                <th>Departemen</th>
                                <th>Perusahaan</th>
                            </tr>
                        </thead>
                        <tbody id="attendeeFeedTableBody">
                            @if (Model.Attendees.Count == 0)
                            {
                                <tr><td colspan="6" class="text-center" style="text-align:center; padding: 24px; color: var(--text-muted);">Belum ada absensi masuk untuk event ini.</td></tr>
                            }
                            else
                            {
                                @foreach (var attendee in Model.Attendees)
                                {
                                    <tr>
                                        <td>@attendee.ScanAt.ToString("dd MMM yyyy HH:mm:ss")</td>
                                        <td>@attendee.Nik</td>
                                        <td><strong>@attendee.Nama</strong></td>
                                        <td>@attendee.Jabatan</td>
                                        <td>@attendee.Departemen</td>
                                        <td>@attendee.CompanyName</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </main>
</div>

<!-- QR and Realtime scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
    (function () {
        const REFRESH_MS = 5000;
        const snapshotUrl = '@snapshotUrl';
        const clockEl = document.querySelector('#liveClock span');
        const fullscreenBtn = document.getElementById('fullscreenToggleBtn');
        const companyGridEl = document.getElementById('companyGrid');
        const pendingCompaniesListEl = document.getElementById('pendingCompaniesList');
        const attendeeFeedBodyEl = document.getElementById('attendeeFeedTableBody');

        // Draw Event QR Code Large
        const qrContainer = document.getElementById('eventQrCode');
        if (qrContainer) {
            new QRCode(qrContainer, {
                text: '@qrUrl',
                width: 260,
                height: 260,
                colorDark: '#030712',
                colorLight: '#ffffff',
                correctLevel: QRCode.CorrectLevel.Q
            });
        }

        function updateClock() {
            if (!clockEl) return;
            const now = new Date();
            clockEl.textContent = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) + ' WITA';
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function formatDateTime(value) {
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '-';
            return date.toLocaleString('id-ID', {
                day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit'
            });
        }

        function syncFullscreenLabel() {
            if (!fullscreenBtn) return;
            const icon = fullscreenBtn.querySelector('i');
            const label = fullscreenBtn.querySelector('span');
            const isFs = !!document.fullscreenElement;
            if (icon) icon.className = isFs ? 'bi bi-fullscreen-exit' : 'bi bi-arrows-fullscreen';
            if (label) label.textContent = isFs ? 'Keluar Fullscreen' : 'Fullscreen';
        }

        function renderCompanyStatuses(companies) {
            if (!companyGridEl) return;
            companyGridEl.innerHTML = (companies || []).length === 0
                ? '<div class="empty-state">Belum ada perusahaan aktif yang dapat ditampilkan.</div>'
                : companies.map(function (company) {
                    const statusClass = company.hasAttendance ? 'is-present' : 'is-pending';
                    const badgeClass = company.hasAttendance ? 'present' : 'pending';
                    const badgeText = company.hasAttendance ? 'Hadir' : 'Belum';
                    return `<article class="company-card ${statusClass}"><h4 class="company-card-name" title="${escapeHtml(company.companyName)}">${escapeHtml(company.companyName)}</h4><span class="badge-status ${badgeClass}">${badgeText}</span></article>`;
                }).join('');
        }

        function renderPendingCompanies(companies) {
            if (!pendingCompaniesListEl) return;
            pendingCompaniesListEl.innerHTML = (companies || []).length === 0
                ? '<div class="empty-state">Semua perusahaan aktif sudah hadir.</div>'
                : companies.map(function (company) {
                    return `<article class="pending-item"><h4>${escapeHtml(company.companyName)}</h4><span>Belum Hadir</span></article>`;
                }).join('');
        }

        function renderAttendees(attendees) {
            if (!attendeeFeedBodyEl) return;
            attendeeFeedBodyEl.innerHTML = (attendees || []).length === 0
                ? '<tr><td colspan="6" class="text-center" style="text-align:center; padding: 24px; color: var(--text-muted);">Belum ada absensi masuk untuk event ini.</td></tr>'
                : attendees.map(function (attendee) {
                    return `<tr><td>${escapeHtml(formatDateTime(attendee.scanAt))}</td><td>${escapeHtml(attendee.nik)}</td><td><strong>${escapeHtml(attendee.nama)}</strong></td><td>${escapeHtml(attendee.jabatan)}</td><td>${escapeHtml(attendee.departemen)}</td><td>${escapeHtml(attendee.companyName)}</td></tr>`;
                }).join('');
        }

        function updateSummary(totals) {
            const companyRate = totals.activeCompanies > 0 ? ((totals.presentCompanies / totals.activeCompanies) * 100).toFixed(1) : '0.0';
            document.getElementById('activeCompaniesValue').textContent = totals.activeCompanies;
            document.getElementById('presentCompaniesValue').textContent = totals.presentCompanies;
            document.getElementById('presentCompaniesRate').textContent = `${companyRate}% dari total`;
            document.getElementById('pendingCompaniesValue').textContent = totals.pendingCompanies;
            
            const attendeeBadge = document.getElementById('totalAttendeesBadge');
            if (attendeeBadge) {
                attendeeBadge.textContent = `${totals.presentEmployees} Peserta Hadir`;
            }
        }

        async function refreshAttendanceSnapshot() {
            if (!snapshotUrl) return;
            try {
                const response = await fetch(snapshotUrl, { cache: 'no-store' });
                if (!response.ok) return;
                const data = await response.json();
                renderCompanyStatuses(data.companyStatuses || []);
                renderPendingCompanies(data.pendingCompanies || []);
                renderAttendees(data.attendees || []);
                updateSummary(data.totals || {});
            } catch {
            }
        }

        fullscreenBtn?.addEventListener('click', async function () {
            try {
                if (!document.fullscreenElement) {
                    await document.documentElement.requestFullscreen();
                } else {
                    await document.exitFullscreen();
                }
            } catch {
            }
            syncFullscreenLabel();
        });

        document.addEventListener('fullscreenchange', syncFullscreenLabel);
        updateClock();
        syncFullscreenLabel();
        setInterval(updateClock, 1000);
        setInterval(refreshAttendanceSnapshot, REFRESH_MS);
    })();
</script>
</body>
</html>

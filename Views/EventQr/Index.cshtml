@model MBS_SAP.Controllers.EventQrIndexViewModel
@{
    ViewData["Title"] = "Event QR Absensi";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

<style>
    .eventqr-shell {
        border: 1px solid var(--border-color);
        border-radius: 18px;
        padding: 18px;
        background:
            radial-gradient(circle at 8% 5%, rgba(56, 189, 248, 0.18), transparent 30%),
            radial-gradient(circle at 92% 10%, rgba(34, 197, 94, 0.14), transparent 32%),
            var(--bg-body);
    }
    .eventqr-grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 14px;
    }
    .eventqr-card {
        border: 1px solid var(--border-color);
        border-radius: 14px;
        background: var(--bg-card);
        box-shadow: 0 5px 16px rgba(15, 23, 42, 0.08);
    }
    .eventqr-card-head {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }
    .eventqr-title {
        margin: 0;
        font-size: 14px;
        font-weight: 800;
        color: var(--text-main);
        letter-spacing: 0.3px;
        text-transform: uppercase;
    }
    .eventqr-card-body {
        padding: 14px;
    }
    .eventqr-form {
        display: grid;
        gap: 10px;
    }
    .eventqr-form label {
        font-size: 11px;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 4px;
        display: block;
    }
    .eventqr-form input,
    .eventqr-form textarea {
        width: 100%;
        border: 1px solid var(--border-color);
        border-radius: 10px;
        background: var(--bg-body);
        color: var(--text-main);
        font-size: 12px;
        padding: 9px 10px;
    }
    .eventqr-form textarea {
        min-height: 72px;
        resize: vertical;
    }
    .eventqr-form input:focus,
    .eventqr-form textarea:focus {
        outline: none;
        border-color: #38bdf8;
        box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.18);
    }
    .eventqr-form .invalid {
        color: #ef4444;
        font-size: 11px;
        margin-top: 3px;
    }
    .eventqr-submit {
        border: 0;
        border-radius: 10px;
        background: linear-gradient(135deg, #0284c7, #0ea5e9);
        color: #ffffff;
        font-size: 12px;
        font-weight: 800;
        padding: 10px 12px;
        cursor: pointer;
    }
    .eventqr-list {
        display: grid;
        gap: 10px;
    }
    .event-row {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 12px;
        background: var(--bg-body);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        align-items: center;
    }
    .event-meta h4 {
        margin: 0;
        font-size: 14px;
        font-weight: 800;
        color: var(--text-main);
    }
    .event-meta p {
        margin: 4px 0 0;
        color: var(--text-muted);
        font-size: 11px;
    }
    .event-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 8px;
    }
    .event-badge {
        border: 1px solid;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 700;
        padding: 3px 8px;
    }
    .event-badge.active {
        color: #166534;
        background: #dcfce7;
        border-color: #86efac;
    }
    .event-badge.inactive {
        color: #b91c1c;
        background: #fee2e2;
        border-color: #fca5a5;
    }
    .event-badge.count {
        color: #0c4a6e;
        background: #e0f2fe;
        border-color: #7dd3fc;
    }
    .event-actions {
        display: grid;
        gap: 6px;
        min-width: 210px;
    }
    .event-btn,
    .event-actions form button {
        border: 1px solid var(--border-color);
        border-radius: 9px;
        font-size: 11px;
        font-weight: 700;
        color: var(--text-main);
        background: #ffffff;
        padding: 7px 10px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }
    .event-btn:hover,
    .event-actions form button:hover {
        border-color: #38bdf8;
        color: #0284c7;
    }
    .event-btn-success {
        background: rgba(34, 197, 94, 0.12);
        border-color: rgba(34, 197, 94, 0.3);
        color: #166534;
    }
    .event-empty {
        text-align: center;
        border: 1px dashed var(--border-color);
        border-radius: 12px;
        padding: 22px 14px;
        color: var(--text-muted);
        font-size: 12px;
    }
    .qr-modal-canvas {
        width: 100%;
        min-height: 260px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px dashed var(--border-color);
        border-radius: 12px;
        background: rgba(148, 163, 184, 0.06);
        margin-bottom: 10px;
        padding: 10px;
    }
    .qr-modal-canvas img,
    .qr-modal-canvas canvas {
        background: #fff;
        padding: 8px;
        border-radius: 8px;
    }
    @@media (max-width: 1024px) {
        .eventqr-grid {
            grid-template-columns: 1fr;
        }
    }
    @@media (max-width: 768px) {
        .event-row {
            grid-template-columns: 1fr;
        }
        .event-actions {
            min-width: 0;
        }
    }
</style>

<div class="eventqr-shell">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">@TempData["ErrorMessage"]</div>
    }

    <div class="eventqr-grid">
        <section class="eventqr-card">
            <header class="eventqr-card-head">
                <h3 class="eventqr-title"><i class="bi bi-calendar2-plus-fill me-2"></i>Buat Acara</h3>
                <span class="badge text-bg-info">Admin</span>
            </header>
            <div class="eventqr-card-body">
                <form asp-action="Create" method="post" class="eventqr-form">
                    @Html.AntiForgeryToken()

                    <div>
                        <label asp-for="Form.EventName">Nama Acara</label>
                        <input asp-for="Form.EventName" placeholder="Contoh: Safety Briefing Shift Pagi" />
                        <span asp-validation-for="Form.EventName" class="invalid"></span>
                    </div>

                    <div>
                        <label asp-for="Form.EventLocation">Lokasi</label>
                        <input asp-for="Form.EventLocation" placeholder="Contoh: Pit A - Hall Utama" />
                        <span asp-validation-for="Form.EventLocation" class="invalid"></span>
                    </div>

                    <div>
                        <label asp-for="Form.StartAt">Waktu Mulai</label>
                        <input asp-for="Form.StartAt" type="datetime-local" />
                        <span asp-validation-for="Form.StartAt" class="invalid"></span>
                    </div>

                    <div>
                        <label asp-for="Form.EndAt">Waktu Selesai</label>
                        <input asp-for="Form.EndAt" type="datetime-local" />
                        <span asp-validation-for="Form.EndAt" class="invalid"></span>
                    </div>

                    <div>
                        <label asp-for="Form.EventDescription">Deskripsi</label>
                        <textarea asp-for="Form.EventDescription" placeholder="Keterangan acara, catatan, atau instruksi scan."></textarea>
                        <span asp-validation-for="Form.EventDescription" class="invalid"></span>
                    </div>

                    <div class="form-check mt-1">
                        <input class="form-check-input" asp-for="Form.IsActive" />
                        <label class="form-check-label" asp-for="Form.IsActive">Aktifkan event setelah dibuat</label>
                    </div>

                    <button class="eventqr-submit" type="submit"><i class="bi bi-check2-circle me-1"></i>Simpan Event & Generate QR</button>
                </form>
            </div>
        </section>

        <section class="eventqr-card">
            <header class="eventqr-card-head">
                <h3 class="eventqr-title"><i class="bi bi-list-check me-2"></i>Daftar Event</h3>
                <span class="badge text-bg-secondary">@Model.Events.Count event</span>
            </header>
            <div class="eventqr-card-body">
                <div class="eventqr-list">
                    @if (Model.Events.Count == 0)
                    {
                        <div class="event-empty">
                            Belum ada event absensi. Buat event baru untuk menghasilkan QR scan non-admin.
                        </div>
                    }
                    else
                    {
                        foreach (var ev in Model.Events)
                        {
                            var qrUrl = $"{baseUrl}/QrAttendance/Scan/{ev.QrToken}";
                            <article class="event-row">
                                <div class="event-meta">
                                    <h4>@ev.EventName</h4>
                                    <p><i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrWhiteSpace(ev.EventLocation) ? "Lokasi belum diisi" : ev.EventLocation)</p>
                                    <p><i class="bi bi-clock me-1"></i>@ev.StartAt.ToString("dd MMM yyyy HH:mm") - @ev.EndAt.ToString("HH:mm")</p>
                                    @if (!string.IsNullOrWhiteSpace(ev.EventDescription))
                                    {
                                        <p><i class="bi bi-chat-left-text me-1"></i>@ev.EventDescription</p>
                                    }
                                    <div class="event-badges">
                                        <span class="event-badge @(ev.IsActive ? "active" : "inactive")">@(ev.IsActive ? "ACTIVE" : "INACTIVE")</span>
                                        <span class="event-badge count">@ev.TotalAttendees hadir</span>
                                    </div>
                                </div>
                                <div class="event-actions">
                                    <button type="button" class="event-btn event-btn-success" data-bs-toggle="modal" data-bs-target="#qrModal" data-name="@ev.EventName" data-url="@qrUrl">
                                        <i class="bi bi-qr-code-scan"></i>Lihat QR
                                    </button>
                                    <a class="event-btn" asp-action="Attendance" asp-route-id="@ev.Id"><i class="bi bi-people-fill"></i>Lihat Kehadiran</a>

                                    <form asp-action="ToggleActive" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ev.Id" />
                                        <button type="submit"><i class="bi bi-power"></i>@(ev.IsActive ? "Nonaktifkan" : "Aktifkan")</button>
                                    </form>

                                    <form asp-action="RegenerateQr" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ev.Id" />
                                        <button type="submit"><i class="bi bi-arrow-repeat"></i>Regenerate QR</button>
                                    </form>
                                </div>
                            </article>
                        }
                    }
                </div>
            </div>
        </section>
    </div>
</div>

<div class="modal fade" id="qrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: 1px solid var(--border-color); background: var(--bg-card);">
            <div class="modal-header" style="border-bottom: 1px solid var(--border-color);">
                <h5 class="modal-title" id="qrModalTitle" style="font-weight: 800; color: var(--text-main);">QR Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="eventQrCanvas" class="qr-modal-canvas"></div>
                <div class="input-group">
                    <input id="eventQrUrl" type="text" class="form-control" readonly />
                    <button class="btn btn-outline-info" id="copyQrUrlBtn" type="button"><i class="bi bi-copy"></i></button>
                </div>
                <small class="text-muted d-block mt-2">Bagikan QR ini ke non-admin. Saat di-scan, sistem langsung merekam kehadiran.</small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        (function () {
            const qrModal = document.getElementById('qrModal');
            const qrCanvas = document.getElementById('eventQrCanvas');
            const qrTitle = document.getElementById('qrModalTitle');
            const qrUrlInput = document.getElementById('eventQrUrl');
            const copyBtn = document.getElementById('copyQrUrlBtn');

            qrModal?.addEventListener('show.bs.modal', function (event) {
                const trigger = event.relatedTarget;
                if (!trigger) return;

                const name = trigger.getAttribute('data-name') || 'QR Event';
                const url = trigger.getAttribute('data-url') || '';

                qrTitle.textContent = 'QR Event - ' + name;
                qrUrlInput.value = url;
                qrCanvas.innerHTML = '';

                if (url) {
                    new QRCode(qrCanvas, {
                        text: url,
                        width: 220,
                        height: 220,
                        colorDark: '#0f172a',
                        colorLight: '#ffffff',
                        correctLevel: QRCode.CorrectLevel.M
                    });
                }
            });

            copyBtn?.addEventListener('click', async function () {
                const val = qrUrlInput.value;
                if (!val) return;
                try {
                    await navigator.clipboard.writeText(val);
                    copyBtn.innerHTML = '<i class="bi bi-check2"></i>';
                    setTimeout(function () {
                        copyBtn.innerHTML = '<i class="bi bi-copy"></i>';
                    }, 1200);
                } catch {
                    alert('Gagal copy link QR.');
                }
            });
        })();
    </script>
}

@{
    ViewData["Title"] = "Admin Area - Bulk Upload";
}

<div class="animate-fade-in">
    <div class="screen-title">Admin Area</div>
    <p class="screen-subtitle">Upload data pelaporan secara massal menggunakan file Excel (.xlsx)</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 mb-4" role="alert" style="background-color: rgba(34, 197, 94, 0.15); color: var(--color-green); border-radius: 12px;">
            <i class="bi bi-check-circle-fill me-2"></i> @Html.Raw(TempData["SuccessMessage"])
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 mb-4" role="alert" style="background-color: rgba(244, 63, 94, 0.15); color: var(--color-red); border-radius: 12px;">
            <i class="bi bi-x-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card-sap border-primary-accent">
        <div class="mb-4">
            <a asp-controller="Admin" asp-action="DownloadTemplate" class="btn btn-outline-success w-100 py-2 fw-bold" style="border-radius: 12px;">
                <i class="bi bi-file-earmark-spreadsheet-fill me-2"></i> Unduh Template Kolom Excel
            </a>
        </div>

        <form asp-controller="Admin" asp-action="UploadExcel" method="post" enctype="multipart/form-data">
            <div class="d-flex justify-content-between align-items-center mb-4 pt-3 border-top" style="border-color: var(--border-color) !important;">
                <h5 class="mb-0 text-white" style="font-weight: 700;"><i class="bi bi-upload me-2 text-primary"></i>Upload Bulk Excel</h5>
            </div>
            
            <div class="form-group-sap mb-4">
                <label class="form-label-sap" for="excelFile">File Excel (SAP.xlsx)</label>
                <div class="input-sap-wrapper">
                    <i class="bi bi-upload input-sap-icon"></i>
                    <input type="file" id="excelFile" name="excelFile" class="input-sap" accept=".xlsx" style="padding-top: 10px;" required />
                </div>
                <small class="text-muted mt-2 d-block" style="font-size: 11px;">
                    Pastikan file memiliki sheet: <strong>HAZARD REPORT, INSPECTION, ACTION PLAN, SAFETY TALK, P5M</strong>
                </small>
            </div>

            <button type="submit" class="btn btn-sap-primary w-100 py-3">
                <i class="bi bi-cloud-arrow-up-fill me-2"></i> MULAI UPLOAD DATA
            </button>
        </form>
    </div>
</div>

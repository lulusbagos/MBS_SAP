                    </div>
                </div>

                <button type="submit" class="btn btn-sap-primary w-100 py-3">
                    <i class="bi bi-check-circle-fill me-2"></i> KIRIM LAPORAN INSPEKSI
                </button>
            </form>
        </div>

        <!-- History/List Column -->
        <div>
            <div class="history-header mb-3">
                <h6 class="text-white" style="font-weight: 700;"><i class="bi bi-list-task me-2" style="color: var(--color-primary);"></i>Log Inspeksi Terakhir</h6>
            </div>
            
            @if (Model == null || !Model.Any())
            {
                <div class="card-sap text-center py-4 text-muted">
                    <i class="bi bi-inbox-fill d-block mb-2" style="font-size: 32px;"></i>
                    Belum ada riwayat inspeksi tercatat.
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @foreach (var item in Model)
                    {
                        <div class="card-sap border-green-accent mb-0">
                            
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span style="font-weight: 700; font-size: 14px; color: var(--text-main);">@item.JenisInspeksi</span>
                                    <span class="d-block text-muted" style="font-size: 11px;"><i class="bi bi-geo-alt-fill me-1"></i>@(item.Lokasi ?? item.Area ?? "General")</span>
                                </div>
                                <span class="status-badge approved" style="font-size: 9px;">
                                    Selesai
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(item.DetilLokasi))
                            {
                                <p style="font-size: 11px; color: var(--text-muted); background-color: var(--bg-layout); padding: 8px; border-radius: 6px; margin: 8px 0 10px; border-left: 3px solid var(--color-primary);">
                                    <strong>Detil:</strong> @item.DetilLokasi
                                </p>
                            }

                            <div class="d-flex justify-content-between align-items-center pt-2 mt-2" style="border-top: 1px solid var(--border-color); font-size: 11px; color: var(--text-muted);">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="status-badge check"><i class="bi bi-check-circle-fill me-1"></i>Selesai</span>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-link text-muted p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border: 1px solid var(--border-color); background: var(--bg-card); font-size: 13px;">
                                            <li><a class="dropdown-item text-white" href="javascript:void(0)" onclick="editInspection(@item.Id)"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Inspeksi</a></li>
                                            <li><hr class="dropdown-divider border-secondary"></li>
                                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="deleteInspection(@item.Id)"><i class="bi bi-trash-fill me-2"></i>Hapus Inspeksi</a></li>
                                        </ul>
                                    </div>
                                </div>
                                <span><i class="bi bi-clock me-1"></i>@item.Tanggal.ToString("dd MMM yyyy") @item.Waktu.ToString(@"hh\:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        
    </div>
</div>

<!-- Modal Add Area -->
<div class="modal fade" id="addAreaModal" tabindex="-1" aria-labelledby="addAreaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold" id="addAreaModalLabel"><i class="bi bi-plus-square-fill text-primary me-2"></i>Tambah Area Utama Baru</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-4">
                <div class="alert alert-info py-2" style="font-size: 12px; border-radius: 8px;">
                    <i class="bi bi-info-circle me-1"></i> Area yang Anda tambahkan hanya akan terlihat oleh karyawan di perusahaan Anda.
                </div>
                <div class="form-group-sap mb-3">
                    <label class="form-label-sap">Nama Area</label>
                    <input type="text" id="newAreaName" class="form-control input-sap text-uppercase" placeholder="Misal: PIT TEMPUDO" />
                    <div id="addAreaError" class="text-danger mt-2" style="font-size: 12px; display: none;"></div>
                </div>
                <div class="mt-3">
                    <h6 class="text-white fw-bold mb-2" style="font-size: 13px;"><i class="bi bi-list-task me-1 text-primary"></i>Daftar Area Terdaftar</h6>
                    <div id="existingAreasList" class="list-group" style="max-height: 180px; overflow-y: auto; border-radius: 8px; border: 1px solid var(--border-color); background: rgba(0,0,0,0.2);">
                        <div class="p-3 text-center text-muted" style="font-size: 12px;">Memuat daftar area...</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 8px;">Tutup</button>
                <button type="button" class="btn btn-primary" id="btnSaveArea" onclick="saveNewArea()" style="border-radius: 8px; font-weight: 600;">Simpan Area</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            const file = input.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('uploadPlaceholder').classList.add('d-none');
                    document.getElementById('imagePreviewContainer').classList.remove('d-none');
                }
                reader.readAsDataURL(file);
            }
        }

        // Geolocation Function
        function getLocation() {
            var btn = document.getElementById('btnGetLocation');
            var input = document.getElementById('lokasi');
            
            if (navigator.geolocation) {
                // Show loading spinner
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="width: 14px; height: 14px;"></span>';
                
                navigator.geolocation.getCurrentPosition(function(position) {
                    var lat = position.coords.latitude.toFixed(6);
                    var lon = position.coords.longitude.toFixed(6);
                    input.value = lat + ", " + lon;
                    btn.innerHTML = '<i class="bi bi-check-circle-fill text-success"></i>';
                }, function(error) {
                    alert('Gagal mendapatkan lokasi GPS: ' + error.message);
                    btn.innerHTML = '<i class="bi bi-crosshair text-danger"></i>';
                }, {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 0
                });
            } else {
                alert("Geolocation tidak didukung oleh browser ini.");
            }
        }

        function setCheck(itemIndex, value, btn) {
            document.getElementById('valCheck' + itemIndex).value = value;
            
            const parent = btn.parentElement;
            const buttons = parent.querySelectorAll('.btn-option');
            buttons.forEach(b => {
                b.classList.remove('active');
            });
            
            btn.classList.add('active');
        }

        // PJA Search Logic
        let pjaTimeout = null;
        let pjaIsLintasPerusahaan = false;

        function toggleLintasPerusahaanSearch() {
            pjaIsLintasPerusahaan = document.getElementById('lintasPerusahaanToggle').checked;
            const input = document.getElementById('pjaSearchInput').value;
            if(input.length >= 3) {
                searchPja();
            }
        }

        $('#pjaSearchInput').on('input', function() {
            clearTimeout(pjaTimeout);
            const query = $(this).val();
            
            if (query.length < 1) {
                $('#pjaSearchResults').hide();
                return;
            }

            pjaTimeout = setTimeout(searchPja, 300);
        });

        function searchPja() {
            const query = $('#pjaSearchInput').val();
            if (query.length < 1) return;

            $.when(
                $.get('/Api/GetPjaReference', {
                    lintasPerusahaan: pjaIsLintasPerusahaan
                }),
                $.get('/Api/SearchEmployee', {
                    query: query,
                    lintasPerusahaan: pjaIsLintasPerusahaan
                })
            ).done(function(pjaRefResp, employeeResp) {
                const pjaRefs = pjaRefResp[0] || [];
                const employees = employeeResp[0] || [];
                const lowerQuery = query.toLowerCase();

                const filteredPjaRefs = pjaRefs.filter(function(x) {
                    return (x.nama || '').toLowerCase().includes(lowerQuery)
                        || (x.perusahaan || '').toLowerCase().includes(lowerQuery)
                        || (x.nik || '').toLowerCase().includes(lowerQuery)
                        || (x.jabatan || '').toLowerCase().includes(lowerQuery);
                });

                const merged = [];
                const seen = new Set();

                filteredPjaRefs.forEach(function(item) {
                    const key = (item.nik || '') + '|' + (item.perusahaan || '');
                    if (!seen.has(key)) {
                        seen.add(key);
                        merged.push(item);
                    }
                });

                employees.forEach(function(item) {
                    const key = (item.nik || '') + '|' + (item.perusahaan || '');
                    if (!seen.has(key)) {
                        seen.add(key);
                        item.companyOnly = false;
                        item.source = item.source || 'employee';
                        merged.push(item);
                    }
                });

                const resultsContainer = $('#pjaSearchResults');
                resultsContainer.empty();
                
                if (merged.length === 0) {
                    resultsContainer.append('<div class="p-3 text-center text-muted" style="font-size: 12px;">PJA tidak ditemukan.</div>');
                } else {
                    merged.forEach(function(k) {
                        const init = (k.nama || '-').charAt(0);
                        const safeNik = (k.nik || '').replace(/'/g, "\\'");
                        const safeNama = (k.nama || '').replace(/'/g, "\\'");
                        const safeJabatan = (k.jabatan || '').replace(/'/g, "\\'");
                        const safeDept = (k.departemen || '').replace(/'/g, "\\'");
                        const safePerusahaan = (k.perusahaan || '').replace(/'/g, "\\'");
                        const safeCompanyOnly = !!k.companyOnly;

                        const badge = safeCompanyOnly
                            ? '<span class="badge bg-warning text-dark" style="font-size:10px;">COMPANY ONLY</span>'
                            : '<span class="badge bg-success" style="font-size:10px;">PJA/EMPLOYEE</span>';

                        const item = $(`
                            <div class="dropdown-item p-3" style="cursor: pointer; border-bottom: 1px solid var(--border-color);" onclick="selectPja('${safeNik}', '${safeNama}', '${safeJabatan}', '${safeDept}', '${safePerusahaan}', ${safeCompanyOnly})">
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--bg-layout); display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 16px; color: var(--color-primary);">
                                        ${init}
                                    </div>
                                    <div>
                                        <div class="d-flex align-items-center gap-2" style="font-weight: 700; font-size: 13px; color: var(--text-main);">
                                            <span>${k.nama || '-'}</span>${badge}
                                        </div>
                                        <div style="font-size: 11px; color: var(--text-muted);"><i class="bi bi-person-badge me-1"></i>${k.nik || '-'} &bull; ${k.jabatan || '-'}</div>
                                        <div style="font-size: 10px; color: var(--text-muted); margin-top: 2px;"><i class="bi bi-building me-1"></i>${k.departemen || '-'} | ${k.perusahaan || '-'}</div>
                                    </div>
                                </div>
                            </div>
                        `);
                        resultsContainer.append(item);
                    });
                }
                resultsContainer.show();
            });
        }

        function selectPja(nik, nama, jabatan, dept, perusahaan, companyOnly) {
            $('#nikPja').val(nik);
            $('#pja').val(nama);
            $('#departemenPja').val(dept);
            
            // Display Logic
            let initial = nama.charAt(0).toUpperCase();
            $('#pjaInitial').text(initial);
            $('#pjaDisplayNama').text(nama);
            $('#pjaDisplayJabatan').text(companyOnly ? (jabatan || 'PENANGGUNG JAWAB PERUSAHAAN') : (jabatan || '-'));
            $('#pjaDisplayDept').text(dept || '-');
            $('#pjaDisplayPerusahaan').text(perusahaan || '-');

            $('#selectedPjaCard').removeClass('d-none');
            $('#pjaSearchResults').hide();
            $('#pjaSearchInput').val('');
            $('#pjaSearchInput').parent().hide();
            $('#lintasPerusahaanToggle').closest('.d-flex').hide();
        }

        function cancelEditInspection() {
            $('#inspectionForm')[0].reset();
            $('#inspectionId').val('');
            $('#formTitle').html('<i class="bi bi-file-earmark-check-fill me-2" style="color: var(--color-primary);"></i>Form Pemeriksaan Unit/Area');
            $('#btnCancelEdit').addClass('d-none');
            clearSelectedPja();
            
            // Reset checklist UI
            $('.btn-option').removeClass('active');
            $('#valCheck1, #valCheck2, #valCheck3, #valCheck4').val('');
            $('#checklistSection').show();

            // Clear custom questions
            customQuestionsList = [];
            renderCustomQuestions();
            toggleFormBuilder(false);

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function editInspection(id) {
            $.get('/Inspection/GetData/' + id, function(data) {
                if (data) {
                    $('#inspectionId').val(data.id);
                    
                    // Format dates and times
                    if (data.tanggal) $('#tanggal').val(data.tanggal.split('T')[0]);
                    if (data.waktu) $('#waktuStr').val(data.waktu.substring(0, 5));
                    
                    // Selects
                    $('#area').val(data.area).change();
                    $('#jenisInspeksi').val(data.jenisInspeksi).change();

                    // Inputs
                    $('#lokasi').val(data.lokasi);
                    $('#detilLokasi').val(data.detilLokasi);

                    // PJA
                    if (data.pja) {
                        const targetNik = data.nikPja || ('COMPANY:' + (data.perusahaanId || ''));
                        selectPja(targetNik, data.pja, '', data.departemenPja, '', !data.nikPja);
                    } else {
                        clearSelectedPja();
                    }

                    // Hide checklist in edit mode since they are not saved in DB (only processed on insert)
                    $('#checklistSection').hide();

                    // Parse custom questions from Catatan
                    let mainCatatan = data.catatan || '';
                    customQuestionsList = [];
                    
                    const marker = "<!--CUSTOM_BUILDER_DATA:";
                    const idx = mainCatatan.indexOf(marker);
                    if (idx !== -1) {
                        try {
                            const jsonStr = mainCatatan.substring(idx + marker.length, mainCatatan.lastIndexOf("-->"));
                            customQuestionsList = JSON.parse(jsonStr);
                        } catch(e) {
                            console.error("Error parsing custom questions json", e);
                        }
                        
                        // Extract original catatan
                        const sepMarker = "--- PERTANYAAN TAMBAHAN ---";
                        const sepIdx = mainCatatan.indexOf(sepMarker);
                        if (sepIdx !== -1) {
                            mainCatatan = mainCatatan.substring(0, sepIdx).trim();
                        }
                    }
                    
                    $('#catatan').val(mainCatatan);
                    renderCustomQuestions();

                    $('#formTitle').html('<i class="bi bi-pencil-square me-2" style="color: var(--color-primary);"></i>Edit Inspeksi');
                    $('#btnCancelEdit').removeClass('d-none');
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
            }).fail(function() {
                alert("Gagal mengambil data inspeksi. Laporan mungkin sudah dihapus.");
            });
        }

        function deleteInspection(id) {
            if (confirm("Apakah Anda yakin ingin menghapus inspeksi ini? Data yang dihapus tidak dapat dikembalikan.")) {
                var form = $('<form action="/Inspection/Delete/' + id + '" method="post">' +
                             '<input type="hidden" name="__RequestVerificationToken" value="' + $('input[name="__RequestVerificationToken"]').val() + '" />' +
                             '</form>');
                $('body').append(form);
                form.submit();
            }
        }

        function clearSelectedPja() {
            $('#pja').val('');
            $('#nikPja').val('');
            $('#departemenPja').val('');
            
            $('#selectedPjaCard').addClass('d-none');
            $('#pjaSearchInput').parent().show();
            $('#lintasPerusahaanToggle').closest('.d-flex').show();
            $('#pjaSearchInput').focus();
        }

        let globalAreasList = [];

        function renderAreasList() {
            var container = $('#existingAreasList');
            if (!container.length) return;
            container.empty();
            if (globalAreasList && globalAreasList.length > 0) {
                globalAreasList.forEach(function(item) {
                    var row = $(`
                        <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent border-0 border-bottom text-white p-2" id="area-row-${item.id}" style="border-color: rgba(255,255,255,0.05) !important;">
                            <span style="font-size: 13px; font-weight: 600;">${item.namaArea}</span>
                            <button type="button" class="btn btn-sm btn-outline-danger p-0" onclick="confirmDeleteArea(${item.id}, '${item.namaArea}')" style="border-radius: 6px; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-color: rgba(239, 68, 68, 0.4); color: #ef4444;">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    `);
                    container.append(row);
                });
            } else {
                container.append('<div class="p-3 text-center text-muted" style="font-size: 12px;">Belum ada Area Utama</div>');
            }
        }

        function confirmDeleteArea(id, namaArea) {
            var row = $(`#area-row-${id}`);
            row.html(`
                <div class="d-flex align-items-center gap-2 w-100 py-1">
                    <span class="text-danger fw-bold text-truncate" style="font-size: 11px; flex-grow: 1;">Hapus ${namaArea}?</span>
                    <input type="password" placeholder="Passcode" class="form-control form-control-sm text-center bg-dark border-secondary text-white" style="width: 80px; font-size: 10px; height: 26px; border-radius: 6px; padding: 0 4px;" id="passcode-${id}" />
                    <button type="button" class="btn btn-danger btn-sm p-0" onclick="executeDeleteArea(${id}, '${namaArea}')" style="font-size: 10px; height: 26px; width: 42px; border-radius: 6px; font-weight: 600;">Hapus</button>
                    <button type="button" class="btn btn-secondary btn-sm p-0" onclick="renderAreasList()" style="font-size: 10px; height: 26px; width: 42px; border-radius: 6px; font-weight: 600; background: var(--bg-body); border-color: var(--border-color);">Batal</button>
                </div>
            `);
            $(`#passcode-${id}`).focus();
        }

        function executeDeleteArea(id, namaArea) {
            var passcode = $(`#passcode-${id}`).val();
            if (!passcode) {
                alert("Passcode wajib diisi!");
                return;
            }

            $.ajax({
                url: '/Api/DeleteArea',
                type: 'POST',
                data: { id: id, passcode: passcode },
                success: function(response) {
                    loadAreas();
                },
                error: function(xhr) {
                    alert(xhr.responseText || "Gagal menghapus area.");
                    renderAreasList();
                }
            });
        }

        function loadAreas(selectedValue) {
            $.ajax({
                url: '/Api/GetAreas',
                type: 'GET',
                cache: false,
                dataType: 'json',
                success: function(data) {
                    globalAreasList = data;
                    renderAreasList();
                    
                    var select = $('#area');
                    select.empty();
                    select.append('<option value="" disabled selected>Pilih Area...</option>');
                    if (data && data.length > 0) {
                        data.forEach(function(item) {
                            select.append('<option value="' + item.namaArea + '">' + item.namaArea + '</option>');
                        });
                    } else {
                        select.append('<option value="" disabled>Belum ada Area Utama</option>');
                    }
                    
                    if (selectedValue) {
                        select.val(selectedValue);
                    }
                    
                    select.trigger('refresh');
                },
                error: function(xhr, status, error) {
                    console.error("Failed to load areas:", error);
                    var select = $('#area');
                    select.empty();
                    select.append('<option value="" disabled>Gagal memuat area</option>');
                    select.trigger('refresh');
                }
            });
        }

        function saveNewArea() {
            var btn = $('#btnSaveArea');
            var errorDiv = $('#addAreaError');
            var areaName = $('#newAreaName').val();

            if (!areaName || areaName.trim() === '') {
                errorDiv.text('Nama area tidak boleh kosong').show();
                return;
            }

            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Menyimpan...');
            errorDiv.hide();

            $.ajax({
                url: '/Api/AddArea',
                type: 'POST',
                dataType: 'json',
                data: { namaArea: areaName },
                success: function(response) {
                    $('#addAreaModal').modal('hide');
                    $('#newAreaName').val('');
                    var areaToSelect = (response && response.data) ? response.data.namaArea : null;
                    loadAreas(areaToSelect);
                    btn.prop('disabled', false).text('Simpan Area');
                },
                error: function(xhr) {
                    errorDiv.text(xhr.responseText || 'Terjadi kesalahan saat menyimpan area').show();
                    btn.prop('disabled', false).text('Simpan Area');
                }
            });
        }

        function setScore(module, question, score) {
            // Update hidden input
            $('#valQ' + module + '_' + question).val(score);

            // Reset all buttons in this group
            $('.btn-q' + module + '_' + question).css({
                'background': 'transparent',
                'color': 'var(--text-muted)'
            });
            $('#btnQ' + module + '_' + question + '_0').css('border-color', 'var(--border-color)');
            $('#btnQ' + module + '_' + question + '_1').css('border-color', 'var(--border-color)');
            $('#btnQ' + module + '_' + question + '_2').css('border-color', 'var(--border-color)');

            // Highlight selected
            if (score === 0) {
                $('#btnQ' + module + '_' + question + '_0').css({ 'background': '#f43f5e', 'color': 'white', 'border-color': '#f43f5e' });
            } else if (score === 1) {
                $('#btnQ' + module + '_' + question + '_1').css({ 'background': '#64748b', 'color': 'white', 'border-color': '#64748b' });
            } else if (score === 2) {
                $('#btnQ' + module + '_' + question + '_2').css({ 'background': '#10b981', 'color': 'white', 'border-color': '#10b981' });
            }

            var commentContainer = $('#commentContainer' + module + '_' + question);
            var divRencana = $('#divRencana' + module + '_' + question);
            var reqImg = $('#reqImg' + module + '_' + question);
            var fotoInput = $('#foto_' + module + '_' + question);
            var commentInput = $('#commentQ' + module + '_' + question);

            // Always show the container because YA also can upload photo (optional)
            commentContainer.slideDown('fast');

            if (score === 0) { // TIDAK
                reqImg.show();
                fotoInput.prop('required', true);
                divRencana.slideDown('fast');
                commentInput.prop('required', true);
            } else if (score === 1) { // N/A
                reqImg.show();
                fotoInput.prop('required', true);
                divRencana.slideUp('fast');
                commentInput.prop('required', false).val('');
                updateMainNotes();
            } else if (score === 2) { // YA
                reqImg.hide();
                fotoInput.prop('required', false);
                divRencana.slideUp('fast');
                commentInput.prop('required', false).val('');
                updateMainNotes();
            }
        }

        function updateMainNotes() {
            var combinedNotes = "";
            for (var m = 1; m <= 5; m++) {
                for (var q = 1; q <= 3; q++) {
                    var score = $('#valQ' + m + '_' + q).val();
                    var status = score == 0 ? "TIDAK" : (score == 1 ? "N/A" : "YA");
                    if (score == 0) {
                        var comment = $('#commentQ' + m + '_' + q).val();
                        if (comment && comment.trim() !== "") {
                            combinedNotes += "[M" + m + " Q" + q + " - " + status + "] Rencana Tindakan: " + comment.trim() + "\n";
                        }
                    }
                }
            }
            $('#catatan').val(combinedNotes);
        }

        let customQuestionsList = [];

        function toggleFormBuilder(show) {
            const box = $('#formBuilderBox');
            if (show) {
                box.slideDown('fast');
                $('#customQuestionText').focus();
            } else {
                box.slideUp('fast');
                // Clear fields
                $('#editQuestionId').val('');
                $('#customQuestionText').val('');
                $('#customAnswerType').val('text').change();
                $('#optionsListContainer').empty();
                $('#builderTitle').html('<i class="bi bi-plus-square text-primary me-1"></i> Buat Pertanyaan Baru');
            }
        }

        function handleAnswerTypeChange() {
            const type = $('#customAnswerType').val();
            const wrapperCount = $('#choiceOptionsCountWrapper');
            const wrapperList = $('#choiceOptionsWrapper');
            if (type === 'choice') {
                wrapperCount.slideDown('fast');
                wrapperList.slideDown('fast');
                
                // Set default count to 3 options
                $('#customOptionsCount').val('3');
                handleOptionsCountChange(['YA', 'TIDAK', 'N/A']);
            } else {
                wrapperCount.slideUp('fast');
                wrapperList.slideUp('fast');
            }
        }

        function handleOptionsCountChange(initialValues = []) {
            const count = parseInt($('#customOptionsCount').val()) || 2;
            const container = $('#optionsListContainer');
            
            // Keep existing values if any, so we don't clear inputs when they change the select count
            const currentValues = [];
            $('#optionsListContainer .option-value').each(function() {
                currentValues.push($(this).val());
            });
            
            container.empty();
            
            for (let i = 0; i < count; i++) {
                let val = '';
                if (initialValues && initialValues[i] !== undefined) {
                    val = initialValues[i];
                } else if (currentValues && currentValues[i] !== undefined) {
                    val = currentValues[i];
                } else {
                    // Smart defaults
                    val = i === 0 ? 'YA' : (i === 1 ? 'TIDAK' : (i === 2 ? 'N/A' : ''));
                }
                
                const placeholder = `Opsi ${i + 1}...`;
                const rowHtml = `
                    <div class="form-group mb-2">
                        <label style="font-size: 10px; color: var(--text-muted); display: block; margin-bottom: 2px;">Opsi ${i + 1} <span class="text-danger">*</span></label>
                        <input type="text" class="form-control input-sap option-value" placeholder="${placeholder}" value="${val}" style="font-size: 11px; height: 34px; border-radius: 6px; background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); color: white;" />
                    </div>
                `;
                container.append(rowHtml);
            }
        }

        function saveCustomQuestion() {
            const questionText = $('#customQuestionText').val().trim();
            const answerType = $('#customAnswerType').val();
            const editId = $('#editQuestionId').val();

            if (!questionText) {
                alert('Teks pertanyaan wajib diisi.');
                return;
            }

            let choicesList = [];
            if (answerType === 'choice') {
                let hasEmptyOption = false;
                $('#optionsListContainer .option-value').each(function(i) {
                    const val = $(this).val().trim();
                    if (!val) {
                        hasEmptyOption = true;
                    }
                    choicesList.push(val);
                });
                
                if (hasEmptyOption) {
                    alert('Semua pilihan ganda / opsi wajib diisi.');
                    return;
                }
                
                if (choicesList.length === 0) {
                    alert('Pilihan ganda / opsi wajib dibuat.');
                    return;
                }
            }

            if (editId) {
                // Update
                const q = customQuestionsList.find(x => x.id === editId);
                if (q) {
                    q.question = questionText;
                    q.type = answerType;
                    q.choices = choicesList;
                    // Reset value if type changed or old value not in new choices
                    if (q.type === 'text') {
                        q.value = '';
                    } else if (!choicesList.includes(q.value)) {
                        q.value = choicesList[0];
                    }
                }
            } else {
                // Insert new
                customQuestionsList.push({
                    id: 'q_' + Date.now(),
                    question: questionText,
                    type: answerType,
                    choices: choicesList,
                    value: answerType === 'choice' ? choicesList[0] : ''
                });
            }

            toggleFormBuilder(false);
            renderCustomQuestions();
        }

        function deleteCustomQuestion(id) {
            if (confirm('Apakah Anda yakin ingin menghapus pertanyaan kustom ini?')) {
                customQuestionsList = customQuestionsList.filter(x => x.id !== id);
                renderCustomQuestions();
            }
        }

        function editCustomQuestion(id) {
            const q = customQuestionsList.find(x => x.id === id);
            if (!q) return;

            $('#editQuestionId').val(q.id);
            $('#customQuestionText').val(q.question);
            
            // Set answer type
            $('#customAnswerType').val(q.type);

            if (q.type === 'choice') {
                $('#choiceOptionsCountWrapper').show();
                $('#choiceOptionsWrapper').show();
                
                // Set options count select
                $('#customOptionsCount').val(q.choices.length);
                
                // Load options inputs
                handleOptionsCountChange(q.choices);
            } else {
                $('#choiceOptionsCountWrapper').hide();
                $('#choiceOptionsWrapper').hide();
            }

            $('#builderTitle').html('<i class="bi bi-pencil-square text-primary me-1"></i> Edit Pertanyaan');
            toggleFormBuilder(true);
        }

        function updateCustomAnswer(id, val) {
            const q = customQuestionsList.find(x => x.id === id);
            if (q) {
                q.value = val;
            }
        }

        function setCustomChoiceAnswer(id, val) {
            const q = customQuestionsList.find(x => x.id === id);
            if (q) {
                q.value = val;
                renderCustomQuestions();
            }
        }

        function renderCustomQuestions() {
            const container = $('#customQuestionsContainer');
            container.empty();

            if (customQuestionsList.length === 0) {
                container.html('<div class="text-muted text-center py-2" style="font-size: 11px; font-style: italic;">Belum ada pertanyaan kustom ditambahkan.</div>');
                return;
            }

            customQuestionsList.forEach((q, idx) => {
                let answerHtml = '';
                if (q.type === 'text') {
                    answerHtml = `
                        <input type="text" class="form-control input-sap custom-answer-input" placeholder="Tulis jawaban..." value="${q.value || ''}" oninput="updateCustomAnswer('${q.id}', this.value)" style="font-size: 12px; height: 38px; border-radius: 8px; background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); color: white;" />
                    `;
                } else if (q.type === 'choice') {
                    answerHtml = '<div class="d-flex gap-1 flex-wrap">';
                    q.choices.forEach(choice => {
                        const isActive = q.value === choice;
                        // Choose a themed look depending on choice name
                        let activeStyles = 'background: var(--color-primary); color: white; border-color: var(--color-primary);';
                        if (choice.toUpperCase() === 'YA') {
                            activeStyles = 'background: #10b981; color: white; border-color: #10b981;';
                        } else if (choice.toUpperCase() === 'TIDAK') {
                            activeStyles = 'background: #f43f5e; color: white; border-color: #f43f5e;';
                        } else if (choice.toUpperCase() === 'N/A') {
                            activeStyles = 'background: #64748b; color: white; border-color: #64748b;';
                        }
                        
                        const inlineStyle = isActive ? activeStyles : 'background: transparent; color: var(--text-muted); border: 1px solid var(--border-color);';
                        
                        answerHtml += `
                            <button type="button" class="btn btn-sm" onclick="setCustomChoiceAnswer('${q.id}', '${choice}')" style="font-size: 11px; font-weight: 600; padding: 6px 12px; border-radius: 8px; transition: all 0.2s ease; ${inlineStyle}">
                                ${choice}
                            </button>
                        `;
                    });
                    answerHtml += '</div>';
                }

                const html = `
                    <div class="checkpoint-card p-3" style="border-radius: 12px; background: rgba(255,255,255,0.01); border: 1px solid var(--border-color); margin-bottom: 4px;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-white fw-semibold" style="font-size: 12.5px;">${idx + 1}. ${q.question}</span>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-sm btn-link p-0 text-primary" onclick="editCustomQuestion('${q.id}')" title="Edit Pertanyaan"><i class="bi bi-pencil" style="font-size: 12px;"></i></button>
                                <button type="button" class="btn btn-sm btn-link p-0 text-danger" onclick="deleteCustomQuestion('${q.id}')" title="Hapus Pertanyaan"><i class="bi bi-trash" style="font-size: 12px;"></i></button>
                            </div>
                        </div>
                        <div class="mt-2">
                            ${answerHtml}
                        </div>
                    </div>
                `;
                container.append(html);
            });
        }

        $(document).ready(function() {
            loadAreas();
            
            // Initialize custom questions empty display
            renderCustomQuestions();
            
            // Auto fetch GPS if creating new inspection
            if (!$('#inspectionId').val() && typeof getLocation === 'function') {
                getLocation();
            }

            // Prevent double submission
            $('#inspectionForm').on('submit', function() {
                var btn = $(this).find('button[type="submit"]');
                if (btn.prop('disabled')) {
                    return false;
                }

                // Construct custom questions text
                if (customQuestionsList.length > 0) {
                    let originalCatatan = $('#catatan').val() || '';
                    const sepMarker = "--- PERTANYAAN TAMBAHAN ---";
                    const sepIdx = originalCatatan.indexOf(sepMarker);
                    if (sepIdx !== -1) {
                        originalCatatan = originalCatatan.substring(0, sepIdx).trim();
                    }
                    
                    let extraText = "\n\n--- PERTANYAAN TAMBAHAN ---";
                    customQuestionsList.forEach((q, index) => {
                        extraText += `\n${index + 1}. ${q.question}: ${q.value || 'Belum Diisi'}`;
                    });
                    extraText += `\n\n<!--CUSTOM_BUILDER_DATA:${JSON.stringify(customQuestionsList)}-->`;
                    
                    $('#catatan').val(originalCatatan + extraText);
                }

                btn.prop('disabled', true);
                var originalText = btn.html();
                btn.html('<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>MENYIMPAN...');
                
                // Allow form to submit normally
                return true;
            });
        });

        $(document).on('click', function(e) {
            if (!$(e.target).closest('.form-group-sap').length) {
                $('#pjaSearchResults').hide();
            }
        });
    </script>
    <style>
        input[type="text"].input-sap, textarea.input-sap {
            text-transform: uppercase;
        }
    </style>
}







@model MBS_SAP.Models.IncidentNews
@{
    ViewData["Title"] = Model.Judul;
    bool isAdmin = (bool)(ViewData["IsAdmin"] ?? false);
    
    var sevClass = (Model.Kategori?.ToLower()) switch
    {
        "ringan" => "sev-ringan",
        "sedang" => "sev-sedang",
        "berat" => "sev-berat",
        "fatal" => "sev-fatal",
        _ => "sev-sedang"
    };
}

<style>
    .detail-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    
    .detail-img-container {
        position: relative;
        width: 100%;
        height: 380px;
        background: #111;
        overflow: hidden;
    }
    
    @@media (max-width: 768px) {
        .detail-img-container {
            height: 240px;
        }
    }
    
    .detail-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
        transition: transform 0.5s ease;
    }
    
    .detail-img:hover {
        transform: scale(1.02);
    }
    
    .detail-no-img {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(244,63,94,0.2), rgba(220,38,38,0.1));
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .detail-body {
        padding: 24px 30px;
    }
    
    @@media (max-width: 576px) {
        .detail-body {
            padding: 20px 16px;
        }
    }
    
    .meta-item {
        font-size: 12px;
        color: var(--text-muted);
        display: inline-flex;
        align-items: center;
        margin-right: 16px;
        margin-bottom: 8px;
    }
    
    .meta-item i {
        margin-right: 6px;
    }
    
    .severity-badge {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        padding: 6px 14px;
        border-radius: 99px;
        display: inline-block;
    }
    
    .sev-ringan { background: rgba(16,185,129,0.15); color: #10b981; }
    .sev-sedang { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .sev-berat  { background: rgba(244,63,94,0.15); color: #f43f5e; }
    .sev-fatal  { background: rgba(220,38,38,0.25); color: #dc2626; }
    
    /* Scrollable text content per user request */
    .scrollable-content {
        max-height: 420px;
        overflow-y: auto;
        padding-right: 16px;
        font-size: 14.5px;
        line-height: 1.8;
        color: var(--text-main);
    }
    
    /* Custom Scrollbar */
    .scrollable-content::-webkit-scrollbar {
        width: 6px;
    }
    
    .scrollable-content::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
    }
    
    .scrollable-content::-webkit-scrollbar-thumb {
        background: rgba(244, 63, 94, 0.3);
        border-radius: 10px;
    }
    
    .scrollable-content::-webkit-scrollbar-thumb:hover {
        background: rgba(244, 63, 94, 0.6);
    }
</style>

<div class="animate-fade-in pb-4">
    <!-- Back button -->
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-sm text-decoration-none p-0" style="color: var(--text-muted); font-weight: 600;">
            <i class="bi bi-arrow-left me-1"></i> Kembali ke Berita
        </a>
    </div>

    <div class="detail-card">
        <!-- Image Area -->
        <div class="detail-img-container">
            @if (!string.IsNullOrEmpty(Model.GambarUrl))
            {
                <img src="@Model.GambarUrl" alt="@Model.Judul" class="detail-img" />
            }
            else
            {
                <div class="detail-no-img">
                    <i class="bi bi-newspaper" style="font-size: 80px; color: rgba(255,255,255,0.2);"></i>
                </div>
            }
            
            <!-- Category Badge overlay -->
            <div style="position: absolute; bottom: 20px; left: 24px; z-index: 2;">
                <span class="severity-badge @sevClass">Kategori: @(Model.Kategori ?? "Umum")</span>
            </div>
            
            <!-- Shadow gradient overlay for readability -->
            <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 120px; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); z-index: 1;"></div>
        </div>

        <div class="detail-body">
            <!-- Title -->
            <h3 style="font-weight: 800; color: var(--text-main); line-height: 1.4; margin-bottom: 16px;">
                @Model.Judul
            </h3>

            <!-- Metadata Details -->
            <div class="d-flex flex-wrap align-items-center mb-4" style="border-bottom: 1px solid var(--border-color); padding-bottom: 16px;">
                <div class="meta-item">
                    <i class="bi bi-calendar3"></i> @Model.CreatedAt.ToString("dd MMMM yyyy, HH:mm")
                </div>
                @if (!string.IsNullOrEmpty(Model.Lokasi))
                {
                    <div class="meta-item">
                        <i class="bi bi-geo-alt-fill text-danger"></i> @Model.Lokasi
                    </div>
                }
                @if (Model.TanggalKejadian.HasValue)
                {
                    <div class="meta-item">
                        <i class="bi bi-clock-history"></i> Kejadian: @Model.TanggalKejadian.Value.ToString("dd MMM yyyy")
                    </div>
                }
                <div class="meta-item">
                    <i class="bi bi-person-fill"></i> Oleh: @Model.DibuatOleh
                </div>
            </div>

            <!-- Content Area - Scrollable -->
            <div class="scrollable-content">
                @Html.Raw(Model.Konten.Replace("\r\n", "<br/>").Replace("\n", "<br/>"))
            </div>

            <!-- Bottom Control -->
            @if (isAdmin)
            {
                <div class="d-flex justify-content-end mt-4 pt-3" style="border-top: 1px solid var(--border-color);">
                    <form asp-action="Delete" method="post" onsubmit="return confirm('Apakah Anda yakin ingin menghapus berita insiden ini?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm px-4" style="border-radius: 10px; font-weight: 600;">
                            <i class="bi bi-trash3-fill me-1"></i> Hapus Berita
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

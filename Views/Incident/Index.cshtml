@model IEnumerable<MBS_SAP.Models.IncidentNews>
@{
    ViewData["Title"] = "Data Insiden";
    bool isAdmin = (bool)(ViewData["IsAdmin"] ?? false);
    var incidents = Model.ToList();
    int currentPage = (int)(ViewBag.CurrentPage ?? 1);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    int totalItems = (int)(ViewBag.TotalItems ?? incidents.Count);
    int pageSize = (int)(ViewBag.PageSize ?? 20);
    var newest = ViewBag.NewestIncident as MBS_SAP.Models.IncidentNews ?? incidents.FirstOrDefault();
}

<style>
    .incident-page { animation: fadeInUp 0.35s ease-out; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .incident-top-banner {
        background: linear-gradient(135deg, #dc2626, #f43f5e);
        border-bottom-left-radius: 24px;
        border-bottom-right-radius: 24px;
        padding: 28px 20px 24px;
        color: #fff;
        text-align: center;
        margin: -20px -20px 20px -20px;
    }

    .newest-card {
        border: 1px solid var(--border-color);
        background: var(--bg-card);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 16px;
    }

    .newest-header {
        background: linear-gradient(135deg, rgba(244,63,94,0.16), rgba(220,38,38,0.08));
        border-bottom: 1px solid var(--border-color);
        padding: 10px 14px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #f43f5e;
    }

    .newest-body {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 14px;
        padding: 14px;
    }

    .newest-image {
        width: 130px;
        height: 96px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid var(--border-color);
    }

    .newest-placeholder {
        width: 130px;
        height: 96px;
        border-radius: 10px;
        border: 1px dashed var(--border-color);
        background: rgba(148,163,184,0.07);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        font-size: 11px;
        text-align: center;
        padding: 8px;
    }

    .newest-title {
        font-size: 16px;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 8px;
        line-height: 1.35;
    }

    .newest-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        color: var(--text-muted);
        font-size: 11px;
        margin-bottom: 8px;
    }

    .newest-desc {
        color: var(--text-muted);
        font-size: 12px;
        line-height: 1.55;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .incident-table-card {
        border: 1px solid var(--border-color);
        border-radius: 16px;
        overflow: hidden;
        background: var(--bg-card);
    }

    .incident-table-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 14px;
        border-bottom: 1px solid var(--border-color);
        background: rgba(148,163,184,0.08);
    }

    .incident-table-title {
        margin: 0;
        font-size: 13px;
        font-weight: 800;
        color: var(--text-main);
    }

    .incident-table-wrap {
        overflow: auto;
    }

    .incident-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1020px;
    }

    .incident-table thead th {
        background: rgba(15,23,42,0.88);
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .4px;
        padding: 11px 10px;
        text-transform: uppercase;
        border-right: 1px solid rgba(255,255,255,0.08);
        white-space: nowrap;
    }

    .incident-table tbody td {
        padding: 10px;
        border-bottom: 1px solid var(--border-color);
        font-size: 12px;
        color: var(--text-main);
        vertical-align: middle;
    }

    .incident-table tbody tr:nth-child(even) {
        background: rgba(148,163,184,0.05);
    }

    .incident-table tbody tr:hover {
        background: rgba(56,189,248,0.08);
    }

    .badge-soft {
        display: inline-block;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 700;
        padding: 3px 10px;
        white-space: nowrap;
    }

    .badge-nearmiss { background: rgba(34,197,94,.2); color: #15803d; }
    .badge-property { background: rgba(245,158,11,.2); color: #b45309; }
    .badge-firstaid { background: rgba(59,130,246,.2); color: #1d4ed8; }
    .badge-medical { background: rgba(139,92,246,.2); color: #6d28d9; }
    .badge-default { background: rgba(148,163,184,.22); color: #334155; }

    .row-title {
        max-width: 260px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 600;
    }

    .row-content {
        max-width: 280px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--text-muted);
    }

    .img-chip {
        font-size: 11px;
        font-weight: 700;
        border-radius: 999px;
        padding: 3px 8px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .img-chip-ok { background: rgba(34,197,94,.18); color: #166534; }
    .img-chip-empty { background: rgba(148,163,184,.2); color: #475569; }

    .btn-table {
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
        padding: 5px 8px;
        border: 1px solid var(--border-color);
        background: #fff;
        color: #0f172a;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .btn-table:hover {
        background: #f8fafc;
        color: #0f172a;
        text-decoration: none;
    }

    .btn-table-edit {
        border-color: rgba(37,99,235,.35);
        color: #1d4ed8;
    }

    .incident-pager {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 14px;
        flex-wrap: wrap;
    }

    .pager-link {
        min-width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: #fff;
        color: #0f172a;
        text-decoration: none;
        font-size: 12px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
    }

    .pager-link:hover {
        text-decoration: none;
        color: #0f172a;
        background: #f8fafc;
    }

    .pager-link.active {
        background: #0ea5e9;
        border-color: #0ea5e9;
        color: #fff;
    }

    .pager-link.disabled {
        opacity: .45;
        pointer-events: none;
    }

    @@media (max-width: 768px) {
        .newest-body {
            grid-template-columns: 1fr;
        }

        .newest-image,
        .newest-placeholder {
            width: 100%;
            height: 180px;
        }
    }
</style>

<div class="incident-page pb-4">
    <div class="incident-top-banner">
        <i class="bi bi-exclamation-triangle-fill d-block mb-2" style="font-size: 30px;"></i>
        <h4 style="font-weight: 800; margin-bottom: 4px; letter-spacing: .4px;">DATA INSIDEN</h4>
        <p style="margin: 0; font-size: 12px; opacity: .92;">Data ditampilkan dari yang paling baru agar monitoring lebih cepat.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 mb-3" role="alert" style="background-color: rgba(16, 185, 129, 0.15); color: var(--color-green); border-radius: 12px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 mb-3" role="alert" style="background-color: rgba(244, 63, 94, 0.15); color: var(--color-red); border-radius: 12px;">
            <i class="bi bi-x-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-sap-primary w-100 py-2 mb-3" style="border-radius: 12px; font-weight: 700;">
            <i class="bi bi-plus-circle-fill me-2"></i> Tambah Data Insiden
        </a>
    }

    @if (!incidents.Any())
    {
        <div class="card-sap text-center py-5 text-muted">
            <i class="bi bi-journal-x d-block mb-3" style="font-size: 44px;"></i>
            <h5>Belum ada data insiden</h5>
            <p class="mb-0">Data akan muncul di sini setelah input dilakukan.</p>
        </div>
    }
    else
    {
        if (newest != null)
        {
            var newestBadge = GetCategoryBadgeClass(newest.Kategori);
            <div class="newest-card">
                <div class="newest-header">
                    <i class="bi bi-stars me-1"></i> Data Insiden Paling Baru
                </div>
                <div class="newest-body">
                    @if (!string.IsNullOrWhiteSpace(newest.GambarUrl))
                    {
                        <img src="@newest.GambarUrl" alt="@newest.Judul" class="newest-image" />
                    }
                    else
                    {
                        <div class="newest-placeholder">
                            Belum ada ilustrasi
                        </div>
                    }
                    <div>
                        <div class="newest-title">@newest.Judul</div>
                        <div class="newest-meta">
                            <span><i class="bi bi-hash"></i> ID @newest.Id</span>
                            <span><i class="bi bi-calendar3"></i> Input @newest.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                            @if (newest.TanggalKejadian.HasValue)
                            {
                                <span><i class="bi bi-clock-history"></i> Kejadian @newest.TanggalKejadian.Value.ToString("dd MMM yyyy")</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(newest.Lokasi))
                            {
                                <span><i class="bi bi-geo-alt-fill"></i> @newest.Lokasi</span>
                            }
                            <span class="badge-soft @newestBadge">@(newest.Kategori ?? "-")</span>
                        </div>
                        <p class="newest-desc">@newest.Konten</p>
                    </div>
                </div>
            </div>
        }

        <div class="incident-table-card">
            <div class="incident-table-head">
                <h6 class="incident-table-title"><i class="bi bi-table me-1"></i> Tabel Data Insiden</h6>
                <span style="font-size:11px; color: var(--text-muted);">Total @totalItems data | Halaman @currentPage dari @totalPages</span>
            </div>

            <div class="incident-table-wrap">
                <table class="incident-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;">ID</th>
                            <th style="width: 210px;">Judul</th>
                            <th style="width: 120px;">Kategori</th>
                            <th style="width: 140px;">Tgl Kejadian</th>
                            <th style="width: 180px;">Lokasi</th>
                            <th style="width: 230px;">Keterangan</th>
                            <th style="width: 120px;">Ilustrasi</th>
                            <th style="width: 160px;">Diinput</th>
                            <th style="width: 160px;">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in incidents)
                        {
                            var badgeClass = GetCategoryBadgeClass(item.Kategori);
                            <tr>
                                <td><strong>#@item.Id</strong></td>
                                <td>
                                    <div class="row-title" title="@item.Judul">@item.Judul</div>
                                </td>
                                <td>
                                    <span class="badge-soft @badgeClass">@(item.Kategori ?? "-")</span>
                                </td>
                                <td>
                                    @(item.TanggalKejadian?.ToString("dd MMM yyyy") ?? "-")
                                </td>
                                <td title="@item.Lokasi">@(string.IsNullOrWhiteSpace(item.Lokasi) ? "-" : item.Lokasi)</td>
                                <td>
                                    <div class="row-content" title="@item.Konten">@item.Konten</div>
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.GambarUrl))
                                    {
                                        <span class="img-chip img-chip-empty"><i class="bi bi-image"></i> Belum</span>
                                    }
                                    else
                                    {
                                        <span class="img-chip img-chip-ok"><i class="bi bi-check2-circle"></i> Ada</span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Detail" asp-route-id="@item.Id" class="btn-table">
                                            <i class="bi bi-eye"></i> Detail
                                        </a>

                                        @if (isAdmin)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-table btn-table-edit" title="Edit data dan tambah ilustrasi">
                                                <i class="bi bi-pencil-square"></i> Edit
                                            </a>

                                            <form asp-action="Delete" method="post" onsubmit="return confirm('Yakin hapus data insiden ini?');" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn-table" style="color:#dc2626; border-color:rgba(220,38,38,.35);">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="incident-pager pb-3 px-2">
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize" class="pager-link @(currentPage <= 1 ? "disabled" : string.Empty)">
                        <i class="bi bi-chevron-left"></i>
                    </a>

                    @for (int p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                    {
                        <a asp-action="Index" asp-route-page="@p" asp-route-pageSize="@pageSize" class="pager-link @(p == currentPage ? "active" : string.Empty)">@p</a>
                    }

                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize" class="pager-link @(currentPage >= totalPages ? "disabled" : string.Empty)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </div>
            }
        </div>
    }
</div>

@functions {
    private static string GetCategoryBadgeClass(string? category)
    {
        var c = (category ?? string.Empty).Trim().ToLowerInvariant();
        if (c.Contains("near")) return "badge-nearmiss";
        if (c.Contains("property")) return "badge-property";
        if (c.Contains("first aid")) return "badge-firstaid";
        if (c.Contains("medical")) return "badge-medical";
        return "badge-default";
    }
}

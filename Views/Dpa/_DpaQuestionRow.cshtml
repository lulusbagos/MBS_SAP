@{
    var prefix = (string)ViewData["prefix"]!;
    var idx = (int)ViewData["idx"]!;
    var question = (string)ViewData["question"]!;
    var globalIdx = (int)ViewData["globalIdx"]!;
}

<div class="checkpoint-row py-3 border-bottom border-secondary mb-2">
    <div class="mb-2">
        <span class="text-white fw-semibold" style="font-size: 13px;">@globalIdx. @question</span>
    </div>
    <div class="dpa-score-group d-flex flex-wrap gap-1" data-prefix="@prefix" data-idx="@idx">
        <input type="hidden" name="@(prefix)_score_@idx" value="5" />

        <button type="button" class="dpa-score-btn active" data-value="5" style="
            padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(34,197,94,0.3);
            background: rgba(34,197,94,0.08); color: #22c55e; font-size: 11px; font-weight: 700;
            cursor: pointer; transition: all 0.2s ease; outline: none;
        ">
            <i class="bi bi-star-fill me-1" style="font-size: 9px;"></i>Sangat Baik
        </button>

        <button type="button" class="dpa-score-btn" data-value="4" style="
            padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(56,189,248,0.3);
            background: rgba(56,189,248,0.08); color: #38bdf8; font-size: 11px; font-weight: 700;
            cursor: pointer; transition: all 0.2s ease; outline: none;
        ">
            <i class="bi bi-star-fill me-1" style="font-size: 9px;"></i>Baik
        </button>

        <button type="button" class="dpa-score-btn" data-value="3" style="
            padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(245,158,11,0.3);
            background: rgba(245,158,11,0.08); color: #f59e0b; font-size: 11px; font-weight: 700;
            cursor: pointer; transition: all 0.2s ease; outline: none;
        ">
            <i class="bi bi-star-half me-1" style="font-size: 9px;"></i>Cukup
        </button>

        <button type="button" class="dpa-score-btn" data-value="2" style="
            padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(249,115,22,0.3);
            background: rgba(249,115,22,0.08); color: #f97316; font-size: 11px; font-weight: 700;
            cursor: pointer; transition: all 0.2s ease; outline: none;
        ">
            <i class="bi bi-star me-1" style="font-size: 9px;"></i>Kurang
        </button>

        <button type="button" class="dpa-score-btn" data-value="1" style="
            padding: 6px 12px; border-radius: 20px; border: 1px solid rgba(244,63,94,0.3);
            background: rgba(244,63,94,0.08); color: #f43f5e; font-size: 11px; font-weight: 700;
            cursor: pointer; transition: all 0.2s ease; outline: none;
        ">
            <i class="bi bi-x-circle me-1" style="font-size: 9px;"></i>Sangat Kurang
        </button>
    </div>
</div>

<style>
    .dpa-score-btn.active {
        box-shadow: 0 0 0 2px currentColor, 0 2px 8px rgba(0,0,0,0.2) !important;
        transform: scale(1.05);
    }
    .dpa-score-btn:hover:not(.active) {
        transform: scale(1.03);
        filter: brightness(1.2);
    }
</style>

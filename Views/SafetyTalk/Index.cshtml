@model IEnumerable<MBS_SAP.Models.SafetyTalk>
@{
    ViewData["Title"] = "Safety Talk - SAP";
}

<div class="animate-fade-in pb-4">
    <!-- Header with Banner -->
    <div class="position-relative mb-4" style="margin: -20px -20px 20px -20px;">
        <div style="background: linear-gradient(135deg, #e11d48, #f43f5e); border-bottom-left-radius: 24px; border-bottom-right-radius: 24px; padding: 32px 20px 24px; text-align: center; position: relative; overflow: hidden;">
            <!-- Decorative circle -->
            <div style="position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
            <div style="position: absolute; bottom: -30px; left: -10px; width: 80px; height: 80px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
            
            <i class="bi bi-megaphone-fill text-white mb-2 d-block" style="font-size: 32px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));"></i>
            <h4 style="font-weight: 800; color: white; text-shadow: 0 2px 4px rgba(0,0,0,0.2); margin-bottom: 4px; letter-spacing: 0.5px;">SAFETY TALK</h4>
            <p style="color: rgba(255,255,255,0.9); font-size: 12px; margin: 0; font-weight: 500;">Dokumentasikan agenda pengarahan K3.</p>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 mb-4" role="alert" style="background-color: rgba(244, 63, 94, 0.15); color: var(--color-red); border-radius: 12px;">
            <i class="bi bi-x-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Hybrid Grid Layout: Form and List side-by-side on laptop, stacked on mobile -->
    <div class="form-responsive-row">
        
        <!-- Form Column -->
        <div class="card-sap border-red-accent">
            <form asp-controller="SafetyTalk" asp-action="Submit" method="post" enctype="multipart/form-data" id="safetyTalkForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="talkId" name="id" value="" />
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0 text-white" style="font-weight: 700;" id="formTitle"><i class="bi bi-megaphone-fill me-2" style="color: #f43f5e;"></i>Catat Safety Talk Baru</h5>
                    <button type="button" class="btn btn-sm btn-outline-secondary d-none" id="btnCancelEdit" onclick="cancelEditSafetyTalk()">
                        <i class="bi bi-x-circle me-1"></i> Batal Edit
                    </button>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group-sap">
                        <label class="form-label-sap" for="tanggal">Tanggal Kegiatan</label>
                        <div class="input-sap-wrapper">
                            <i class="bi bi-calendar-event-fill input-sap-icon"></i>
                            <input type="date" id="tanggal" name="tanggal" class="input-sap" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                    </div>
                    <div class="col-md-6 form-group-sap">
                        <label class="form-label-sap" for="waktuStr">Waktu Mulai</label>
                        <div class="input-sap-wrapper">
                            <i class="bi bi-clock-fill input-sap-icon"></i>
                            <input type="time" id="waktuStr" name="waktuStr" class="input-sap" value="@DateTime.Now.ToString("HH:mm")" required />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group-sap">
                        <label class="form-label-sap" for="area">Area Utama</label>
                        <div class="input-sap-wrapper">
                            <i class="bi bi-geo-alt-fill input-sap-icon"></i>
                            <select id="area" name="area" class="input-sap" required>
                                <option value="" disabled selected>Pilih Area...</option>
                                <option value="Mining">Mining</option>
                                <option value="Haulroad">Haulroad</option>
                                <option value="Port">Port</option>
                                <option value="Supporting Area">Supporting Area</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6 form-group-sap">
                        <label class="form-label-sap" for="lokasi">Lokasi Spesifik</label>
                        <div class="input-sap-wrapper">
                            <i class="bi bi-geo-fill input-sap-icon"></i>
                            <input type="text" id="lokasi" name="lokasi" class="input-sap" placeholder="Klik ikon target di kanan untuk mengambil lokasi GPS..." style="padding-right: 40px;" readonly required />
                            <button type="button" class="btn btn-link p-0 position-absolute" id="btnGetLocation" style="right: 12px; top: 10px; color: var(--color-primary);" onclick="getLocation()" title="Ambil Lokasi GPS">
                                <i class="bi bi-crosshair"></i>
                            </button>
                        </div>
                        <small class="text-muted" style="font-size: 10px;">Klik ikon target untuk menggunakan GPS</small>
                    </div>
                </div>

                <div class="form-group-sap">
                    <label class="form-label-sap" for="detilLokasi">Detail Lokasi</label>
                    <div class="input-sap-wrapper">
                        <i class="bi bi-compass-fill input-sap-icon"></i>
                        <input type="text" id="detilLokasi" name="detilLokasi" class="input-sap" placeholder="Misal: Halaman Depan Pos 33" />
                    </div>
                </div>

                <div class="form-group-sap">
                    <label class="form-label-sap" for="judul">Judul / Topik Pembahasan</label>
                    <div class="input-sap-wrapper">
                        <i class="bi bi-megaphone-fill input-sap-icon"></i>
                        <input type="text" id="judul" name="judul" class="input-sap" placeholder="Misal: Statistik insiden 2025 dan kewaspadaan kerja" required />
                    </div>
                </div>

                <div class="form-group-sap">
                    <label class="form-label-sap" for="keterangan">Keterangan / Daftar Hadir / Notulen</label>
                    <div class="input-sap-wrapper">
                        <i class="bi bi-file-earmark-text-fill input-sap-icon" style="top: 14px;"></i>
                        <textarea id="keterangan" name="keterangan" class="input-sap" rows="3" placeholder="Masukkan ringkasan notulen talk, jumlah peserta, atau instansi terkait..." style="padding-left: 42px;"></textarea>
                    </div>
                </div>

                <div class="row">
                    <!-- Presenter Photo -->
                    <div class="col-6 form-group-sap mb-4">
                        <label class="form-label-sap">Foto Diri Presenter</label>
                        <input type="file" id="fotoDiriInput" name="fotoDiri" accept="image/*" capture="user" class="d-none" onchange="previewDiri(this)" />
                        <div class="upload-card" onclick="document.getElementById('fotoDiriInput').click()" style="padding: 16px 8px;">
                            <div id="diriPlaceholder">
                                <i class="bi bi-person-bounding-box" style="font-size: 20px;"></i>
                                <span class="d-block text-white" style="font-size: 11px; font-weight: 700; margin-top: 4px;">Ambil Foto Diri</span>
                            </div>
                            <div id="diriPreviewContainer" class="d-none">
                                <img id="diriPreview" src="" alt="Preview" style="max-width: 100%; max-height: 80px; border-radius: 6px;" />
                            </div>
                        </div>
                    </div>

                    <!-- Event Photo -->
                    <div class="col-6 form-group-sap mb-4">
                        <label class="form-label-sap">Foto Kegiatan Briefing</label>
                        <input type="file" id="fotoKegiatanInput" name="fotoKegiatan" accept="image/*" capture="environment" class="d-none" onchange="previewKegiatan(this)" />
                        <div class="upload-card" onclick="document.getElementById('fotoKegiatanInput').click()" style="padding: 16px 8px;">
                            <div id="kegiatanPlaceholder">
                                <i class="bi bi-camera-fill" style="font-size: 20px;"></i>
                                <span class="d-block text-white" style="font-size: 11px; font-weight: 700; margin-top: 4px;">Ambil Foto Briefing</span>
                            </div>
                            <div id="kegiatanPreviewContainer" class="d-none">
                                <img id="kegiatanPreview" src="" alt="Preview" style="max-width: 100%; max-height: 80px; border-radius: 6px;" />
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-sap-primary w-100 py-3" style="background-color: #f43f5e; border-color: #e11d48;">
                    <i class="bi bi-check-circle-fill me-2"></i> SIMPAN SAFETY TALK
                </button>
            </form>
        </div>

        <!-- History/List Column -->
        <div>
            <div class="history-header mb-3">
                <h6 class="text-white" style="font-weight: 700;"><i class="bi bi-card-list me-2" style="color: var(--color-primary);"></i>Log Briefing Keselamatan</h6>
            </div>
            
            @if (Model == null || !Model.Any())
            {
                <div class="card-sap text-center py-4 text-muted">
                    <i class="bi bi-inbox-fill d-block mb-2" style="font-size: 32px;"></i>
                    Belum ada safety briefing tercatat.
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @foreach (var item in Model)
                    {
                        <div class="card-sap border-red-accent mb-0">
                            
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span style="font-weight: 700; font-size: 14px; color: var(--text-main);">@item.Judul</span>
                                    <span class="d-block text-muted" style="font-size: 11px;"><i class="bi bi-geo-alt-fill me-1"></i>@(item.Lokasi ?? item.Area ?? "General")</span>
                                </div>
                                <span class="status-badge approved" style="font-size: 9px; background-color: rgba(244, 63, 94, 0.15); color: #f43f5e;">
                                    Selesai
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(item.Keterangan))
                            {
                                <p style="font-size: 11px; color: var(--text-muted); background-color: var(--bg-layout); padding: 8px; border-radius: 6px; margin: 8px 0 10px; border-left: 3px solid #f43f5e; white-space: pre-line;">
                                    @item.Keterangan
                                </p>
                            }

                            <!-- Images -->
                            <div class="d-flex gap-2 my-2">
                                @if (!string.IsNullOrEmpty(item.FotoDiri))
                                {
                                    <a href="@item.FotoDiri" target="_blank">
                                        <img src="@item.FotoDiri" alt="Presenter" style="max-height: 50px; border-radius: 4px; border: 1px solid var(--border-color);" />
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(item.FotoKegiatan))
                                {
                                    <a href="@item.FotoKegiatan" target="_blank">
                                        <img src="@item.FotoKegiatan" alt="Briefing" style="max-height: 50px; border-radius: 4px; border: 1px solid var(--border-color);" />
                                    </a>
                                }
                            </div>

                            <div class="d-flex justify-content-between align-items-center pt-2 mt-2" style="border-top: 1px solid var(--border-color); font-size: 11px; color: var(--text-muted);">
                                <div class="d-flex align-items-center gap-2">
                                    <span><i class="bi bi-person me-1"></i>@item.Nama</span>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-link text-muted p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border: 1px solid var(--border-color); background: var(--bg-card); font-size: 13px;">
                                            <li><a class="dropdown-item text-white" href="javascript:void(0)" onclick="editSafetyTalk(@item.Id)"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Laporan</a></li>
                                            <li><hr class="dropdown-divider border-secondary"></li>
                                            <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="deleteSafetyTalk(@item.Id)"><i class="bi bi-trash-fill me-2"></i>Hapus Laporan</a></li>
                                        </ul>
                                    </div>
                                </div>
                                <span><i class="bi bi-clock me-1"></i>@item.Tanggal.ToString("dd MMM yyyy") @item.Waktu.ToString(@"hh\:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        
    </div>
</div>

@section Scripts {
    <script>
        function previewDiri(input) {
            const file = input.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('diriPreview').src = e.target.result;
                    document.getElementById('diriPlaceholder').classList.add('d-none');
                    document.getElementById('diriPreviewContainer').classList.remove('d-none');
                }
                reader.readAsDataURL(file);
            }
        }

        function previewKegiatan(input) {
            const file = input.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('kegiatanPreview').src = e.target.result;
                    document.getElementById('kegiatanPlaceholder').classList.add('d-none');
                    document.getElementById('kegiatanPreviewContainer').classList.remove('d-none');
                }
                reader.readAsDataURL(file);
            }
        }

        // Geolocation Function
        function getLocation() {
            var btn = document.getElementById('btnGetLocation');
            var input = document.getElementById('lokasi');
            var detailInput = document.getElementById('detilLokasi');

            function buildSpecificLocationLabel(payload) {
                if (!payload) return '';

                const addr = payload.address || {};
                const candidates = [
                    addr.road,
                    addr.path,
                    addr.neighbourhood,
                    addr.suburb,
                    addr.village,
                    addr.hamlet,
                    addr.city_district,
                    addr.city,
                    addr.county,
                    addr.state
                ];

                const compact = candidates
                    .filter(function(x) { return typeof x === 'string' && x.trim().length > 0; })
                    .slice(0, 4)
                    .join(', ');

                if (compact) {
                    return compact;
                }

                return typeof payload.display_name === 'string' ? payload.display_name : '';
            }

            async function fillSpecificLocation(lat, lon) {
                if (!detailInput) {
                    return;
                }

                try {
                    const endpoint = 'https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=' + encodeURIComponent(lat) + '&lon=' + encodeURIComponent(lon) + '&zoom=18&addressdetails=1';
                    const response = await fetch(endpoint, {
                        headers: {
                            'Accept': 'application/json'
                        }
                    });

                    if (!response.ok) {
                        return;
                    }

                    const json = await response.json();
                    const resolved = buildSpecificLocationLabel(json);
                    if (resolved) {
                        detailInput.value = resolved;
                    }
                } catch (e) {
                    // Keep silent when reverse geocoding fails; GPS coordinates are still captured.
                }
            }
            
            if (navigator.geolocation) {
                // Show loading spinner
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="width: 14px; height: 14px;"></span>';
                
                navigator.geolocation.getCurrentPosition(async function(position) {
                    var lat = position.coords.latitude.toFixed(6);
                    var lon = position.coords.longitude.toFixed(6);
                    input.value = lat + ", " + lon;
                    await fillSpecificLocation(lat, lon);
                    btn.innerHTML = '<i class="bi bi-check-circle-fill text-success"></i>';
                }, function(error) {
                    alert('Gagal mendapatkan lokasi GPS: ' + error.message);
                    btn.innerHTML = '<i class="bi bi-crosshair text-danger"></i>';
                }, {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 0
                });
            } else {
                alert("Geolocation tidak didukung oleh browser ini.");
            }
        }

        function cancelEditSafetyTalk() {
            $('#safetyTalkForm')[0].reset();
            $('#talkId').val('');
            $('#formTitle').html('<i class="bi bi-megaphone-fill me-2" style="color: #f43f5e;"></i>Catat Safety Talk Baru');
            $('#btnCancelEdit').addClass('d-none');
            
            // Reset images
            $('#diriPreview, #kegiatanPreview').attr('src', '');
            $('#diriPreviewContainer, #kegiatanPreviewContainer').addClass('d-none');
            $('#diriPlaceholder, #kegiatanPlaceholder').removeClass('d-none');

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function editSafetyTalk(id) {
            $.get('/SafetyTalk/GetData/' + id, function(data) {
                if (data) {
                    $('#talkId').val(data.id);
                    
                    // Format dates and times
                    if (data.tanggal) $('#tanggal').val(data.tanggal.split('T')[0]);
                    if (data.waktu) $('#waktuStr').val(data.waktu.substring(0, 5));
                    
                    // Selects
                    $('#area').val(data.area).change();

                    // Inputs
                    $('#lokasi').val(data.lokasi);
                    $('#detilLokasi').val(data.detilLokasi);
                    $('#judul').val(data.judul);
                    $('#keterangan').val(data.keterangan);

                    $('#formTitle').html('<i class="bi bi-pencil-square me-2" style="color: var(--color-primary);"></i>Edit Laporan Safety Talk');
                    $('#btnCancelEdit').removeClass('d-none');
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
            }).fail(function() {
                alert("Gagal mengambil data laporan. Laporan mungkin sudah dihapus.");
            });
        }

        function deleteSafetyTalk(id) {
            if (confirm("Apakah Anda yakin ingin menghapus laporan ini? Data yang dihapus tidak dapat dikembalikan.")) {
                var form = $('<form action="/SafetyTalk/Delete/' + id + '" method="post">' +
                             '<input type="hidden" name="__RequestVerificationToken" value="' + $('input[name="__RequestVerificationToken"]').val() + '" />' +
                             '</form>');
                $('body').append(form);
                form.submit();
            }
        }

        $(document).ready(function() {
            // Prevent double submission
            $('#safetyTalkForm').on('submit', function() {
                var btn = $(this).find('button[type="submit"]');
                if (btn.prop('disabled')) {
                    return false;
                }
                btn.prop('disabled', true);
                var originalText = btn.html();
                btn.html('<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>MENYIMPAN...');
                
                // Allow form to submit normally
                return true;
            });
        });
    </script>
}
